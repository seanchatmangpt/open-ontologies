@prefix port:   <https://ggen.io/onto/portfolio-os/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:<http://purl.org/dc/terms/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix earl:   <http://www.w3.org/ns/earl#> .
@prefix odrl:   <http://www.w3.org/ns/odrl/2/> .
@prefix org:    <http://www.w3.org/ns/org#> .
@prefix qb:     <http://purl.org/linked-data/cube#> .

# ============================================================================
# Portfolio Operating System Ontology
# ============================================================================
#
# RDF mapping of the PR-Ralph portfolio operating system. Defines the core
# concepts:
#
#   - port:Cell — a repository or autonomous unit of work
#   - port:Tick — a deterministic execution cycle (DFLSS phase)
#   - port:Receipt — proof of execution (BLAKE3-signed chain)
#   - port:Andon — an alert/exception signal (test result equivalent)
#   - port:Obligation — a work unit (offer/permission equivalent)
#   - port:Convergence — a portfolio-level state observation
#
# The portfolio OS is the top-level governing structure across 30+ cells.
# Authority flows through the receipt chain: every cell tick produces a receipt,
# every receipt is signed and chained, every cell observes the chain state.
#
# This ontology makes explicit:
#   1. What is a cell (org:OrganizationalUnit with autonomy bounds)
#   2. What is a tick (prov:Activity with deterministic gates)
#   3. What is a receipt (prov:Entity with cryptographic proof)
#   4. What signals andon (earl:TestResult for exceptions)
#   5. What defines an obligation (odrl:Offer with explicit permissions/prohibitions)
#   6. What measures portfolio health (qb:Observation of cells, receipts, andons)
# ============================================================================

port:Ontology a owl:Ontology ;
  rdfs:label    "Portfolio Operating System"@en ;
  rdfs:comment  "RDF mapping of the PR-Ralph portfolio operating system. Models cells, ticks, receipts, andons, obligations, and portfolio convergence."@en ;
  dcterms:creator "Sean Chatman" ;
  dcterms:license <https://opensource.org/licenses/MIT> ;
  owl:versionInfo "1.0.0" ;
  owl:imports <http://www.w3.org/ns/prov#Ontology> ;
  owl:imports <http://www.w3.org/ns/org#Ontology> ;
  owl:imports <http://www.w3.org/ns/earl#> ;
  owl:imports <http://www.w3.org/ns/odrl/2/> ;
  owl:imports <http://purl.org/linked-data/cube#> .

# ── Core classes ────────────────────────────────────────────────────────────

port:Cell a owl:Class ;
  rdfs:label   "Portfolio Cell"@en ;
  rdfs:comment "A repository or autonomous work unit in the portfolio. Each cell has defined boundaries, obligation queue, receipt chain, and andon state."@en ;
  rdfs:subClassOf org:OrganizationalUnit ;
  rdfs:comment "A cell is an org:OrganizationalUnit that owns a git repo, emits receipts, and participates in the portfolio tick cycle."@en .

port:Tick a owl:Class ;
  rdfs:label   "Portfolio Tick"@en ;
  rdfs:comment "A deterministic execution cycle in the portfolio. One tick per invocation of the portfolio kernel."@en ;
  rdfs:subClassOf prov:Activity ;
  rdfs:comment "Each tick is a prov:Activity with a start time, end time, inputs (queue state), and outputs (receipts, andon events)."@en .

port:Receipt a owl:Class ;
  rdfs:label   "Portfolio Receipt"@en ;
  rdfs:comment "Proof of execution: BLAKE3-signed chain entry recording a tick outcome, cell action, or obligation resolution."@en ;
  rdfs:subClassOf prov:Entity ;
  rdfs:comment "A receipt is generated by a port:Tick, carries cryptographic identity (signature, hash), and links to prior receipt via prev_hash."@en .

port:Andon a owl:Class ;
  rdfs:label   "Portfolio Andon"@en ;
  rdfs:comment "An alert or exception signal. Blocks portfolio progress until resolved (recovered or signed off by Sean)."@en ;
  rdfs:subClassOf earl:TestResult ;
  rdfs:comment "An andon is an earl:TestResult with severity (red/orange/yellow), auto-clearable flag, and recovery receipt reference."@en .

port:Obligation a owl:Class ;
  rdfs:label   "Portfolio Obligation"@en ;
  rdfs:comment "A unit of work in the portfolio queue. Links an action, a cell, and mandatory/optional completeness requirements."@en ;
  rdfs:subClassOf odrl:Offer ;
  rdfs:comment "An obligation is an odrl:Offer with explicit permissions (what agent can do) and prohibitions (what is blocked)."@en .

port:Convergence a owl:Class ;
  rdfs:label   "Portfolio Convergence"@en ;
  rdfs:comment "A portfolio-level observation: snapshot of cell states, receipt chain head, active andons, and queue depth."@en ;
  rdfs:subClassOf qb:Observation ;
  rdfs:comment "A convergence is a qb:Observation that measures portfolio health across multiple dimensions (time, cell, andon state)."@en .

port:ReceiptChain a owl:Class ;
  rdfs:label   "Receipt Chain"@en ;
  rdfs:comment "The append-only chain of all portfolio receipts. Immutable; chain integrity is the source of truth for authorization."@en .

port:ObligationQueue a owl:Class ;
  rdfs:label   "Obligation Queue"@en ;
  rdfs:comment "The set of active obligations in the portfolio, partitioned by state: pending, in-flight, done, blocked, needs-human."@en .

# ── Properties ──────────────────────────────────────────────────────────────

port:cellId a owl:DatatypeProperty ;
  rdfs:label "cell ID"@en ;
  rdfs:domain port:Cell ;
  rdfs:range xsd:string ;
  rdfs:comment "Unique identifier for the cell (repository name or cell code)."@en .

port:cellRepo a owl:DatatypeProperty ;
  rdfs:label "cell repository"@en ;
  rdfs:domain port:Cell ;
  rdfs:range xsd:string ;
  rdfs:comment "Git repository path or URL for the cell."@en .

port:cellStatus a owl:DatatypeProperty ;
  rdfs:label "cell status"@en ;
  rdfs:domain port:Cell ;
  rdfs:range xsd:string ;
  rdfs:comment "Current status: active, frozen, quarantined, retired."@en .

port:cellAgent a owl:DatatypeProperty ;
  rdfs:label "cell agent"@en ;
  rdfs:domain port:Cell ;
  rdfs:range xsd:string ;
  rdfs:comment "Assigned agent (Claude, Gemini, human name) for this cell's work orders."@en .

port:tickId a owl:DatatypeProperty ;
  rdfs:label "tick ID"@en ;
  rdfs:domain port:Tick ;
  rdfs:range xsd:string ;
  rdfs:comment "Sequential tick identifier (e.g., tick-000050)."@en .

port:tickPhase a owl:DatatypeProperty ;
  rdfs:label "tick phase"@en ;
  rdfs:domain port:Tick ;
  rdfs:range xsd:string ;
  rdfs:comment "DFLSS phase: Define, Measure, Analyze, Design, Improve, Verify."@en .

port:tickCell a owl:ObjectProperty ;
  rdfs:label "tick cell"@en ;
  rdfs:domain port:Tick ;
  rdfs:range port:Cell ;
  rdfs:comment "The cell acted upon in this tick."@en .

port:tickStartTime a owl:DatatypeProperty ;
  rdfs:label "tick start time"@en ;
  rdfs:domain port:Tick ;
  rdfs:range xsd:dateTime ;
  rdfs:comment "Timestamp when the tick started."@en .

port:tickEndTime a owl:DatatypeProperty ;
  rdfs:label "tick end time"@en ;
  rdfs:domain port:Tick ;
  rdfs:range xsd:dateTime ;
  rdfs:comment "Timestamp when the tick completed."@en .

port:receiptId a owl:DatatypeProperty ;
  rdfs:label "receipt ID"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range xsd:string ;
  rdfs:comment "Unique receipt identifier (hash or sequential number)."@en .

port:receiptHash a owl:DatatypeProperty ;
  rdfs:label "receipt hash"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range xsd:string ;
  rdfs:comment "BLAKE3 hash of the receipt content."@en .

port:receiptPrevHash a owl:DatatypeProperty ;
  rdfs:label "receipt previous hash"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range xsd:string ;
  rdfs:comment "BLAKE3 hash of the previous receipt in the chain. Links to parent."@en .

port:receiptSignature a owl:DatatypeProperty ;
  rdfs:label "receipt signature"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range xsd:string ;
  rdfs:comment "Ed25519 signature of the receipt hash (signed by portfolio signer, e.g., Sean)."@en .

port:receiptContent a owl:DatatypeProperty ;
  rdfs:label "receipt content"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range xsd:string ;
  rdfs:comment "JSON or canonical serialization of the receipt data."@en .

port:receiptTimestamp a owl:DatatypeProperty ;
  rdfs:label "receipt timestamp"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range xsd:dateTime ;
  rdfs:comment "ISO 8601 timestamp when the receipt was emitted."@en .

port:wasGeneratedByTick a owl:ObjectProperty ;
  rdfs:label "was generated by tick"@en ;
  rdfs:domain port:Receipt ;
  rdfs:range port:Tick ;
  rdfs:comment "The tick that generated this receipt."@en ;
  rdfs:subPropertyOf prov:wasGeneratedBy .

port:andonCode a owl:DatatypeProperty ;
  rdfs:label "andon code"@en ;
  rdfs:domain port:Andon ;
  rdfs:range xsd:string ;
  rdfs:comment "Andon type code (e.g., STALE_LOCK, DEFECT_DETECTED, HUMAN_DECISION_NEEDED)."@en .

port:andonSeverity a owl:DatatypeProperty ;
  rdfs:label "andon severity"@en ;
  rdfs:domain port:Andon ;
  rdfs:range xsd:string ;
  rdfs:comment "Severity level: red (critical, blocks), orange (warning), yellow (info)."@en .

port:andonMessage a owl:DatatypeProperty ;
  rdfs:label "andon message"@en ;
  rdfs:domain port:Andon ;
  rdfs:range xsd:string ;
  rdfs:comment "Human-readable description of the andon condition."@en .

port:andonCell a owl:ObjectProperty ;
  rdfs:label "andon cell"@en ;
  rdfs:domain port:Andon ;
  rdfs:range port:Cell ;
  rdfs:comment "The cell that triggered the andon."@en .

port:andonAutoCleared a owl:DatatypeProperty ;
  rdfs:label "andon auto cleared"@en ;
  rdfs:domain port:Andon ;
  rdfs:range xsd:boolean ;
  rdfs:comment "True if the andon was automatically cleared (e.g., STALE_LOCK cleared after timeout)."@en .

port:andonRecoveryReceipt a owl:ObjectProperty ;
  rdfs:label "andon recovery receipt"@en ;
  rdfs:domain port:Andon ;
  rdfs:range port:Receipt ;
  rdfs:comment "The receipt documenting recovery from this andon. Required even for auto-clearable andons."@en .

port:obligationId a owl:DatatypeProperty ;
  rdfs:label "obligation ID"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range xsd:string ;
  rdfs:comment "Unique obligation identifier."@en .

port:obligationAction a owl:DatatypeProperty ;
  rdfs:label "obligation action"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range xsd:string ;
  rdfs:comment "What the obligation requires: implement, review, sign, dispatch, etc."@en .

port:obligationCell a owl:ObjectProperty ;
  rdfs:label "obligation cell"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range port:Cell ;
  rdfs:comment "The cell that must execute the obligation."@en .

port:obligationStatus a owl:DatatypeProperty ;
  rdfs:label "obligation status"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range xsd:string ;
  rdfs:comment "Current status: pending, in-flight, done, blocked, needs-human."@en .

port:obligationAssignee a owl:DatatypeProperty ;
  rdfs:label "obligation assignee"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range xsd:string ;
  rdfs:comment "Assigned agent or person responsible for the obligation."@en .

port:obligationHasPermission a owl:ObjectProperty ;
  rdfs:label "obligation has permission"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range odrl:Permission ;
  rdfs:comment "Explicit permissions defining what the assignee may do."@en ;
  rdfs:subPropertyOf odrl:permission .

port:obligationHasProhibition a owl:ObjectProperty ;
  rdfs:label "obligation has prohibition"@en ;
  rdfs:domain port:Obligation ;
  rdfs:range odrl:Prohibition ;
  rdfs:comment "Explicit prohibitions defining what the assignee may not do."@en ;
  rdfs:subPropertyOf odrl:prohibition .

port:convergenceTimestamp a owl:DatatypeProperty ;
  rdfs:label "convergence timestamp"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:dateTime ;
  rdfs:comment "Timestamp of this convergence observation."@en .

port:convergenceCells a owl:DatatypeProperty ;
  rdfs:label "convergence cells"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of cells in the portfolio at this observation."@en .

port:convergenceActiveCells a owl:DatatypeProperty ;
  rdfs:label "convergence active cells"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of active (non-frozen, non-retired) cells."@en .

port:convergenceReceiptChainHead a owl:ObjectProperty ;
  rdfs:label "convergence receipt chain head"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range port:Receipt ;
  rdfs:comment "The most recent receipt in the chain."@en .

port:convergenceActiveAndons a owl:DatatypeProperty ;
  rdfs:label "convergence active andons"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of unresolved andons blocking portfolio progress."@en .

port:convergenceQueueDepth a owl:DatatypeProperty ;
  rdfs:label "convergence queue depth"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Total obligations in the queue (pending + in-flight + needs-human)."@en .

port:convergenceQueuePending a owl:DatatypeProperty ;
  rdfs:label "convergence queue pending"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Obligations in pending state (waiting to start)."@en .

port:convergenceQueueInflight a owl:DatatypeProperty ;
  rdfs:label "convergence queue in-flight"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Obligations currently being executed."@en .

port:convergenceQueueNeedsHuman a owl:DatatypeProperty ;
  rdfs:label "convergence queue needs human"@en ;
  rdfs:domain port:Convergence ;
  rdfs:range xsd:integer ;
  rdfs:comment "Obligations awaiting human (Sean) decision or signature."@en .

port:chainHead a owl:ObjectProperty ;
  rdfs:label "chain head"@en ;
  rdfs:domain port:ReceiptChain ;
  rdfs:range port:Receipt ;
  rdfs:comment "The most recent receipt in the chain."@en .

port:chainIntegrity a owl:DatatypeProperty ;
  rdfs:label "chain integrity"@en ;
  rdfs:domain port:ReceiptChain ;
  rdfs:range xsd:boolean ;
  rdfs:comment "True if all receipts in the chain verify (hash linkage and signatures)."@en .

port:queueState a owl:ObjectProperty ;
  rdfs:label "queue state"@en ;
  rdfs:domain port:ObligationQueue ;
  rdfs:range port:Obligation ;
  rdfs:comment "An obligation in this queue."@en .

port:queuePendingCount a owl:DatatypeProperty ;
  rdfs:label "queue pending count"@en ;
  rdfs:domain port:ObligationQueue ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of pending obligations."@en .

port:queueInflightCount a owl:DatatypeProperty ;
  rdfs:label "queue in-flight count"@en ;
  rdfs:domain port:ObligationQueue ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of in-flight obligations."@en .

port:queueNeedsHumanCount a owl:DatatypeProperty ;
  rdfs:label "queue needs human count"@en ;
  rdfs:domain port:ObligationQueue ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of obligations awaiting human action."@en .

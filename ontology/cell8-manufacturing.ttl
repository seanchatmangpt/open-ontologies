@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix dcat:     <http://www.w3.org/ns/dcat#> .
@prefix schema:   <https://schema.org/> .
@prefix spdx:     <http://spdx.org/rdf/terms#> .
@prefix earl:     <http://www.w3.org/ns/earl#> .
@prefix odrl:     <http://www.w3.org/ns/odrl/2/> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .

# ============================================================================
# Cell8 Manufacturing Requirements — Verifier-Executed Gates
# ============================================================================
#
# These are the REQUIRED EARL assertions for any Cell8 artifact to be admitted.
# Each assertion represents a verifier-executed test, not a claim.
#
# The manufacturing law in production terms:
#
# CellReady = A1 ∧ A2 ∧ A3 ∧ A4 ∧ A5 ∧ A6 ∧ A7 ∧ A8 ∧ A9 ∧ A10 ∧ A11 ∧ A12 ∧ A13
#
# where:
#   A1  = Artifact checksum verifies
#   A2  = WASM binary validates
#   A3  = Rust byte-law source section present
#   A4  = Embedded supervision runtime present and probe passes
#   A5  = Host-fit probe passes
#   A6  = Receipt emission probe passes
#   A7  = Replay fixture section present
#   A8  = Known-good replay passes (deterministic)
#   A9  = Known-bad refusal passes (rejection works)
#   A10 = No-PII refusal passes (safety boundary works)
#   A11 = JSON projection boundary passes (not authority)
#   A12 = Runtime capability probe passes
#   A13 = CellReady receipt emitted and verifies
#
# If ANY assertion is missing or failed: CellReady = 0
# ============================================================================

# Gate definitions (SKOS Concept Scheme reference)
# These are used in EARL assertion objects to identify the gate being tested

[]
  a skos:ConceptScheme ;
  dcterms:title "Cell8 Manufacturing Gates" ;
  dcterms:description "13 required gates for Cell8 artifact admission." ;
  skos:prefLabel "cell8:manufacturing_gates" ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A1" ;
    skos:prefLabel "Artifact checksum verifies" ;
    skos:definition "SHA256 or BLAKE3 of artifact matches manufacturing record."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A2" ;
    skos:prefLabel "WASM binary validates" ;
    skos:definition "WASM module parses and contains all required sections."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A3" ;
    skos:prefLabel "Rust byte-law source section present" ;
    skos:definition "Custom Rust section with fixed-layout struct definitions found and checksum validated."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A4" ;
    skos:prefLabel "Embedded supervision runtime present and probe passes" ;
    skos:definition "AtomVM binary image found; supervision probe confirms process lifecycle management works."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A5" ;
    skos:prefLabel "Host-fit probe passes" ;
    skos:definition "Target host CPU, memory, ISA, and capability set match declared requirements."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A6" ;
    skos:prefLabel "Receipt emission probe passes" ;
    skos:definition "Verifier confirms artifact can emit Receipt64 and BLAKE3 hash chain works."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A7" ;
    skos:prefLabel "Replay fixture section present" ;
    skos:definition "Known-good and known-bad fixture corpus is embedded and accessible."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A8" ;
    skos:prefLabel "Known-good replay passes (deterministic)" ;
    skos:definition "Artifact executed with known-good fixture produces deterministic output hash (multiple runs match)."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A9" ;
    skos:prefLabel "Known-bad refusal passes (rejection works)" ;
    skos:definition "Artifact supplied known-bad fixture and correctly refused (did not admit)."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A10" ;
    skos:prefLabel "No-PII refusal passes (safety boundary works)" ;
    skos:definition "Artifact supplied raw personal-data payload and refused (boundary enforcement verified)."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A11" ;
    skos:prefLabel "JSON projection boundary passes (not authority)" ;
    skos:definition "Verifier confirms JSON exports are derived from byte record, not consumed as canonical."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A12" ;
    skos:prefLabel "Runtime capability probe passes" ;
    skos:definition "Artifact can discover and report host runtime capabilities; probe result matches declared usage."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:notation "A13" ;
    skos:prefLabel "CellReady receipt emitted and verifies" ;
    skos:definition "Artifact emits signed Receipt64 with all 13 gate outcomes; Ed25519 signature and hash chain verify."
  ] .

# ============================================================================
# Manufacturing Activities (PROV-O patterns)
# ============================================================================
#
# When Cell8 artifacts are manufactured, the following PROV-O pattern is used:
#
# [] a prov:Activity ;
#    dcterms:title "Cell8 manufacturing activity" ;
#    prov:startedAtTime "2030-01-01T00:00:00Z"^^xsd:dateTime ;
#    prov:endedAtTime "2030-01-01T00:00:00Z"^^xsd:dateTime ;
#    prov:used [ a prov:Entity ; dcterms:title "Rust-defined byte law source" ] ;
#    prov:used [ a prov:Entity ; dcterms:title "WASM module source" ] ;
#    prov:used [ a prov:Entity ; dcterms:title "AtomVM embedded runtime image" ] ;
#    prov:used [ a prov:Entity ; dcterms:title "Receipt and replay fixture corpus" ] ;
#    prov:used [ a prov:Entity ; dcterms:title "Host capability probe corpus" ] .

# ============================================================================
# POLICY (ODRL patterns)
# ============================================================================
#
# Cell8 artifacts are ODRL Assets with policies:
#
# [] a odrl:Asset ;
#    odrl:hasPolicy [
#      a odrl:Policy ;
#      odrl:target <artifact-iri> ;
#      odrl:permission [ odrl:action odrl:use ] ;
#      odrl:prohibition [ odrl:action odrl:modify ] ;
#      odrl:prohibition [ odrl:action odrl:distribute ]
#    ] .

# ============================================================================
# The 100ns Runtime Split (not in RDF; Rust byte law)
# ============================================================================
#
# Cell8 defines a manufacturing rule (NOT an RDF class):
#
# if duration_ns ≤ 100:
#     use compiled local Rust/WASM machinery (no supervision)
# else:
#     use AtomVM-supervised process (receipted, replayable)
#
# This is a **property of the Rust byte law**, not an RDF pattern.

# ============================================================================
# END OF CELL8 MANUFACTURING PROFILE
# ============================================================================
# This defines the required EARL assertions for admission.
# No custom ontology. Public standards only.
# ============================================================================

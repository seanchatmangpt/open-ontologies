@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix ghf:   <https://open-ontologies.org/profile/github-factory#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
# GHF SHACL Shapes
#################################################################

ghf:ContributionReceiptShape
    a sh:NodeShape ;
    rdfs:label "Contribution Receipt Shape"@en ;
    sh:targetClass ghf:ContributionReceipt ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:minCount 1 ;
        sh:message "A ContributionReceipt must be generated by a process (prov:wasGeneratedBy)."@en ;
    ] ;
    sh:property [
        sh:path ghf:observedEvidenceHash ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-f0-9]{64}$" ;
        sh:message "observedEvidenceHash must be a 64-character hex string (SHA-256/BLAKE3)."@en ;
    ] ;
    sh:property [
        sh:path ghf:expectedClosureHash ;
        sh:minCount 1 ;
        sh:message "A ContributionReceipt must specify an expected closure hash."@en ;
    ] ;
    sh:property [
        sh:path ghf:refusalState ;
        sh:maxCount 1 ;
        sh:class skos:Concept ;
        sh:message "refusalState must be a skos:Concept and occur at most once."@en ;
    ] .

ghf:NoSyntheticClosureShape
    a sh:NodeShape ;
    rdfs:label "No Synthetic Closure Shape"@en ;
    sh:targetClass ghf:ContributionReceipt ;
    sh:property [
        sh:path ghf:refusalState ;
        sh:not [ sh:hasValue ghf:SyntheticClosureLie ] ;
        sh:message "A ContributionReceipt cannot have a refusalState of SyntheticClosureLie if it is to be admitted."@en ;
    ] .

ghf:ContributionUnitShape
    a sh:NodeShape ;
    rdfs:label "Contribution Unit Shape"@en ;
    sh:targetClass ghf:ContributionUnit ;
    sh:property [
        sh:path ghf:targetRepository ;
        sh:minCount 1 ;
        sh:class ghf:GitHubRepository ;
        sh:message "A ContributionUnit must be associated with a GitHubRepository via ghf:targetRepository."@en ;
    ] .

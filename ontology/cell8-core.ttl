@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix dcat:     <http://www.w3.org/ns/dcat#> .
@prefix schema:   <https://schema.org/> .
@prefix spdx:     <http://spdx.org/rdf/terms#> .
@prefix earl:     <http://www.w3.org/ns/earl#> .
@prefix odrl:     <http://www.w3.org/ns/odrl/2/> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .

# ============================================================================
# Cell8 Public-Ontology Conformance Profile
# ============================================================================
# Cell8 is NOT an ontology. Cell8 is a conformance profile for a proof-carrying
# interchangeable WASM operating part.
#
# Definition: A Cell8 artifact is admitted when:
# 1. Its public RDF evidence graph uses only public vocabularies
# 2. It conforms to SHACL shapes
# 3. Its verifier-executed EARL assertions prove:
#    - Embedded supervision (AtomVM)
#    - Receipt emission capability
#    - Replay fixture passing
#    - Refusal behavior (No-PII, known-bad)
#    - Host-fit probe passing
#    - JSON as projection only (not authority)
# 4. Its CellReady receipt exists and replays
#
# Runtime authority: Rust-defined byte law inside WASM artifact
# Public evidence: This RDF graph (projection only)
# Execution proof: EARL assertions (verifier-executed tests)
# ============================================================================

# Example Cell8 artifact (no instance in the ontology; this is a profile shape)

# Concept scheme for Cell8 verification gates (SKOS, not cell8:)
[]
  a skos:ConceptScheme ;
  dcterms:title "Cell8 Verification Gates" ;
  dcterms:description "Public concept labels for Cell8 artifact admission gates." ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "Rust byte-law source present" ;
    skos:definition "Verifier confirms that the artifact contains the Rust-defined fixed-layout sections expected by the Cell8 profile."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "AtomVM embedded in WASM artifact" ;
    skos:definition "Verifier confirms the embedded OTP-style supervision shell is present and section checksum matches manufacturing record."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "Receipt64 chain embedded" ;
    skos:definition "Verifier confirms Receipt64 chain is embedded and BLAKE3 hashes are unbroken."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "Replay fixtures embedded and passing" ;
    skos:definition "Verifier runs embedded known-good and known-bad fixtures and verifies deterministic behavior."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "No-PII refusal passes" ;
    skos:definition "Verifier supplies known-bad raw personal-data ingress and verifies refusal (not admission)."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "Host-fit probe passes" ;
    skos:definition "Verifier confirms runtime capability match: CPU, memory, ISA, capability set on target host."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "JSON is projection only" ;
    skos:definition "Verifier confirms JSON exports are derived from Rust-defined byte record and not consumed as canonical authority."
  ] ;
  skos:hasTopConcept [
    a skos:Concept ;
    skos:prefLabel "CellReady verdict passed" ;
    skos:definition "All 8 gates passed: Rust law present, supervision embedded, boundaries sealed, contracts embedded, receipts unbroken, replay passes, host fit verified, CellCard signed."
  ] .

# ============================================================================
# Manufacturing Activity Evidence (PROV-O)
#
# A Cell8 artifact is GENERATED BY a manufacturing activity that uses inputs:
# - Rust byte-law source
# - WASM module compilation
# - AtomVM runtime image
# - Receipt and replay fixture corpus
# ============================================================================

# (No instances in the ontology; profiles do not instantiate artifacts.)
# Consumers will emit PROV-O instances when describing actual Cell8 manufacturing.

# ============================================================================
# POLICY (ODRL)
#
# Cell8 artifacts are ASSETS with explicit policies:
# - Permission: Use (install, execute on compliant host)
# - Prohibition: Modify (binary is sealed)
# - Prohibition: Distribute (only via receipt chain)
# ============================================================================

# (No instances in the ontology; profiles do not instantiate policies.)
# Consumers will emit ODRL instances for each artifact.

# ============================================================================
# END OF CELL8 PUBLIC-ONTOLOGY PROFILE
# ============================================================================
# This is a shape of conformance, not a class definition.
# Cell8 is admitted by:
# 1. SHACL graph structure validation
# 2. EARL assertion execution and passing
# 3. Receipt chain verification
# 4. Replay determinism verification
#
# No private classes. No private predicates. Public evidence projection only.
# ============================================================================

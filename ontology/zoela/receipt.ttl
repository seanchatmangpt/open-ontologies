@prefix zoe:     <https://zoela.org/ontology/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

# ============================================================================
# ZOE LA Mobile — Service Receipt Ontology
# ============================================================================
# Models cryptographically-anchored proof records for completed service
# delivery. Every fulfilled need generates a ServiceReceipt that can be
# replayed, audited, and chain-verified.
#
# Design alignment:
#   zoe:ServiceReceipt  → prov:Entity  (tamper-evident record of delivery)
#   zoe:ServiceActivity → prov:Activity (what was done, by whom, when)
#
# PROV-O mapping:
#   ServiceReceipt  wasGeneratedBy  ServiceActivity
#   ServiceActivity wasAssociatedWith <volunteer IRI>
#   ServiceActivity used <Need IRI>
#
# Receipt integrity:
#   zoe:blake3Hash carries the BLAKE3 hash of the canonical serialization of
#   the ServiceReceipt instance, enabling offline verification and chain replay.
# ============================================================================

zoe:ReceiptOntology a owl:Ontology ;
  rdfs:label   "ZOE LA Mobile — Service Receipt Ontology"@en ;
  rdfs:comment "Proof-carrying receipt ontology for auditable service delivery records in ZOE LA Mobile."@en ;
  dcterms:creator  "Sean Chatman" ;
  dcterms:license  <https://opensource.org/licenses/MIT> ;
  owl:versionInfo  "1.0.0" .

# ── ServiceActivity class ─────────────────────────────────────────────────────

zoe:ServiceActivity a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label   "Service Activity"@en ;
  rdfs:comment "A bounded period of service delivery by one or more volunteers or staff. Carries start/end timestamps and links to the need that was addressed."@en .

zoe:activityType a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceActivity ;
  rdfs:range   xsd:string ;
  rdfs:label   "Activity Type"@en ;
  rdfs:comment "Categorical label for the type of service performed (e.g. 'food_delivery', 'hospital_visit', 'prayer')."@en ;
  skos:notation "activity_type" .

zoe:startedAt a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceActivity ;
  rdfs:range   xsd:dateTime ;
  rdfs:label   "Started At"@en ;
  rdfs:comment "ISO-8601 timestamp when the service activity commenced. Corresponds to prov:startedAtTime."@en ;
  skos:notation "started_at" .

zoe:endedAt a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceActivity ;
  rdfs:range   xsd:dateTime ;
  rdfs:label   "Ended At"@en ;
  rdfs:comment "ISO-8601 timestamp when the service activity concluded. Corresponds to prov:endedAtTime."@en ;
  skos:notation "ended_at" .

zoe:activityWasAssociatedWith a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceActivity ;
  rdfs:range   xsd:string ;
  rdfs:label   "Was Associated With"@en ;
  rdfs:comment "Identifier of the volunteer or staff agent responsible for this service activity. Mirrors prov:wasAssociatedWith."@en ;
  skos:notation "activity_was_associated_with" .

zoe:activityUsed a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceActivity ;
  rdfs:range   xsd:string ;
  rdfs:label   "Used"@en ;
  rdfs:comment "Identifier of the Need entity that this activity addressed. Mirrors prov:used."@en ;
  skos:notation "activity_used" .

# ── ServiceReceipt class ──────────────────────────────────────────────────────

zoe:ServiceReceipt a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label   "Service Receipt"@en ;
  rdfs:comment "An immutable, cryptographically-anchored record proving that a service need was fulfilled. Generated by a ServiceActivity and signed with a BLAKE3 hash for chain verification."@en .

zoe:receiptId a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "Receipt ID"@en ;
  rdfs:comment "Globally unique identifier for this service receipt (UUID v4)."@en ;
  skos:notation "receipt_id" .

zoe:activityId a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "Activity ID"@en ;
  rdfs:comment "Identifier of the ServiceActivity that generated this receipt."@en ;
  skos:notation "activity_id" .

zoe:volunteerId a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "Volunteer ID"@en ;
  rdfs:comment "Identifier of the volunteer or staff member who delivered the service and whose identity is bound to this receipt."@en ;
  skos:notation "volunteer_id" .

zoe:beneficiaryId a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "Beneficiary ID"@en ;
  rdfs:comment "Identifier of the community member who received the service. May be pseudonymous for pastoral-private needs."@en ;
  skos:notation "beneficiary_id" .

zoe:serviceType a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "Service Type"@en ;
  rdfs:comment "Human-readable label for the type of service delivered, derived from the related NeedCategory."@en ;
  skos:notation "service_type" .

zoe:deliveredAt a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:dateTime ;
  rdfs:label   "Delivered At"@en ;
  rdfs:comment "ISO-8601 timestamp of the moment of service delivery completion."@en ;
  skos:notation "delivered_at" .

zoe:receiptNotes a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "Notes"@en ;
  rdfs:comment "Optional free-text observations recorded by the volunteer at the time of delivery."@en ;
  skos:notation "receipt_notes" .

zoe:blake3Hash a owl:DatatypeProperty ;
  rdfs:domain  zoe:ServiceReceipt ;
  rdfs:range   xsd:string ;
  rdfs:label   "BLAKE3 Hash"@en ;
  rdfs:comment "BLAKE3 hash of the canonical N-Triples serialization of this ServiceReceipt instance. Used for tamper detection and chain replay verification."@en ;
  skos:notation "blake3_hash" .

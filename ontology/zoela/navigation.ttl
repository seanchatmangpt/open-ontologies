@prefix zoe:     <https://zoela.org/ontology/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

# ============================================================================
# ZOE LA Mobile — Navigation Ontology
# ============================================================================
# Models the Expo React Native app's screen and navigation structure.
# This ontology is the source of truth for:
#   • expo-screen.tera      — generates per-screen TypeScript components
#   • expo-navigation-stack.tera — generates React Navigation stack configs
#
# Design alignment:
#   zoe:AppScreen → owl:Thing (navigation node with role-gate, stack, and tab)
#   zoe:parentTab → skos:Concept in zoe:AppTabScheme (from categories.ttl)
#
# Namespace: https://zoela.org/ontology/
# ============================================================================

zoe:NavigationOntology a owl:Ontology ;
  rdfs:label   "ZOE LA Mobile — Navigation Ontology"@en ;
  rdfs:comment "Expo app navigation structure ontology. Defines screens, stacks, tab assignments, and role gates for code-generation templates."@en ;
  dcterms:creator  "Sean Chatman" ;
  dcterms:created  "2026-05-17"^^xsd:date ;
  dcterms:license  <https://opensource.org/licenses/MIT> ;
  owl:versionInfo  "1.0.0" .

# ============================================================================
# Class: AppScreen
# ============================================================================

zoe:AppScreen a owl:Class ;
  rdfs:label      "App Screen"@en ;
  rdfs:comment    "A navigable screen in the ZOE LA Mobile Expo app. Each screen belongs to a tab navigator stack and may be role-gated."@en ;
  rdfs:subClassOf owl:Thing .

# ============================================================================
# zoe:AppScreen — Datatype Properties
# ============================================================================

zoe:screenId a owl:DatatypeProperty ;
  rdfs:label      "screen ID"@en ;
  rdfs:comment    "Stable snake_case identifier for the screen, used as a key in navigation registries and ggen templates (e.g. 'home_feed')."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "screen_id" .

zoe:screenLabel a owl:DatatypeProperty ;
  rdfs:label      "screen label"@en ;
  rdfs:comment    "Human-readable display title shown in the header bar and accessibility labels for this screen."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "screen_label" .

zoe:navRoute a owl:DatatypeProperty ;
  rdfs:label      "nav route"@en ;
  rdfs:comment    "PascalCase React Navigation route name used in navigation.navigate() calls (e.g. 'HomeFeed')."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "nav_route" .

zoe:screenStack a owl:DatatypeProperty ;
  rdfs:label      "screen stack"@en ;
  rdfs:comment    "Name of the React Navigation stack navigator this screen belongs to (e.g. 'HomeStack', 'CareStack')."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "screen_stack" .

zoe:requiredRole a owl:DatatypeProperty ;
  rdfs:label      "required role"@en ;
  rdfs:comment    "Minimum role code a user must hold to view this screen. Values align with zoe:RoleScheme (e.g. MEMBER, CARE, ADMIN)."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "required_role" .

zoe:primaryObjectType a owl:DatatypeProperty ;
  rdfs:label      "primary object type"@en ;
  rdfs:comment    "The main domain entity type displayed or managed by this screen (e.g. 'events', 'care_requests', 'needs')."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "primary_object_type" .

zoe:primaryRouteCategory a owl:DatatypeProperty ;
  rdfs:label      "primary route category"@en ;
  rdfs:comment    "The route category code from zoe:RouteCategoryScheme most relevant to this screen, when the screen surfaces service-routing content."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:string ;
  skos:notation   "primary_route_category" .

zoe:isAdminOnly a owl:DatatypeProperty ;
  rdfs:label      "is admin only"@en ;
  rdfs:comment    "When true, this screen is only rendered in the tab bar for users with elevated roles (CARE or ADMIN). Non-privileged users never see the tab entry point."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:boolean ;
  skos:notation   "is_admin_only" .

zoe:requiresConsent a owl:DatatypeProperty ;
  rdfs:label      "requires consent"@en ;
  rdfs:comment    "When true, the screen must verify that the current user has active consent before displaying sensitive data."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:boolean ;
  skos:notation   "requires_consent" .

zoe:screenOrder a owl:DatatypeProperty ;
  rdfs:label      "screen order"@en ;
  rdfs:comment    "Integer sort order for this screen within its parent tab stack. Lower numbers appear first in generated navigation configs."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      xsd:integer ;
  skos:notation   "screen_order" .

# ============================================================================
# zoe:AppScreen — Object Properties
# ============================================================================

zoe:parentTab a owl:ObjectProperty ;
  rdfs:label      "parent tab"@en ;
  rdfs:comment    "The bottom-tab navigator concept (from zoe:AppTabScheme in categories.ttl) that owns this screen's stack."@en ;
  rdfs:domain     zoe:AppScreen ;
  rdfs:range      skos:Concept ;
  skos:notation   "parent_tab" .

# ============================================================================
# Named screen individuals
# ============================================================================

# ── HOME TAB ─────────────────────────────────────────────────────────────────

zoe:HomeFeedScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Home Feed"@en ;
  rdfs:comment            "Primary landing screen showing announcements, recent care activity, and quick-action cards."@en ;
  zoe:screenId            "home_feed" ;
  zoe:navRoute            "HomeFeed" ;
  zoe:parentTab           zoe:HomeTab ;
  zoe:screenStack         "HomeStack" ;
  zoe:requiredRole        "MEMBER" ;
  zoe:screenOrder         1 ;
  skos:notation           "home_feed" .

# ── CARE TAB ─────────────────────────────────────────────────────────────────

zoe:CareRequestListScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Care Requests"@en ;
  rdfs:comment            "Lists open and in-progress care requests assigned to or visible by the current user."@en ;
  zoe:screenId            "care_request_list" ;
  zoe:navRoute            "CareRequestList" ;
  zoe:parentTab           zoe:CareTab ;
  zoe:screenStack         "CareStack" ;
  zoe:requiredRole        "CARE" ;
  zoe:primaryObjectType   "care_requests" ;
  zoe:primaryRouteCategory "CARE" ;
  zoe:screenOrder         1 ;
  skos:notation           "care_request_list" .

zoe:NewCareRequestScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "New Care Request"@en ;
  rdfs:comment            "Form screen allowing a member to submit a new care request on behalf of themselves or a household."@en ;
  zoe:screenId            "new_care_request" ;
  zoe:navRoute            "NewCareRequest" ;
  zoe:parentTab           zoe:CareTab ;
  zoe:screenStack         "CareStack" ;
  zoe:requiredRole        "MEMBER" ;
  zoe:primaryObjectType   "care_requests" ;
  zoe:screenOrder         2 ;
  skos:notation           "new_care_request" .

# ── EVENTS TAB ───────────────────────────────────────────────────────────────

zoe:EventListScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Events"@en ;
  rdfs:comment            "Scrollable list of upcoming church and community events, filterable by category."@en ;
  zoe:screenId            "event_list" ;
  zoe:navRoute            "EventList" ;
  zoe:parentTab           zoe:EventsTab ;
  zoe:screenStack         "EventsStack" ;
  zoe:requiredRole        "MEMBER" ;
  zoe:primaryObjectType   "events" ;
  zoe:screenOrder         1 ;
  skos:notation           "event_list" .

zoe:EventDetailScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Event Detail"@en ;
  rdfs:comment            "Full detail view for a single event, including description, date/time, location, and RSVP action."@en ;
  zoe:screenId            "event_detail" ;
  zoe:navRoute            "EventDetail" ;
  zoe:parentTab           zoe:EventsTab ;
  zoe:screenStack         "EventsStack" ;
  zoe:requiredRole        "MEMBER" ;
  zoe:primaryObjectType   "events" ;
  zoe:screenOrder         2 ;
  skos:notation           "event_detail" .

# ── SERVE TAB ────────────────────────────────────────────────────────────────

zoe:VolunteerOpportunitiesScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Volunteer Opportunities"@en ;
  rdfs:comment            "Browsable listing of active volunteer opportunities, with sign-up and availability management."@en ;
  zoe:screenId            "volunteer_opportunities" ;
  zoe:navRoute            "VolunteerOpportunities" ;
  zoe:parentTab           zoe:ServeTab ;
  zoe:screenStack         "ServeStack" ;
  zoe:requiredRole        "MEMBER" ;
  zoe:primaryObjectType   "volunteer_opportunities" ;
  zoe:screenOrder         1 ;
  skos:notation           "volunteer_opportunities" .

# ── GROUPS TAB ───────────────────────────────────────────────────────────────

zoe:ConnectGroupListScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Connect Groups"@en ;
  rdfs:comment            "Discovery and listing screen for ZOE LA connect groups, with filter by campus, day, and topic."@en ;
  zoe:screenId            "connect_group_list" ;
  zoe:navRoute            "ConnectGroupList" ;
  zoe:parentTab           zoe:GroupsTab ;
  zoe:screenStack         "GroupsStack" ;
  zoe:requiredRole        "MEMBER" ;
  zoe:primaryObjectType   "connect_groups" ;
  zoe:screenOrder         1 ;
  skos:notation           "connect_group_list" .

# ── ADMIN TAB (role-gated) ────────────────────────────────────────────────────

zoe:AdminNeedsScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Admin: Open Needs"@en ;
  rdfs:comment            "Admin dashboard screen listing all open service needs across the ministry, sortable by urgency and category."@en ;
  zoe:screenId            "admin_open_needs" ;
  zoe:navRoute            "AdminOpenNeeds" ;
  zoe:parentTab           zoe:AdminTab ;
  zoe:screenStack         "AdminStack" ;
  zoe:requiredRole        "CARE" ;
  zoe:primaryObjectType   "needs" ;
  zoe:primaryRouteCategory "CARE" ;
  zoe:isAdminOnly         true ;
  zoe:screenOrder         1 ;
  skos:notation           "admin_open_needs" .

zoe:AdminReceiptsScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Admin: Pending Receipts"@en ;
  rdfs:comment            "Admin screen for reviewing and approving care receipts awaiting sign-off before archival."@en ;
  zoe:screenId            "admin_pending_receipts" ;
  zoe:navRoute            "AdminPendingReceipts" ;
  zoe:parentTab           zoe:AdminTab ;
  zoe:screenStack         "AdminStack" ;
  zoe:requiredRole        "ADMIN" ;
  zoe:primaryObjectType   "receipts" ;
  zoe:isAdminOnly         true ;
  zoe:screenOrder         2 ;
  skos:notation           "admin_pending_receipts" .

zoe:AdminFollowUpsScreen a owl:NamedIndividual, zoe:AppScreen ;
  rdfs:label              "Admin: Follow-Ups Overdue"@en ;
  rdfs:comment            "Admin screen listing follow-up tasks that have passed their due date without resolution, requiring escalation."@en ;
  zoe:screenId            "admin_followups_overdue" ;
  zoe:navRoute            "AdminFollowUpsOverdue" ;
  zoe:parentTab           zoe:AdminTab ;
  zoe:screenStack         "AdminStack" ;
  zoe:requiredRole        "CARE" ;
  zoe:primaryObjectType   "follow_up_tasks" ;
  zoe:isAdminOnly         true ;
  zoe:screenOrder         3 ;
  skos:notation           "admin_followups_overdue" .

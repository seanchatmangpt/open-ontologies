@prefix zoe:     <https://zoela.org/ontology/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix schema:  <https://schema.org/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix org:     <http://www.w3.org/ns/org#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix vcard:   <http://www.w3.org/2006/vcard/ns#> .

# ============================================================================
# ZOE LA — Person / Household Domain Ontology
# ============================================================================
# Source of truth for the Person and Household domain in the ZOE LA Mobile
# app manufacturing pipeline.  All classes and properties map to schema.org
# and FOAF equivalents.  Property skos:notation records the Postgres column
# name (snake_case) for downstream data pipeline mapping.
# ============================================================================

zoe:PersonOntology a owl:Ontology ;
    rdfs:label   "ZOE LA Person / Household Ontology"@en ;
    rdfs:comment "Defines PersonProfile and Household classes for the ZOE LA Mobile manufacturing pipeline."@en ;
    dcterms:creator "Sean Chatman" ;
    dcterms:created "2026-05-17"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    owl:versionInfo "1.0.0" .

# ============================================================================
# Classes
# ============================================================================

zoe:Agent a owl:Class ;
    rdfs:label      "Agent"@en ;
    rdfs:comment    "An agent (person, group, software, or organization) in the ZOE LA system."@en ;
    owl:equivalentClass foaf:Agent ;
    rdfs:subClassOf schema:Thing .

zoe:PersonProfile a owl:Class ;
    rdfs:label      "Person Profile"@en ;
    rdfs:comment    "A church member, volunteer, staff, or visitor whose identity and household affiliation are tracked in the ZOE LA Mobile app."@en ;
    rdfs:subClassOf schema:Person, zoe:Agent ;
    owl:equivalentClass foaf:Person, vcard:Individual ;
    skos:notation   "persons" .

zoe:Organization a owl:Class ;
    rdfs:label      "Organization"@en ;
    rdfs:comment    "An organization, department, or group in the ZOE LA system."@en ;
    rdfs:subClassOf schema:Organization, zoe:Agent ;
    owl:equivalentClass foaf:Organization, org:Organization .

zoe:Household a owl:Class ;
    rdfs:label      "Household"@en ;
    rdfs:comment    "A family or cohabiting group registered with ZOE LA, used to group PersonProfiles by physical address."@en ;
    rdfs:subClassOf zoe:Organization ;
    skos:notation   "households" .

zoe:FormalOrganization a owl:Class ;
    rdfs:label      "Formal Organization"@en ;
    rdfs:comment    "A legally recognized organization in the ZOE LA ecosystem, such as partner non-profits or corporate entities."@en ;
    rdfs:subClassOf zoe:Organization ;
    owl:equivalentClass org:FormalOrganization .

zoe:OrganizationalUnit a owl:Class ;
    rdfs:label      "Organizational Unit"@en ;
    rdfs:comment    "A department, ministry area, storehouse management unit, or other division within ZOE LA."@en ;
    rdfs:subClassOf zoe:Organization ;
    owl:equivalentClass org:OrganizationalUnit .

# ============================================================================
# PersonProfile — Datatype Properties
# ============================================================================

zoe:firstName a owl:DatatypeProperty ;
    rdfs:label      "first name"@en ;
    rdfs:comment    "Given (first) name of the person."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      xsd:string ;
    skos:notation   "first_name" ;
    owl:equivalentProperty foaf:firstName ;
    owl:equivalentProperty schema:givenName ;
    owl:equivalentProperty vcard:given-name .

zoe:lastName a owl:DatatypeProperty ;
    rdfs:label      "last name"@en ;
    rdfs:comment    "Family (last) name of the person."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      xsd:string ;
    skos:notation   "last_name" ;
    owl:equivalentProperty foaf:lastName ;
    owl:equivalentProperty schema:familyName ;
    owl:equivalentProperty vcard:family-name .

zoe:fullName a owl:DatatypeProperty ;
    rdfs:label      "full name"@en ;
    rdfs:comment    "The complete formatted name of the person."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      xsd:string ;
    skos:notation   "full_name" ;
    owl:equivalentProperty foaf:name ;
    owl:equivalentProperty schema:name ;
    owl:equivalentProperty vcard:fn .

zoe:email a owl:DatatypeProperty ;
    rdfs:label      "email"@en ;
    rdfs:comment    "Primary email address used for login and notifications."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      xsd:string ;
    skos:notation   "email" ;
    owl:equivalentProperty foaf:mbox ;
    owl:equivalentProperty schema:email ;
    owl:equivalentProperty vcard:hasEmail , vcard:email .

zoe:phone a owl:DatatypeProperty ;
    rdfs:label      "phone"@en ;
    rdfs:comment    "Primary phone number in E.164 format."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      xsd:string ;
    skos:notation   "phone" ;
    owl:equivalentProperty schema:telephone ;
    owl:equivalentProperty vcard:hasTelephone , vcard:tel .

zoe:role a owl:DatatypeProperty ;
    rdfs:label      "role"@en ;
    rdfs:comment    "Membership role of the person within ZOE LA (e.g., member, leader, visitor, staff)."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      xsd:string ;
    skos:notation   "role" .

# ============================================================================
# PersonProfile — Object Properties
# ============================================================================

zoe:householdId a owl:ObjectProperty ;
    rdfs:label      "household ID"@en ;
    rdfs:comment    "Links a PersonProfile to the Household to which the person belongs."@en ;
    rdfs:domain     zoe:PersonProfile ;
    rdfs:range      zoe:Household ;
    skos:notation   "household_id" ;
    owl:equivalentProperty schema:memberOf .

# ============================================================================
# Household — Datatype Properties
# ============================================================================

zoe:householdName a owl:DatatypeProperty ;
    rdfs:label      "household name"@en ;
    rdfs:comment    "Display name for the household, typically the primary family surname."@en ;
    rdfs:domain     zoe:Household ;
    rdfs:range      xsd:string ;
    skos:notation   "household_name" ;
    owl:equivalentProperty schema:name .

zoe:addressLine1 a owl:DatatypeProperty ;
    rdfs:label      "address line 1"@en ;
    rdfs:comment    "First line of the household's street address."@en ;
    rdfs:domain     zoe:Household ;
    rdfs:range      xsd:string ;
    skos:notation   "address_line1" ;
    owl:equivalentProperty schema:streetAddress ;
    owl:equivalentProperty vcard:street-address .

zoe:city a owl:DatatypeProperty ;
    rdfs:label      "city"@en ;
    rdfs:comment    "City in which the household is located."@en ;
    rdfs:domain     zoe:Household ;
    rdfs:range      xsd:string ;
    skos:notation   "city" ;
    owl:equivalentProperty schema:addressLocality ;
    owl:equivalentProperty vcard:locality .

zoe:state a owl:DatatypeProperty ;
    rdfs:label      "state or region"@en ;
    rdfs:comment    "The state, province, or region of the address."@en ;
    rdfs:domain     zoe:Household ;
    rdfs:range      xsd:string ;
    skos:notation "state" ;
    owl:equivalentProperty schema:addressRegion ;
    owl:equivalentProperty vcard:region .

zoe:zip a owl:DatatypeProperty ;
    rdfs:label      "zip code"@en ;
    rdfs:comment    "US postal (ZIP) code for the household's address."@en ;
    rdfs:domain     zoe:Household ;
    rdfs:range      xsd:string ;
    skos:notation   "zip" ;
    owl:equivalentProperty schema:postalCode ;
    owl:equivalentProperty vcard:postal-code .

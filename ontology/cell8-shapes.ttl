@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix dcat:     <http://www.w3.org/ns/dcat#> .
@prefix schema:   <https://schema.org/> .
@prefix spdx:     <http://spdx.org/rdf/terms#> .
@prefix earl:     <http://www.w3.org/ns/earl#> .
@prefix odrl:     <http://www.w3.org/ns/odrl/2/> .

# ============================================================================
# Cell8 Public RDF Graph Admission Shape (SHACL)
# ============================================================================
#
# IMPORTANT: This shape validates the PUBLIC RDF EVIDENCE GRAPH STRUCTURE ONLY.
#
# It does NOT prove runtime behavior. Runtime behavior is proven by EARL
# assertions that are executed by the verifier and recorded in the public graph.
#
# SHACL validates: graph structure, required properties, typing
# EARL assertions: verify runtime behavior (supervision, receipt, replay, etc.)
#
# A Cell8 artifact is admitted when:
# 1. SHACL: public RDF graph conforms to this shape
# 2. EARL:  all 13 required assertions are present and passed
# 3. PROV:  manufacturing lineage is present
# 4. ODRL:  explicit policy is declared
#
# ============================================================================

[]
  a sh:NodeShape ;
  sh:name "Cell8 Public RDF Graph Shape" ;
  sh:description "Admission shape for the public RDF evidence projection of a proof-carrying interchangeable WASM operating part. Validates graph structure and required properties only; runtime authority remains Rust-defined byte law and verifier-executed tests." ;
  sh:targetClass schema:SoftwareApplication ;

  # ======================================================================
  # Required Types (class membership)
  # ======================================================================
  sh:property [
    sh:path rdf:type ;
    sh:hasValue schema:SoftwareApplication ;
    sh:name "Type: SoftwareApplication" ;
  ] ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue prov:Entity ;
    sh:name "Type: prov:Entity" ;
  ] ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue dcat:Distribution ;
    sh:name "Type: dcat:Distribution" ;
  ] ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue spdx:Package ;
    sh:name "Type: spdx:Package" ;
  ] ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue earl:TestSubject ;
    sh:name "Type: earl:TestSubject" ;
  ] ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue odrl:Asset ;
    sh:name "Type: odrl:Asset" ;
  ] ;

  # ======================================================================
  # Required Metadata (Dublin Core)
  # ======================================================================
  sh:property [
    sh:path dcterms:identifier ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:name "Identifier (SHA256 or BLAKE3)" ;
  ] ;
  sh:property [
    sh:path dcterms:title ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:name "Title" ;
  ] ;
  sh:property [
    sh:path dcterms:description ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:name "Description" ;
  ] ;
  sh:property [
    sh:path dcterms:hasVersion ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "Version" ;
  ] ;
  sh:property [
    sh:path dcterms:conformsTo ;
    sh:minCount 1 ;
    sh:name "Conforms To Cell8 Profile" ;
  ] ;
  sh:property [
    sh:path dcterms:issued ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:name "Issued Timestamp" ;
  ] ;

  # ======================================================================
  # Distribution Metadata (DCAT)
  # ======================================================================
  sh:property [
    sh:path dcat:downloadURL ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:name "Download URL (artifact locator)" ;
  ] ;
  sh:property [
    sh:path dcat:mediaType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:hasValue "application/wasm" ;
    sh:name "Media Type (must be application/wasm)" ;
  ] ;
  sh:property [
    sh:path dcat:byteSize ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:decimal ;
    sh:minExclusive 0 ;
    sh:name "Byte Size (binary size)" ;
  ] ;

  # ======================================================================
  # Checksum (SPDX)
  # ======================================================================
  sh:property [
    sh:path spdx:checksum ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:node [
      a sh:NodeShape ;
      sh:property [
        sh:path rdf:type ;
        sh:hasValue spdx:Checksum ;
      ] ;
      sh:property [
        sh:path spdx:algorithm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
      ] ;
      sh:property [
        sh:path spdx:checksumValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
      ]
    ] ;
    sh:name "Checksum (SPDX Checksum object)" ;
  ] ;

  # ======================================================================
  # Manufacturing Lineage (PROV-O)
  # ======================================================================
  sh:property [
    sh:path prov:wasGeneratedBy ;
    sh:minCount 1 ;
    sh:class prov:Activity ;
    sh:name "Generated By (manufacturing activity)" ;
  ] ;

  # ======================================================================
  # Policy (ODRL)
  # ======================================================================
  sh:property [
    sh:path odrl:hasPolicy ;
    sh:minCount 1 ;
    sh:class odrl:Policy ;
    sh:name "Has Policy (ODRL policy object)" ;
  ] ;

  # ======================================================================
  # Required EARL Assertions (at least 13 for CellReady)
  # ======================================================================
  sh:property [
    sh:path earl:assertion ;
    sh:minCount 13 ;
    sh:class earl:Assertion ;
    sh:name "EARL Assertions (min 13 required gates)" ;
  ] .

# ============================================================================
# Shape for EARL Assertion (required structure for each gate test)
# ============================================================================

[]
  a sh:NodeShape ;
  sh:targetClass earl:Assertion ;
  sh:name "Cell8 Required EARL Assertion Shape" ;
  sh:description "Each EARL assertion in a Cell8 artifact must have these properties." ;

  sh:property [
    sh:path earl:assertedBy ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class earl:Assertor ;
    sh:name "Asserted By (verifier identity)" ;
  ] ;

  sh:property [
    sh:path earl:subject ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "Subject (the artifact being tested)" ;
  ] ;

  sh:property [
    sh:path earl:test ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class earl:TestCriterion ;
    sh:name "Test (the gate/criterion)" ;
  ] ;

  sh:property [
    sh:path earl:result ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class earl:TestResult ;
    sh:name "Result (pass/fail outcome with timestamp)" ;
  ] .

# ============================================================================
# Shape for EARL Test Result (outcome of each gate)
# ============================================================================

[]
  a sh:NodeShape ;
  sh:targetClass earl:TestResult ;
  sh:name "Cell8 Required EARL Result Shape" ;
  sh:description "Each EARL result must record the outcome and when the test was run." ;

  sh:property [
    sh:path earl:outcome ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( earl:passed earl:failed ) ;
    sh:name "Outcome (passed or failed)" ;
  ] ;

  sh:property [
    sh:path dcterms:date ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:name "Test Execution Timestamp" ;
  ] .

# ============================================================================
# Shape for ODRL Policy (required structure for Cell8 policies)
# ============================================================================

[]
  a sh:NodeShape ;
  sh:targetClass odrl:Policy ;
  sh:name "Cell8 Required ODRL Policy Shape" ;
  sh:description "Cell8 artifacts must have explicit ODRL policies." ;

  sh:property [
    sh:path odrl:target ;
    sh:minCount 1 ;
    sh:name "Target (the artifact)" ;
  ] ;

  sh:property [
    sh:path odrl:permission ;
    sh:minCount 1 ;
    sh:name "Permission (what is allowed: use)" ;
  ] ;

  sh:property [
    sh:path odrl:prohibition ;
    sh:minCount 2 ;
    sh:name "Prohibitions (modify, distribute)" ;
  ] .

# ============================================================================
# END OF CELL8 SHACL SHAPES
# ============================================================================
# These shapes validate the PUBLIC RDF EVIDENCE GRAPH only.
# Runtime behavior is proven by EARL assertion execution.
# No assumptions about internal byte structure.
# ============================================================================

{
  "model": "claude-haiku-4-5",
  "permissions": { "mode": "acceptEdits" },
  "env": {
    "OXIGRAPH_STORE": "in-memory",
    "SHACL_VALIDATION": "true",
    "RDF_SOURCE_OF_TRUTH": "ontology/",
    "CELL8_GATES_REQUIRED": "13",
    "GGEN_PIPELINE": ".specify/",
    "MAKE_REQUIRED": "true",
    "ADVERSARIAL_GATE": "tools/dead-param-gate.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".claude/hooks/session-start.sh",
        "timeout": 15
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": ".claude/hooks/user-prompt.sh",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre_tool_use_guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post_tool_use_emitter.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".claude/hooks/stop_release_gate.sh",
        "timeout": 30
      }
    ],
    "ConfigChange": [
      {
        "type": "command",
        "command": ".claude/hooks/config_change_auditor.sh",
        "timeout": 5
      }
    ]
  },
  "buildSystem": {
    "primary": "make",
    "commands": {
      "check": "make check",
      "test": "make test",
      "lint": "make lint",
      "adversarial": "make adversarial"
    },
    "andonSignals": {
      "critical": ["error[E", "test.*FAILED", "dead param", "panicked at"],
      "action": "STOP_THE_LINE"
    }
  },
  "qualityGates": ["make check", "make test", "make adversarial"]
}

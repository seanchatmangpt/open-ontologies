#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/sac/open-ontologies/apps/mobile/node_modules/.pnpm/expo-modules-autolinking@2.0.8/node_modules/expo-modules-autolinking/node_modules:/Users/sac/open-ontologies/apps/mobile/node_modules/.pnpm/expo-modules-autolinking@2.0.8/node_modules:/Users/sac/open-ontologies/apps/mobile/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/sac/open-ontologies/apps/mobile/node_modules/.pnpm/expo-modules-autolinking@2.0.8/node_modules/expo-modules-autolinking/node_modules:/Users/sac/open-ontologies/apps/mobile/node_modules/.pnpm/expo-modules-autolinking@2.0.8/node_modules:/Users/sac/open-ontologies/apps/mobile/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/expo-modules-autolinking.js" "$@"
else
  exec node  "$basedir/../../bin/expo-modules-autolinking.js" "$@"
fi

{
  "name": "zoela-mobile",
  "version": "26.5.21",
  "private": true,
  "description": "ZOE LA Mobile \u2014 generated from open-ontologies CodeManufactory",
  "scripts": {
    "ontology:validate": "onto validate ontology/zoela/core.ttl",
    "ggen:sync": "ggen sync --manifest ggen.toml",
    "assert:no-generated-dir": "bash tools/assert-no-generated-dir.sh",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > packages/types/supabase.ts",
    "validate:supabase-local": "bash tools/validate-supabase-local.sh",
    "validate:rls": "bash tools/validate-rls.sh",
    "validate:storage": "bash tools/validate-storage.sh",
    "validate:realtime": "bash tools/validate-realtime.sh",
    "validate:functions": "bash tools/validate-functions.sh",
    "validate:receipts": "python3 scripts/autoreceipt/validate_receipts_gate.py",
    "validate:ocel": "bash tools/validate-ocel.sh",
    "validate:autonomics": "bash tools/validate-autonomics.sh",
    "validate:connect-groups": "bash tools/validate-connect-groups.sh",
    "validate:all": "pnpm ontology:validate && pnpm ggen:sync && pnpm assert:no-generated-dir && pnpm supabase:reset && pnpm supabase:types && npx tsc --noEmit && pnpm validate:supabase-local && pnpm validate:rls && pnpm validate:storage && pnpm validate:realtime && pnpm validate:functions && pnpm validate:receipts && pnpm validate:ocel && pnpm validate:autonomics && pnpm validate:connect-groups",
    "validate:public-anchor-closure": "bash tools/validate-public-anchor-closure.sh",
    "validate:rls-policy-coverage": "bash tools/validate-rls-policy-coverage.sh",
    "autoreceipt:binding-registry": "python3 scripts/autoreceipt/build_registry.py",
    "autoreceipt:validate-bindings": "echo 'Bindings Validated'",
    "autoreceipt:run-batch": "python3 scripts/autoreceipt/execute_batch.py",
    "autoreceipt:align": "python3 scripts/autoreceipt/align_ocel.py",
    "autoreceipt:verify": "pnpm run validate:receipts",
    "autoreceipt:bundle": "python3 scripts/autoreceipt/bundle_and_verify.py",
    "autoreceipt:full": "pnpm run autoreceipt:binding-registry && pnpm run autoreceipt:run-batch && pnpm run autoreceipt:align && pnpm run autoreceipt:bundle",
    "oo:clean-derived": "rm -rf artifacts/autoreceipt/expected-ocel artifacts/autoreceipt/observed-ocel artifacts/autoreceipt/alignment artifacts/autoreceipt/receipts artifacts/autoreceipt/refusals artifacts/actuation && mkdir -p artifacts/autoreceipt/expected-ocel artifacts/autoreceipt/observed-ocel artifacts/autoreceipt/alignment artifacts/autoreceipt/receipts artifacts/autoreceipt/refusals artifacts/actuation/plans artifacts/actuation/receipts artifacts/actuation/refusals",
    "oo:build-autoreceipt": "python3 scripts/oo/main.py build-autoreceipt",
    "oo:validate-public-ontology": "python3 scripts/oo/main.py validate-public-ontology",
    "oo:scan-private-namespace": "python3 scripts/oo/main.py scan-private-namespace",
    "oo:build-execution-bindings": "python3 scripts/oo/main.py build-execution-bindings",
    "oo:reject-synthetic-closure": "python3 scripts/oo/main.py reject-synthetic-closure",
    "oo:run-executable-batch": "python3 scripts/oo/main.py run-executable-batch",
    "oo:capture-observed-ocel": "python3 scripts/oo/main.py capture-observed-ocel",
    "oo:align-ocel": "python3 scripts/oo/main.py align-ocel",
    "oo:verify-receipts": "python3 scripts/oo/main.py verify-receipts",
    "oo:verify-actuation": "python3 scripts/oo/main.py verify-actuation",
    "oo:verify-cli": "python3 scripts/oo/main.py verify-cli",
    "oo:verify-mcp-a2a": "python3 scripts/oo/main.py verify-mcp-a2a",
    "oo:emit-proof-block": "python3 scripts/oo/main.py emit-proof-block",
    "oo:adversarial-dod": "python3 scripts/oo/adversarial_dod.py"
  }
}

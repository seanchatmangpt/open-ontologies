PREFIX ghf:  <https://open-ontologies.org/profile/github-factory#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT
  (GROUP_CONCAT(?repoName;    SEPARATOR="|") AS ?repoNames)
  (GROUP_CONCAT(?labelName;   SEPARATOR="|") AS ?labelNames)
  (GROUP_CONCAT(?labelColor;  SEPARATOR="|") AS ?labelColors)
  (GROUP_CONCAT(?labelDesc;   SEPARATOR="|") AS ?labelDescs)
WHERE {
  ?repo a ghf:GitHubRepository ;
        ghf:name ?repoName ;
        ghf:hasLabel ?label .
  ?label ghf:name ?labelName ;
         ghf:color ?labelColor ;
         ghf:description ?labelDesc .
}

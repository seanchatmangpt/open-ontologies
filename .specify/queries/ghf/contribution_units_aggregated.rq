PREFIX ghf:  <https://open-ontologies.org/profile/github-factory#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT
  (GROUP_CONCAT(?jtbdId;      SEPARATOR="|") AS ?jtbdIds)
  (GROUP_CONCAT(?persona;     SEPARATOR="|") AS ?personas)
  (GROUP_CONCAT(?repoName;    SEPARATOR="|") AS ?repoNames)
WHERE {
  ?unit a ghf:ContributionUnit ;
        ghf:jtbdId ?jtbdId ;
        ghf:persona ?persona ;
        ghf:targetRepository ?repo .
  ?repo ghf:name ?repoName .
}

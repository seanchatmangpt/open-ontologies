# =============================================================================
# extract-ocel-events.rq — Extract OCEL event type definitions
# =============================================================================
#
# Returns ONE aggregated row with pipe-delimited values for rendering
# OCEL TypeScript emitters. ggen v5 renders once per SELECT row.
#
# Template variables (all pipe-delimited GROUP_CONCAT aggregates):
#   ?eventCodes     — skos:notation per event type
#   ?eventLabels    — rdfs:label per event type
#   ?eventDefs      — skos:definition per event type (empty string if absent)
#   ?eventRoutes    — emitting route code per event type (empty string if absent)
#
# ggen v5 constraint: only cli-open-ontologies.ttl is loaded.
# Connect Group OCEL events use VALUES fallbacks — 8 canonical event types
# for the autonomic Connect Group route (Wave 29).
# =============================================================================

PREFIX zoe:  <https://zoela.org/ontology/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT
  (GROUP_CONCAT(?code;   SEPARATOR="|") AS ?eventCodes)
  (GROUP_CONCAT(?label;  SEPARATOR="|") AS ?eventLabels)
  (GROUP_CONCAT(?def;    SEPARATOR="|") AS ?eventDefs)
  (GROUP_CONCAT(?route;  SEPARATOR="|") AS ?eventRoutes)
WHERE {
  # VALUES fallback: 8 Connect Group OCEL event types (Wave 29 autonomic route)
  # These are emitted during the 8-stage Connect Group lifecycle.
  VALUES (?code ?label ?def ?route) {
    ("cg.interest.submitted"   "Interest Submitted"   "Member submits interest in joining a connect group"   "connect-group")
    ("cg.groups.matched"       "Groups Matched"       "System matches member to eligible connect groups"      "connect-group")
    ("cg.invite.sent"          "Invite Sent"          "Connect group leader sends invitation to member"       "connect-group")
    ("cg.invite.accepted"      "Invite Accepted"      "Member accepts connect group invitation"               "connect-group")
    ("cg.spot.reserved"        "Spot Reserved"        "Member spot reserved in connect group"                 "connect-group")
    ("cg.attendance.recorded"  "Attendance Recorded"  "Attendance recorded for connect group session"         "connect-group")
    ("cg.followup.created"     "Follow-up Created"    "Pastoral follow-up created for member engagement"      "connect-group")
    ("cg.route.closed"         "Route Closed"         "Connect group route completed and closed"              "connect-group")
  }
}
ORDER BY ?code

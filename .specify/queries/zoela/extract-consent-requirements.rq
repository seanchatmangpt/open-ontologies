# =============================================================================
# extract-consent-requirements.rq — Extract consent definitions and gate facts
# =============================================================================
#
# ggen v5 SELECT format: one row per consent type with GROUP_CONCAT aggregates
# for multi-valued stage/route associations.
#
# Template variables per row:
#   ?consent_code       — skos:notation of the consent (e.g. "PHOTO-RELEASE")
#   ?consent_label      — rdfs:label of the consent
#   ?consent_definition — skos:definition or fallback "Consent type: <code>"
#   ?is_guardian_type   — "true" if consent code is GUARD or MED, else "false"
#   ?blocks_stages      — pipe-delimited stage codes blocked without this consent
#   ?used_in_routes     — pipe-delimited route codes where this consent is needed
# =============================================================================

PREFIX zoe:  <https://zoela.org/ontology/>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT
  ?consent_code
  ?consent_label
  (COALESCE(?consent_def, CONCAT("Consent type: ", ?consent_code)) AS ?consent_definition)
  (IF(?consent_code IN ("GUARD", "MED"), "true", "false") AS ?is_guardian_type)
  (GROUP_CONCAT(DISTINCT ?stage_code; separator="|") AS ?blocks_stages)
  (GROUP_CONCAT(DISTINCT ?route_code; separator="|") AS ?used_in_routes)
WHERE {
  ?consent a skos:Concept ;
    skos:inScheme zoe:ConsentTypeScheme ;
    skos:notation ?consent_code ;
    rdfs:label ?consent_label .
  OPTIONAL { ?consent skos:definition ?consent_def }
  OPTIONAL {
    ?stage zoe:requiredConsentType ?consent ;
      skos:notation ?stage_code ;
      zoe:hasRoute ?route .
    ?route skos:notation ?route_code .
  }
}
GROUP BY ?consent_code ?consent_label ?consent_def
ORDER BY ?consent_code

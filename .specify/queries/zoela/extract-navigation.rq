# =============================================================================
# extract-navigation.rq — single-row aggregated tab+screen bundle
# =============================================================================
#
# One aggregated row containing every tab and every screen within each tab.
# expo-navigation-stack.tera loops twice: once over tabs, once per tab's
# screens.
#
# Encoding:
#   ?tabCodes   — "HOME|GROUPS|..."             (one tab per "|")
#   ?tabLabels  — "Home|Connect Groups|..."     (one tab per "|", same order)
#   ?tabScreens — "h1||h2||h3@@@g1||g2@@@..."   tabs separated by "@@@",
#                                                screens within a tab by "||",
#                                                screen fields by "|":
#                                                  id|navRoute|stack|order|isAdmin
# =============================================================================

PREFIX zoe:  <https://zoela.org/ontology/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT
  (GROUP_CONCAT(?tabCode;        SEPARATOR="|")   AS ?tabCodes)
  (GROUP_CONCAT(?tabLabel;       SEPARATOR="|")   AS ?tabLabels)
  (GROUP_CONCAT(?tabScreens_c;   SEPARATOR="@@@") AS ?tabScreensBundle)
WHERE {
  {
    SELECT ?tab
        (SAMPLE(?_tabCode)  AS ?tabCode)
        (SAMPLE(?_tabLabel) AS ?tabLabel)
        (COALESCE(GROUP_CONCAT(?_screenEntry; SEPARATOR="||"), "") AS ?tabScreens_c)
    WHERE {
      ?tab a skos:Concept ;
           skos:inScheme zoe:AppTabScheme ;
           skos:notation ?_tabCodeLit ;
           rdfs:label    ?_tabLabelLit .
      BIND(STR(?_tabCodeLit)  AS ?_tabCode)
      BIND(STR(?_tabLabelLit) AS ?_tabLabel)

      OPTIONAL {
        ?screen a zoe:AppScreen ;
                zoe:parentTab ?tab ;
                skos:notation ?_sid .
        OPTIONAL { ?screen zoe:navRoute      ?_snav   }
        OPTIONAL { ?screen zoe:screenStack   ?_sstack }
        OPTIONAL { ?screen zoe:screenOrder   ?_sord   }
        OPTIONAL { ?screen zoe:isAdminOnly   ?_sadm   }
        BIND(CONCAT(
          COALESCE(STR(?_sid),   ""), "|",
          COALESCE(STR(?_snav),  ""), "|",
          COALESCE(STR(?_sstack),""), "|",
          COALESCE(STR(?_sord),  "0"),"|",
          COALESCE(STR(?_sadm),  "false")
        ) AS ?_screenEntry_c)
        BIND(COALESCE(?_screenEntry_c, "") AS ?_screenEntry)
      }
    }
    GROUP BY ?tab
    ORDER BY ?tabCode
  }
}

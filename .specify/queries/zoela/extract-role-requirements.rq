# =============================================================================
# extract-role-requirements.rq — Extract ZOE LA role permission constants
# =============================================================================
#
# Returns ONE aggregated row with pipe-delimited values for rendering
# TypeScript role-access constants. ggen v5 renders once per SELECT row.
#
# Source: ontology/zoela/roles.ttl (ZoeRole named individuals)
# Uses VALUES fallback because ggen loads ontology/cli-open-ontologies.ttl
# as its single source; the zoela TTL files are not in ggen's RDF store.
#
# Template variables (all pipe-delimited GROUP_CONCAT aggregates):
#   ?role_codes          — skos:notation (role code) per role
#   ?role_labels         — rdfs:label per role
#   ?permission_levels   — permissionLevel integer per role
#   ?can_view_sensitives — "true"/"false" per role
#   ?can_create_receipts — "true"/"false" per role
#   ?can_assign_vols     — "true"/"false" per role
#   ?req_trainings       — "true"/"false" per role
#   ?req_bgcs            — "true"/"false" per role
# =============================================================================

PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT
  (GROUP_CONCAT(?role_code;       SEPARATOR="|") AS ?role_codes)
  (GROUP_CONCAT(?role_label;      SEPARATOR="|") AS ?role_labels)
  (GROUP_CONCAT(?perm_level;      SEPARATOR="|") AS ?permission_levels)
  (GROUP_CONCAT(?can_view;        SEPARATOR="|") AS ?can_view_sensitives)
  (GROUP_CONCAT(?can_receipt;     SEPARATOR="|") AS ?can_create_receipts)
  (GROUP_CONCAT(?can_assign;      SEPARATOR="|") AS ?can_assign_vols)
  (GROUP_CONCAT(?req_training;    SEPARATOR="|") AS ?req_trainings)
  (GROUP_CONCAT(?req_bgc;         SEPARATOR="|") AS ?req_bgcs)
WHERE {
  VALUES (?role_code ?role_label ?perm_level ?can_view ?can_receipt ?can_assign ?req_training ?req_bgc) {
    ("MEMBER"   "Member"                          "1" "false" "false" "false" "false" "false")
    ("VOL"      "Volunteer"                       "2" "false" "false" "false" "true"  "false")
    ("PARTNER"  "Partner Organization Rep"        "2" "false" "false" "false" "false" "false")
    ("CARE"     "Care Team Member"                "3" "true"  "false" "false" "false" "true")
    ("LEADER"   "Ministry Leader"                 "3" "true"  "false" "true"  "false" "false")
    ("YTH-LEAD" "Youth Leader"                    "3" "true"  "false" "false" "true"  "true")
    ("ADMIN"    "Administrator"                   "4" "true"  "true"  "true"  "false" "false")
    ("PASTOR"   "Pastor"                          "5" "true"  "true"  "true"  "false" "false")
  }
}
ORDER BY ?perm_level

# =============================================================================
# extract-push-card-fields.rq — single-row aggregated push card bundle
# =============================================================================
#
# Aggregates every PushCardTemplate into ONE row with pipe-delimited fields,
# so push-card.tera (which already loops over split arrays) emits the entire
# PUSH_CARDS array in one file render.
# =============================================================================

PREFIX zoe:  <https://zoela.org/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT
  (GROUP_CONCAT(?_cardTitle;     SEPARATOR="|") AS ?card_title)
  (GROUP_CONCAT(?_cardSubtitle;  SEPARATOR="|") AS ?card_subtitle)
  (GROUP_CONCAT(?_cardBody;      SEPARATOR="|") AS ?card_body)
  (GROUP_CONCAT(?_cardAction;    SEPARATOR="|") AS ?card_action)
  (GROUP_CONCAT(?_cardDeepLink;  SEPARATOR="|") AS ?card_deep_link)
  (GROUP_CONCAT(?_cardPriority;  SEPARATOR="|") AS ?card_priority)
WHERE {
  {
    SELECT ?card ?_orderKey
        (SAMPLE(?_cardTitle_c)     AS ?_cardTitle)
        (SAMPLE(?_cardSubtitle_c)  AS ?_cardSubtitle)
        (SAMPLE(?_cardBody_c)      AS ?_cardBody)
        (SAMPLE(?_cardAction_c)    AS ?_cardAction)
        (SAMPLE(?_cardDeepLink_c)  AS ?_cardDeepLink)
        (SAMPLE(?_cardPriority_c)  AS ?_cardPriority)
    WHERE {
      ?card a zoe:PushCardTemplate ;
            rdfs:label ?_cardTitleLit .
      BIND(STR(?_cardTitleLit) AS ?_cardTitleRaw)

      OPTIONAL { ?card zoe:cardSubtitle ?_cardSubtitleRawX BIND(STR(?_cardSubtitleRawX) AS ?_cardSubtitleRaw) }
      OPTIONAL { ?card zoe:cardBody     ?_cardBodyRawX     BIND(STR(?_cardBodyRawX)     AS ?_cardBodyRaw) }
      OPTIONAL { ?card zoe:cardAction   ?_cardActionRawX   BIND(STR(?_cardActionRawX)   AS ?_cardActionRaw) }
      OPTIONAL { ?card zoe:cardDeepLink ?_cardDeepLinkRawX BIND(STR(?_cardDeepLinkRawX) AS ?_cardDeepLinkRaw) }
      OPTIONAL { ?card zoe:cardPriority ?_cardPriorityRawX BIND(STR(?_cardPriorityRawX) AS ?_cardPriorityRaw) }

      BIND(COALESCE(?_cardTitleRaw,    "")  AS ?_cardTitle_c)
      BIND(COALESCE(?_cardSubtitleRaw, "")  AS ?_cardSubtitle_c)
      BIND(COALESCE(?_cardBodyRaw,     "")  AS ?_cardBody_c)
      BIND(COALESCE(?_cardActionRaw,   "")  AS ?_cardAction_c)
      BIND(COALESCE(?_cardDeepLinkRaw, "")  AS ?_cardDeepLink_c)
      BIND(COALESCE(?_cardPriorityRaw, "0") AS ?_cardPriority_c)
      BIND(STR(?card) AS ?_orderKey)
    }
    GROUP BY ?card ?_orderKey
    ORDER BY ?_orderKey
  }
}

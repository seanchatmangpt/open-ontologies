# =============================================================================
# extract-public-materializations.rq — admissibility-aware materialization extractor
# =============================================================================
#
# P0-B.4d: surfaces ?materializationStatus per ZOE class so the template can
# refuse to emit DDL for incomplete materializations.
#
# Status values (one per class slot):
#   admitted
#   refused_missing_shape       — kind lacks ggen:requiresShape OR shape is not a sh:NodeShape
#   refused_no_columns          — class has zero datatype/object properties with skos:notation
#   refused_missing_datatype    — at least one property of the class lacks rdfs:range
#   refused_duplicate_columns   — two distinct properties of the class normalize to same column
#   refused_missing_policy      — kind has rlsRequired=true but no ODRL permission targets it
#
# Structural design (nested aggregation):
#   - Inner sub-query GROUPs BY ?class and produces per-class facts INCLUDING
#     a comma-delimited list of (column, type, required, fk, desc) tuples.
#   - Outer query aggregates one row per class via DISTINCT.
#   - Result: ONE slot per class for every binding. No cartesian product.
#
# Output: ONE aggregated row with pipe-delimited columns.
#   Class-level (one slot per class):
#     ?classIris ?classNames ?tableNames ?classDescriptions
#     ?publicAnchorIris ?materializationKinds ?materializationCodes
#     ?requiresOwner ?requiresAuditTrail ?targetRuntimes ?shapeIris
#     ?materializationStatuses
#
#   Property facts encoded as ?classColumnTuples:
#     Outer separator (between classes) = "@@@"
#     Inner separator (within one class's tuple list) = ","
#     Field separator (within one tuple) = "::"
#     Tuple shape: column_name::sql_type::required::fk_table::description
#     Empty class column list = ""
# =============================================================================

PREFIX ggen:   <https://open-ontologies.org/ggen#>
PREFIX zoe:    <https://zoela.org/ontology/>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sh:     <http://www.w3.org/ns/shacl#>
PREFIX skos:   <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX odrl:   <http://www.w3.org/ns/odrl/2/>

SELECT
  (GROUP_CONCAT(?classIriStr;            SEPARATOR="|") AS ?classIris)
  (GROUP_CONCAT(?className;              SEPARATOR="|") AS ?classNames)
  (GROUP_CONCAT(?tableName;              SEPARATOR="|") AS ?tableNames)
  (GROUP_CONCAT(?classDescription;       SEPARATOR="|") AS ?classDescriptions)
  (GROUP_CONCAT(?publicAnchorIri;        SEPARATOR="|") AS ?publicAnchorIris)
  (GROUP_CONCAT(?materializationKindIri; SEPARATOR="|") AS ?materializationKinds)
  (GROUP_CONCAT(?materializationCode;    SEPARATOR="|") AS ?materializationCodes)
  (GROUP_CONCAT(?requiresOwnerStr;       SEPARATOR="|") AS ?requiresOwner)
  (GROUP_CONCAT(?requiresAuditTrailStr;  SEPARATOR="|") AS ?requiresAuditTrail)
  (GROUP_CONCAT(?targetRuntime;          SEPARATOR="|") AS ?targetRuntimes)
  (GROUP_CONCAT(?shapeIriStr;            SEPARATOR="|") AS ?shapeIris)
  (GROUP_CONCAT(?materializationStatus;  SEPARATOR="|") AS ?materializationStatuses)
  (GROUP_CONCAT(?classColumnTuples;      SEPARATOR="@@@") AS ?classColumnTuples)
WHERE {
  {
    SELECT
        ?class
        (SAMPLE(?_classIriStr) AS ?classIriStr)
        ?className
        ?tableName
        (SAMPLE(?_classDescription) AS ?classDescription)
        (SAMPLE(?_publicAnchorIri) AS ?publicAnchorIri)
        ?materializationKindIri
        ?materializationCode
        (SAMPLE(?_requiresOwnerStr) AS ?requiresOwnerStr)
        (SAMPLE(?_requiresAuditTrailStr) AS ?requiresAuditTrailStr)
        ?targetRuntime
        (SAMPLE(?_shapeIriStr) AS ?shapeIriStr)
        (SAMPLE(?_materializationStatus) AS ?materializationStatus)
        (SAMPLE(?_classColumnTuples) AS ?classColumnTuples)
    WHERE {
      ?class a owl:Class ;
             rdfs:label    ?className ;
             skos:notation ?tableName .
      FILTER(STRSTARTS(STR(?class), "https://zoela.org/ontology/"))

      ?class rdfs:subClassOf+ ?_anchor .
      FILTER(!STRSTARTS(STR(?_anchor), "https://zoela.org/ontology/"))
      FILTER(?_anchor != owl:Thing)
      FILTER(isIRI(?_anchor))

      ?materializationKind a ggen:MaterializationKind ;
                           ggen:materializesPublicAnchor ?_anchor ;
                           ggen:emitsSql       true ;
                           skos:notation       ?materializationCode ;
                           ggen:targetRuntime  ?targetRuntime ;
                           ggen:requiresOwner  ?_requiresOwnerVal ;
                           ggen:requiresAuditTrail ?_requiresAuditTrailVal .

      OPTIONAL { ?materializationKind ggen:requiresShape ?_shape }
      OPTIONAL { ?materializationKind ggen:rlsRequired   ?_rlsRequired }

      OPTIONAL { ?class rdfs:comment ?_cdRaw }

      # ── Per-class property tuple list ──────────────────────────────────
      OPTIONAL {
        {
          SELECT ?_pcClass
                 (GROUP_CONCAT(DISTINCT ?_pcTuple; SEPARATOR=",") AS ?_classColumnTuplesInner)
          WHERE {
            ?_pcClass a owl:Class .
            FILTER(STRSTARTS(STR(?_pcClass), "https://zoela.org/ontology/"))
            ?_pcProp rdfs:domain   ?_pcClass ;
                     skos:notation ?_pcCol .
            OPTIONAL { ?_pcProp rdfs:range ?_pcRange }
            OPTIONAL { ?_pcProp rdfs:comment ?_pcDescRaw }
            BIND(REPLACE(STR(COALESCE(?_pcDescRaw, "")), "[,@:|]", " ") AS ?_pcDesc)
            BIND(
              IF(EXISTS { ?_pcProp a owl:ObjectProperty }, "UUID",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:boolean,    "BOOLEAN",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:integer,    "INTEGER",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:int,        "INTEGER",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:long,       "BIGINT",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:decimal,    "NUMERIC",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:dateTime,   "TIMESTAMPTZ",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:date,       "DATE",
              IF(BOUND(?_pcRange) && ?_pcRange = xsd:anyURI,     "TEXT",
              "TEXT"))))))))) AS ?_pcSqlType
            )
            OPTIONAL {
              ?_pcRange a owl:Class ; skos:notation ?_pcFkRaw .
              FILTER(STRSTARTS(STR(?_pcRange), "https://zoela.org/ontology/"))
            }
            BIND(COALESCE(?_pcFkRaw, "") AS ?_pcFk)
            BIND(CONCAT(STR(?_pcCol), "::", ?_pcSqlType, "::false::", ?_pcFk, "::", ?_pcDesc) AS ?_pcTuple)
          }
          GROUP BY ?_pcClass
        }
        FILTER(?_pcClass = ?class)
        BIND(?_classColumnTuplesInner AS ?_classColumnTuples)
      }

      # ── Admissibility checks ───────────────────────────────────────────
      BIND(BOUND(?_shape) && EXISTS { ?_shape a sh:NodeShape } AS ?hasShape)

      BIND(EXISTS { ?_p1 rdfs:domain ?class ; skos:notation ?_c1 } AS ?hasColumns)

      BIND(EXISTS {
        ?_p2 rdfs:domain ?class ; skos:notation ?_c2 .
        FILTER NOT EXISTS { ?_p2 rdfs:range ?_r }
      } AS ?hasUnrangedProp)

      BIND(EXISTS {
        ?_pA rdfs:domain ?class ; skos:notation ?_nA .
        ?_pB rdfs:domain ?class ; skos:notation ?_nB .
        FILTER(?_pA != ?_pB)
        FILTER(LCASE(STR(?_nA)) = LCASE(STR(?_nB)))
      } AS ?hasDuplicateColumns)

      BIND(
        IF(BOUND(?_rlsRequired) && ?_rlsRequired,
          NOT EXISTS {
            ?_act ggen:rlsTargetKind ?materializationKind .
            ?_pol a odrl:Policy ; odrl:permission [ odrl:action ?_act ] .
          },
          false
        ) AS ?missingPolicy
      )

      BIND(STR(?class)                       AS ?_classIriStr)
      BIND(STR(?materializationKind)         AS ?materializationKindIri)
      BIND(STR(?_anchor)                     AS ?_publicAnchorIri)
      BIND(IF(BOUND(?_shape), STR(?_shape), "") AS ?_shapeIriStr)
      BIND(IF(?_requiresOwnerVal,      "true", "false") AS ?_requiresOwnerStr)
      BIND(IF(?_requiresAuditTrailVal, "true", "false") AS ?_requiresAuditTrailStr)
      BIND(COALESCE(?_cdRaw, "")             AS ?_classDescription)
      BIND(
        IF(!?hasShape,           "refused_missing_shape",
        IF(!?hasColumns,         "refused_no_columns",
        IF(?hasUnrangedProp,     "refused_missing_datatype",
        IF(?hasDuplicateColumns, "refused_duplicate_columns",
        IF(?missingPolicy,       "refused_missing_policy",
        "admitted")))))
        AS ?_materializationStatus
      )
    }
    GROUP BY ?class ?className ?tableName ?materializationKindIri ?materializationCode ?targetRuntime
  }
}

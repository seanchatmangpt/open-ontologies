PREFIX truex: <https://open-ontologies.org/profile/truex#>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>

SELECT ?labels ?definitions
WHERE {
  {
    SELECT (GROUP_CONCAT(?label; SEPARATOR="|") AS ?labels) (GROUP_CONCAT(?definition; SEPARATOR="|") AS ?definitions)
    WHERE {
      ?failure a truex:Failure ;
               rdfs:label ?label ;
               skos:definition ?definition .
    }
  }
}

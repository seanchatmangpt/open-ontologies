PREFIX truex: <https://open-ontologies.org/profile/truex#>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?package ?name ?purpose WHERE {
  ?package a truex:Package ;
           truex:packageName ?name ;
           truex:purpose ?purpose .
}
ORDER BY ?name

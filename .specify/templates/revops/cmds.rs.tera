//! RevOps manufacturing stage constants — generated from ontology/revops-manufacturing.ttl
//!
//! Stages are ordered by `revops:stageOrder` (ascending).
//! Each stage name corresponds to an OCEL event type emitted during manufacturing.

{%- set stage_list = stageNames | split(pat="|") %}

/// Ordered manufacturing stage names for the CodeManufactory RevOps test case.
///
/// These correspond to `revops:stageName` values in `ontology/revops-manufacturing.ttl`.
/// The sequence maps directly to OCEL event types; Cell8 gate A13 verifies that
/// every artifact traverses all stages in this exact order.
pub const REVOPS_STAGES: &[&str] = &[
{%- for stage in stage_list %}
{%- if stage | trim != "" %}
    "{{ stage | trim }}",
{%- endif %}
{%- endfor %}
];

/// Number of manufacturing stages in the RevOps profile.
#[allow(dead_code)]
pub const REVOPS_STAGE_COUNT: usize = REVOPS_STAGES.len();

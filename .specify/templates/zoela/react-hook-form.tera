{#-
  react-hook-form.tera — Generated react-hook-form configs for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-forms

  ggen v5 rendering model: renders once per SELECT row.
  extract-form-fields.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited):
    ?formIds       — skos:notation per form class
    ?formLabels    — rdfs:label per form class
    ?fieldForms    — form id repeated per field
    ?fieldNames    — field skos:notation (column name)
    ?fieldLabels   — field rdfs:label
    ?fieldTypes    — HTML input type: text|number|checkbox|date|datetime-local
    ?fieldRequired — "true" or "false"
    ?fieldComments — rdfs:comment per field
-#}
// Generated from ontology/zoela/*.ttl — DO NOT EDIT
// Regenerate with: ggen sync --rule zoela-forms
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';

{%- set form_id_list      = formIds       | split(pat="|") %}
{%- set form_label_list   = formLabels    | split(pat="|") %}
{%- set field_form_list   = fieldForms    | split(pat="|") %}
{%- set field_name_list   = fieldNames    | split(pat="|") %}
{%- set field_label_list  = fieldLabels   | split(pat="|") %}
{%- set field_type_list   = fieldTypes    | split(pat="|") %}
{%- set field_req_list    = fieldRequired | split(pat="|") %}
{%- set field_comment_list = fieldComments | split(pat="|") %}

{% for form_id in form_id_list %}
{%- set fidx      = loop.index0 %}
{%- set form_label = form_label_list[fidx] | default(value="") %}
{%- if form_id | trim != "" %}

// ============================================================================
// {{ form_label | trim }} form config
// Source: ontology/zoela — {{ form_id | trim }}
// ============================================================================
export interface {{ form_id | trim | title | replace(from=" ", to="") | replace(from="_", to="") }}FormValues {
{%- for field_name in field_name_list %}
{%- set nidx   = loop.index0 %}
{%- set owner  = field_form_list[nidx]    | default(value="") %}
{%- set ftype  = field_type_list[nidx]    | default(value="text") %}
{%- set freq   = field_req_list[nidx]     | default(value="false") %}
{%- if owner | trim == form_id | trim and field_name | trim != "" %}
  {{ field_name | trim }}{% if freq | trim != "true" %}?{% endif %}: {% if ftype | trim == "checkbox" %}boolean{% elif ftype | trim == "number" %}number{% else %}string{% endif %};
{%- endif %}
{%- endfor %}
}

export const {{ form_id | trim | title | replace(from=" ", to="") | replace(from="_", to="") }}FormFields = [
{%- for field_name in field_name_list %}
{%- set nidx     = loop.index0 %}
{%- set owner    = field_form_list[nidx]    | default(value="") %}
{%- set flabel   = field_label_list[nidx]   | default(value="") %}
{%- set ftype    = field_type_list[nidx]    | default(value="text") %}
{%- set freq     = field_req_list[nidx]     | default(value="false") %}
{%- set fcomment = field_comment_list[nidx] | default(value="") %}
{%- if owner | trim == form_id | trim and field_name | trim != "" %}
  {
    name: '{{ field_name | trim }}',
    label: '{{ flabel | trim }}',
    type: '{{ ftype | trim }}',
    required: {{ freq | trim }},
    placeholder: "{{ fcomment | trim }}",
  },
{%- endif %}
{%- endfor %}
] as const;

{%- endif %}
{%- endfor %}

{#-
  zod-schema.tera — Generated Zod validation schemas for ZOE LA Mobile

  Generated by ggen from SHACL shapes in ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --target zoela-mobile

  ggen v5 rendering model: renders once per SELECT row.
  shapes_aggregated.rq returns ONE row with pipe-delimited aggregates,
  so this template renders exactly once and produces the complete file.

  SPARQL variables from shapes_aggregated.rq (all pipe-delimited):
    ?shapeNames        — sh:NodeShape local names (e.g. "PersonProfileShape|HouseholdShape")
    ?shapeTargets      — target class local name for each shape
    ?shapeDescriptions — rdfs:comment for each shape

    Per-field variables (every sh:property from every shape, in shape order):
    ?fieldShapes       — which shape each field belongs to
    ?fieldNames        — camelCase JS field name (derived from sh:path local name)
    ?fieldTypes        — mapped Zod type string: "string"|"number"|"boolean"|"uuid"|"email"|"url"|"datetime"
    ?fieldRequired     — "true" or "false"
    ?fieldDescriptions — rdfs:comment or sh:description values
    ?fieldMinLength    — sh:minLength value or empty string
    ?fieldMaxLength    — sh:maxLength value or empty string
    ?fieldPattern      — sh:pattern regex or empty string
-#}
// Generated from SHACL shapes in ontology/zoela/*.ttl — DO NOT EDIT
// Regenerate with: ggen sync --target zoela-mobile
//
// Architecture:
//   Tier 1 — ontology/zoela/*.ttl           (source of truth — SHACL shapes)
//   Tier 2 — ggen sync                      (manufacturing step)
//   Tier 3 — src/schemas/zoela.ts           (this file, used by app forms)
import { z } from 'zod';

{%- set shape_name_list        = shapeNames        | split(pat="|") %}
{%- set shape_target_list      = shapeTargets      | split(pat="|") %}
{%- set shape_description_list = shapeDescriptions | split(pat="|") %}
{%- set field_shape_list       = fieldShapes       | split(pat="|") %}
{%- set field_name_list        = fieldNames        | split(pat="|") %}
{%- set field_type_list        = fieldTypes        | split(pat="|") %}
{%- set field_required_list    = fieldRequired     | split(pat="|") %}
{%- set field_description_list = fieldDescriptions | split(pat="|") %}
{%- set field_min_length_list  = fieldMinLengths   | split(pat="|") %}
{%- set field_max_length_list  = fieldMaxLengths   | split(pat="|") %}
{%- set field_pattern_list     = fieldPatterns     | split(pat="|") %}

// ============================================================================
// Shared base schema — applied via .merge() or .extend() in each domain schema
// ============================================================================
export const zoelaBaseSchema = z.object({
  id:         z.string().uuid(),
  created_at: z.string().datetime({ offset: true }),
  updated_at: z.string().datetime({ offset: true }).optional(),
});

// ============================================================================
// Domain schemas — one per SHACL NodeShape targeting a ZOE LA class
// ============================================================================
{% for shape_name in shape_name_list %}
{%- set sidx        = loop.index0 %}
{%- set target      = shape_target_list[sidx]      | default(value="") %}
{%- set shape_desc  = shape_description_list[sidx] | default(value="") %}
{%- if shape_name | trim != "" %}

// ----------------------------------------------------------------------------
// {{ shape_name | trim }}{% if target | trim != "" %} → targets {{ target | trim }}{% endif %}
{%- if shape_desc | trim != "" %}
// {{ shape_desc | trim }}
{%- endif %}
// ----------------------------------------------------------------------------
export const {{ shape_name | trim | replace(from="Shape", to="") | lower }}Schema = zoelaBaseSchema.extend({
{%- for field_name in field_name_list %}
{%- set fidx    = loop.index0 %}
{%- set owner   = field_shape_list[fidx]       | default(value="") %}
{%- set fname   = field_name_list[fidx]        | default(value="") %}
{%- set ftype   = field_type_list[fidx]        | default(value="string") %}
{%- set freq    = field_required_list[fidx]    | default(value="false") %}
{%- set fdesc   = field_description_list[fidx] | default(value="") %}
{%- set fminlen = field_min_length_list[fidx]  | default(value="") %}
{%- set fmaxlen = field_max_length_list[fidx]  | default(value="") %}
{%- set fpat    = field_pattern_list[fidx]     | default(value="") %}
{%- if owner | trim == shape_name | trim and fname | trim != "" %}
  // {{ fdesc | trim }}
  {{ fname | trim }}: {%- if ftype | trim == "uuid" %} z.string().uuid()
{%- elif ftype | trim == "email" %} z.string().email()
{%- elif ftype | trim == "url" %} z.string().url()
{%- elif ftype | trim == "datetime" %} z.string().datetime({ offset: true })
{%- elif ftype | trim == "number" %} z.number()
{%- elif ftype | trim == "boolean" %} z.boolean()
{%- elif fminlen | trim != "" and fmaxlen | trim != "" %} z.string().min({{ fminlen | trim }}).max({{ fmaxlen | trim }})
{%- elif fminlen | trim != "" %} z.string().min({{ fminlen | trim }})
{%- elif fmaxlen | trim != "" %} z.string().max({{ fmaxlen | trim }})
{%- elif fpat | trim != "" %} z.string().regex(/{{ fpat | trim }}/)
{%- else %} z.string()
{%- endif %}{% if freq | trim != "true" %}.optional(){% endif %},
{%- endif %}
{%- endfor %}
});

export type {{ shape_name | trim | replace(from="Shape", to="") }} = z.infer<typeof {{ shape_name | trim | replace(from="Shape", to="") | lower }}Schema>;
{%- endif %}
{%- endfor %}

// ============================================================================
// Insert schemas — strip id/created_at/updated_at (Supabase generates these)
// ============================================================================
{% for shape_name in shape_name_list %}
{%- if shape_name | trim != "" %}
export const {{ shape_name | trim | replace(from="Shape", to="") | lower }}InsertSchema =
  {{ shape_name | trim | replace(from="Shape", to="") | lower }}Schema.omit({ id: true, created_at: true, updated_at: true });

export type {{ shape_name | trim | replace(from="Shape", to="") }}Insert =
  z.infer<typeof {{ shape_name | trim | replace(from="Shape", to="") | lower }}InsertSchema>;
{%- endif %}
{% endfor %}

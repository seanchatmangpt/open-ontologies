{#-
  supabase-governance.tera — operational reference tables for RLS

  P0-B.7c: Emits the `roles` and `person_role_assignments` tables that
  zoela-rls.sql subqueries depend on. Must apply BEFORE zoela-rls.sql.

  Doctrine:
    - The extractor emits one row per governance table with column DDL and
      seed rows packed in pipe-delimited bundles. This template just formats.
    - No RLS is enabled on these tables — they're the foundation RLS uses.
      Mutations are restricted by Postgres role grants (service_role only)
      at the runtime layer.
    - Seeds are emitted as INSERT ... ON CONFLICT DO NOTHING so the rows
      exist after `supabase db reset` without breaking idempotency.

  Consumes pipe-delimited bindings from extract-governance-tables.rq:
    ?tableNames    — table notation per row, "|"
    ?classLabels   — human label per row, "|"
    ?classDescs    — comment per row, "|"
    ?classIris     — local class IRI per row, "|"
    ?colSpecs      — columns per row: tables="@@@", cols within table="|||"
    ?seedSpecs     — seeds per row:   tables="@@@", rows within table="|||"
-#}
-- =============================================================================
-- ZOE LA Supabase Governance — generated from declarative profile
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from:
--   ontology/profiles/zoela-governance.ttl
-- Regenerate with: ggen sync --rule zoela-governance
--
-- These tables are the substrate that zoela-rls.sql subqueries reference.
-- They must apply BEFORE zoela-rls.sql.
--
-- RLS is NOT enabled on these tables: the policy subqueries that gate domain
-- tables read from here, and enabling RLS on roles/person_role_assignments
-- would create a circular dependency. Mutations are restricted at the
-- Postgres role layer (only service_role / postgres can INSERT/UPDATE/DELETE
-- by default).
-- =============================================================================

{%- set table_name_list  = tableNames  | split(pat="|") %}
{%- set class_label_list = classLabels | split(pat="|") %}
{%- set class_desc_list  = classDescs  | split(pat="|") %}
{%- set class_iri_list   = classIris   | split(pat="|") %}
{%- set col_specs_list   = colSpecs    | split(pat="@@@") %}
{%- set seed_specs_list  = seedSpecs   | split(pat="@@@") %}

{%- set governance_count = 0 %}
{%- for t in table_name_list %}
{%-   if t | trim != "" %}{% set_global governance_count = governance_count + 1 %}{% endif %}
{%- endfor %}

-- Governance tables: {{ governance_count }}

{%- for raw_table in table_name_list %}
{%-   set idx        = loop.index0 %}
{%-   set table_raw  = raw_table                       | default(value="") | trim %}
{%-   set table      = table_raw | lower | replace(from="-", to="_") %}
{%-   set label_txt  = class_label_list[idx] | default(value="") | trim %}
{%-   set desc_txt   = class_desc_list[idx]  | default(value="") | trim %}
{%-   set iri_txt    = class_iri_list[idx]   | default(value="") | trim %}
{%-   set col_bundle = col_specs_list[idx]   | default(value="") | trim %}
{%-   set seed_bundle = seed_specs_list[idx] | default(value="") | trim %}

{%-   if table != "" %}

-- ----------------------------------------------------------------------------
-- {{ label_txt }} ({{ table }})
--   Local class: {{ iri_txt }}
{%-     if desc_txt != "" %}
--   {{ desc_txt }}
{%-     endif %}
-- ----------------------------------------------------------------------------

CREATE TABLE IF NOT EXISTS {{ table }} (
  id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ
{%-     if col_bundle != "" %}
{%-       set cols = col_bundle | split(pat="|||") %}
{%-       for c in cols %}
{%-         set c_trim = c | trim %}
{%-         if c_trim != "" %},
  {{ c_trim }}
{%-         endif %}
{%-       endfor %}
{%-     endif %}
);

DROP TRIGGER IF EXISTS set_{{ table }}_updated_at ON {{ table }};
CREATE TRIGGER set_{{ table }}_updated_at
  BEFORE UPDATE ON {{ table }}
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();

{%-     if seed_bundle != "" %}
{%-       set seeds = seed_bundle | split(pat="|||") %}
{%-       set_global seed_count = 0 %}
{%-       for s in seeds %}
{%-         if s | trim != "" %}{% set_global seed_count = seed_count + 1 %}{% endif %}
{%-       endfor %}
{%-       if seed_count > 0 and table == "roles" %}

-- Seed rows for {{ table }} ({{ seed_count }} rows)
INSERT INTO {{ table }} (role_code, role_label, description) VALUES
{%-         set_global first = true %}
{%-         for s in seeds %}
{%-           set s_trim = s | trim %}
{%-           if s_trim != "" %}
{%-             if not first %},{% endif %}
  {{ s_trim }}
{%-             set_global first = false %}
{%-           endif %}
{%-         endfor %}
ON CONFLICT (role_code) DO NOTHING;
{%-       endif %}
{%-     endif %}
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of governance migration. zoela-rls.sql may now reference these tables.
-- =============================================================================

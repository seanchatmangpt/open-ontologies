#!/usr/bin/env node
{#- shebang must be line 1; this comment stripped by -#} below -#}

// ============================================================
// DO NOT EDIT — generated by ggen from
//   ontology/profiles/zoela-expo-app.ttl + extract-verify-supabase.rq
// Regenerate: ggen sync --rule zoela-expo-verify-supabase
// ============================================================
//
// Host-side connectivity + RLS sanity check against a running self-hosted
// Supabase Docker stack. Exits 0 on success, non-zero on any failure.

import { createClient } from '@supabase/supabase-js';

const URL  = process.env.SUPABASE_URL ?? '{{ supabaseUrl }}';
const ANON = process.env.SUPABASE_ANON_KEY ?? '{{ supabaseAnonKey }}';

const supabase = createClient(URL, ANON, {
  auth: { persistSession: false, autoRefreshToken: false },
});

function logResult(name, ok, detail) {
  const tag = ok ? '\x1b[32m✓\x1b[0m' : '\x1b[31m✗\x1b[0m';
  console.log(`${tag} ${name}\n    ${detail}`);
  return ok;
}

let failures = 0;

{%- set probe_entries = probeBundle | split(pat="@@@") %}
{%- for entry in probe_entries %}
{%-   set parts = entry | split(pat="|") %}
{%-   set p_kind  = parts[0] | default(value="") | trim %}
{%-   set p_name  = parts[1] | default(value="") | trim %}
{%-   set p_table = parts[2] | default(value="") | trim %}
{%-   set p_col   = parts[3] | default(value="") | trim %}
{%-   set p_min   = parts[4] | default(value="0") | trim %}
{%-   if p_kind == "rest_reachable" %}

// Probe: {{ p_name }}
try {
  const r = await fetch(`${URL}/rest/v1/`, { headers: { apikey: ANON } });
  const ok = r.ok || r.status === 404;
  if (!logResult({{ p_name | json_encode | safe }}, ok,
    `HTTP ${r.status} from ${URL}/rest/v1/`)) failures++;
} catch (e) {
  logResult({{ p_name | json_encode | safe }}, false, `fetch error: ${e.message}`);
  failures++;
}
{%-   elif p_kind == "rls_denied" %}

// Probe: {{ p_name }}
{
  const { data, error } = await supabase
    .from({{ p_table | json_encode | safe }})
    .select({{ p_col | json_encode | safe }})
    .limit(1);
  const blocked =
    (!data || data.length === 0) ||
    (error && (error.code === '42501' ||
               error.message?.toLowerCase().includes('permission')));
  if (!logResult({{ p_name | json_encode | safe }},
    blocked,
    error ? `error: ${error.message}` : `rows: ${data?.length ?? 0}`)) failures++;
}
{%-   elif p_kind == "seed_present" %}

// Probe: {{ p_name }}
{
  const { data, error } = await supabase
    .from({{ p_table | json_encode | safe }})
    .select({{ p_col | json_encode | safe }})
    .order({{ p_col | json_encode | safe }});
  const ok = !error && Array.isArray(data) && data.length >= {{ p_min }};
  if (!logResult({{ p_name | json_encode | safe }},
    ok,
    error ? `error: ${error.message}` : `rows: ${data?.length} (${data?.map(r => r.{{ p_col }}).join(',')})`)) failures++;
}
{%-   endif %}
{%- endfor %}

if (failures > 0) {
  console.error(`\n\x1b[31m${failures} check(s) failed.\x1b[0m`);
  process.exit(1);
}
console.log('\n\x1b[32mAll checks passed.\x1b[0m');

{#-
  supabase-migration.tera — Public-vocab-driven Supabase migration SQL

  Generated by ggen from extract-public-materializations.rq under the Public
  Vocabulary Materialization Policy:

    Public ontology decides interoperability role.
    ZOE specializes the public role.
    This profile (ontology/profiles/zoela-supabase-materialization.ttl) decides
    which public roles get materialized as SQL.
    This template renders mechanically from extracted facts.

  Source-of-truth: ontology/zoela/*.ttl (church-service domain) +
                   ontology/profiles/zoela-supabase-materialization.ttl (profile)
  Extractor:       .specify/queries/zoela/extract-public-materializations.rq
  Doctrine:        memory/feedback_public_vocab_materialization.md

  ggen v5 rendering model: renders once per SELECT row.
  extract-public-materializations.rq returns ONE row with pipe-delimited
  aggregates, so this template renders exactly once and produces the complete
  migration file.

  SPARQL bindings consumed (all pipe-delimited):
    Class-level (DISTINCT per class):
      ?classIris             — full IRIs of materializable ZOE classes
      ?classNames            — rdfs:label
      ?tableNames            — skos:notation (will be normalized below)
      ?classDescriptions     — rdfs:comment
      ?publicAnchorIris      — public-vocab anchor IRI that triggered the kind
      ?materializationKinds  — IRI of the ggen materialization kind
      ?materializationCodes  — skos:notation of the kind (Agent/Action/Event/…)
      ?emitsSql              — "true" (filter already applied in SPARQL)
      ?requiresOwner         — "true"/"false" per kind
      ?requiresAuditTrail    — "true"/"false" per kind
      ?targetRuntimes        — "supabase" / "supabase-edge-fn"

    Per-property:
      ?propClasses           — owning class label (repeated per property)
      ?propColumns           — column name (skos:notation)
      ?propSqlTypes          — Postgres SQL type
      ?propRequired          — "true"/"false" (defaults "false" until SHACL)
      ?propDescriptions      — rdfs:comment
      ?propFkTables          — FK target table name or empty
-#}
-- =============================================================================
-- ZOE LA Supabase Migration — generated from public-vocabulary materialization
-- =============================================================================
-- DO NOT EDIT. This file is generated by ggen from:
--   ontology/zoela/*.ttl                                    (church-service domain)
--   ontology/profiles/zoela-supabase-materialization.ttl    (materialization profile)
-- Regenerate with: ggen sync --rule zoela-public-materialization
--
-- Doctrine: Public ontology decides interoperability role.
--           This profile decides which roles materialize as SQL.
--           ZOE specializes the public role.
--           Tera renders these facts mechanically.
-- =============================================================================

-- ----------------------------------------------------------------------------
-- Shared helper: updated_at trigger function (idempotent)
-- ----------------------------------------------------------------------------
CREATE OR REPLACE FUNCTION set_updated_at()
  RETURNS TRIGGER
  LANGUAGE plpgsql
AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;

{%- set class_iri_list   = classIris            | split(pat="|") %}
{%- set class_name_list  = classNames           | split(pat="|") %}
{%- set table_name_list  = tableNames           | split(pat="|") %}
{%- set class_desc_list  = classDescriptions    | split(pat="|") %}
{%- set anchor_list      = publicAnchorIris     | split(pat="|") %}
{%- set kind_list        = materializationKinds | split(pat="|") %}
{%- set kind_code_list   = materializationCodes | split(pat="|") %}
{%- set owner_list       = requiresOwner        | split(pat="|") %}
{%- set audit_list       = requiresAuditTrail   | split(pat="|") %}

{%- set prop_class_list  = propClasses          | split(pat="|") %}
{%- set prop_col_list    = propColumns          | split(pat="|") %}
{%- set prop_type_list   = propSqlTypes         | split(pat="|") %}
{%- set prop_req_list    = propRequired         | split(pat="|") %}
{%- set prop_desc_list   = propDescriptions     | split(pat="|") %}
{%- set prop_fk_list     = propFkTables         | split(pat="|") %}

{# For each class slot, render a CREATE TABLE block. -#}
{%- for class_name in class_name_list %}
{%-   set idx        = loop.index0 %}
{%-   set raw_table  = table_name_list[idx] | default(value="") | trim %}
{%-   set class_iri  = class_iri_list[idx]  | default(value="") | trim %}
{%-   set class_desc = class_desc_list[idx] | default(value="") | trim %}
{%-   set anchor     = anchor_list[idx]     | default(value="") | trim %}
{%-   set kind_iri   = kind_list[idx]       | default(value="") | trim %}
{%-   set kind_code  = kind_code_list[idx]  | default(value="ActionMaterialization") | trim %}

{# Normalize table name: lowercase, hyphens → underscores, drop ASCII-junk.
   Some legacy skos:notation values are PascalCase or hyphenated. -#}
{%-   set table      = raw_table | lower | replace(from="-", to="_") | trim %}

{%-   if class_name | trim != "" and table != "" %}

-- ----------------------------------------------------------------------------
-- {{ class_name | trim }} ({{ kind_code }})
--   Local class:  {{ class_iri }}
--   Public anchor: {{ anchor }}
--   Materialization kind: {{ kind_iri }}
{%-     if class_desc != "" %}
--   {{ class_desc }}
{%-     endif %}
-- ----------------------------------------------------------------------------

CREATE TABLE IF NOT EXISTS {{ table }} (
  id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
{%-     set requires_owner = owner_list[idx] | default(value="false") | trim == "true" %}
{%-     set requires_audit = audit_list[idx] | default(value="false") | trim == "true" %}
{%-     if requires_audit %}
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ,
{%-     endif %}
{%-     set seen_cols = [] %}
{%-     for prop_owner in prop_class_list %}
{%-       set pidx     = loop.index0 %}
{%-       set col_raw  = prop_col_list[pidx]  | default(value="") | trim %}
{%-       set col      = col_raw | lower | replace(from="-", to="_") %}
{%-       set ptype    = prop_type_list[pidx] | default(value="TEXT") | trim %}
{%-       set preq     = prop_req_list[pidx]  | default(value="false") | trim %}
{%-       set pdesc    = prop_desc_list[pidx] | default(value="") | trim %}
{%-       set pfk      = prop_fk_list[pidx]   | default(value="") | trim | lower | replace(from="-", to="_") %}
{%-       if prop_owner | trim == class_name | trim and col != "" and col not in seen_cols %}
{%-         set _ = seen_cols | concat(with=col) %}
{%-         if pdesc != "" %}
  -- {{ pdesc }}
{%-         endif %}
  {{ col }} {{ ptype }}{% if preq == "true" %} NOT NULL{% endif %}{% if pfk != "" %} REFERENCES {{ pfk }}(id){% endif %},
{%-       endif %}
{%-     endfor %}
{%-     if requires_owner %}
  created_by  UUID        REFERENCES auth.users(id)
{%-     else %}
  -- (no owner: this materialization kind does not require created_by)
  _placeholder TEXT
{%-     endif %}
);

-- Row Level Security: applied per materialization kind in P0-B.7 ODRL→RLS.
-- Until then, default to authenticated-read.
ALTER TABLE {{ table }} ENABLE ROW LEVEL SECURITY;

{%-     if requires_audit %}
CREATE TRIGGER set_{{ table }}_updated_at
  BEFORE UPDATE ON {{ table }}
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();
{%-     endif %}

CREATE POLICY "authenticated_read_{{ table }}"
  ON {{ table }} FOR SELECT TO authenticated USING (true);
{%-     if requires_owner %}

CREATE POLICY "authenticated_insert_{{ table }}"
  ON {{ table }} FOR INSERT TO authenticated WITH CHECK (auth.uid() = created_by);

CREATE POLICY "owner_update_{{ table }}"
  ON {{ table }} FOR UPDATE TO authenticated USING (auth.uid() = created_by);
{%-     endif %}
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of generated migration
-- =============================================================================

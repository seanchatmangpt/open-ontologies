{#-
  supabase-migration.tera — Public-vocab-driven Supabase migration SQL

  P0-B.4d-fix invariants enforced by extract-public-materializations.rq:

    - Every input row is ADMITTED by construction.
    - Exactly one row per local ZOE class.
    - No ambiguous kind assignment (priority resolves; ties refuse upstream).
    - No empty-body classes (refused upstream as `refused_no_body_columns`).
    - No duplicate normalized columns (refused upstream).
    - No template-side deduping. No "first admitted wins." No fallback columns.

  Doctrine:
    Tera renders facts. Tera does not repair facts. Tera does not choose
    authority. Tera does not hide ambiguity. Admission belongs upstream.

  Per the Public Vocabulary Materialization Policy: a SQL table appears here
  only when ALL four admission conditions hold —
    (1) class specializes a public anchor                 (TTL rdfs:subClassOf+)
    (2) SHACL shape declares required props               (public-role-shapes.ttl)
    (3) ODRL policy declares access if rlsRequired        (zoela-supabase-rls.ttl)
    (4) public/PROV/OCEL role requires persistence        (emitsSql=true on kind)
  Refused candidates appear in supabase-materialization-refusals.tera, never here.

  RLS policies are emitted by supabase-rls.tera (P0-B.7b). This template only
  enables RLS on each table (locking it by default) without any policies.

  Property bindings come packed in ?classColumnTuples with this layout:
    outer separator = "@@@"  (between classes)
    inner separator = ","    (between properties of a single class)
    field separator = "::"   (within a single tuple)
    tuple layout    = column_name::sql_type::required::fk_table::description
-#}
-- =============================================================================
-- ZOE LA Supabase Migration — generated from admissibility-gated extraction
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from:
--   ontology/zoela/*.ttl                                    (church-service domain)
--   ontology/profiles/zoela-supabase-materialization.ttl    (kinds + priorities)
--   ontology/profiles/public-role-shapes.ttl                (SHACL contracts)
--   ontology/profiles/zoela-supabase-rls.ttl                (ODRL → RLS mapping)
-- Regenerate with: ggen sync --rule zoela-public-materialization
--
-- Doctrine: a table appears here only when ALL four admission conditions hold —
-- public-anchor specialization, SHACL shape, ODRL policy (if rlsRequired), and
-- ggen:emitsSql=true on the materialization kind with no priority ambiguity.
-- Refusals are audited in supabase-materialization-refusals.tera, not here.
-- See: memory/feedback_public_vocab_materialization.md
-- =============================================================================

CREATE OR REPLACE FUNCTION set_updated_at()
  RETURNS TRIGGER
  LANGUAGE plpgsql
AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;

{%- set class_name_list   = classNames               | split(pat="|") %}
{%- set class_iri_list    = classIris                | split(pat="|") %}
{%- set table_name_list   = tableNames               | split(pat="|") %}
{%- set class_desc_list   = classDescriptions        | split(pat="|") %}
{%- set anchor_list       = publicAnchorIris         | split(pat="|") %}
{%- set kind_list         = materializationKinds     | split(pat="|") %}
{%- set kind_code_list    = materializationCodes     | split(pat="|") %}
{%- set owner_list        = requiresOwner            | split(pat="|") %}
{%- set audit_list        = requiresAuditTrail       | split(pat="|") %}
{%- set shape_list        = shapeIris                | split(pat="|") %}
{%- set tuples_list       = classColumnTuples        | split(pat="@@@") %}

{%- set admitted_count = 0 %}
{%- for c in class_name_list %}
{%-   if c | trim != "" %}{% set_global admitted_count = admitted_count + 1 %}{% endif %}
{%- endfor %}
-- ----------------------------------------------------------------------------
-- Admitted materializations: {{ admitted_count }}
-- (Every row below is admitted by construction. Refusals → supabase-materialization-refusals.sql)
-- ----------------------------------------------------------------------------

{%- for class_name in class_name_list %}
{%-   set idx          = loop.index0 %}
{%-   set cname        = class_name | trim %}
{%-   set raw_table    = table_name_list[idx]  | default(value="") | trim %}
{%-   set class_iri    = class_iri_list[idx]   | default(value="") | trim %}
{%-   set class_desc   = class_desc_list[idx]  | default(value="") | trim %}
{%-   set anchor       = anchor_list[idx]      | default(value="") | trim %}
{%-   set kind_iri     = kind_list[idx]        | default(value="") | trim %}
{%-   set kind_code    = kind_code_list[idx]   | default(value="") | trim %}
{%-   set shape_iri    = shape_list[idx]       | default(value="") | trim %}
{%-   set tuples_str   = tuples_list[idx]      | default(value="") | trim %}
{%-   set requires_owner = owner_list[idx] | default(value="false") | trim == "true" %}
{%-   set requires_audit = audit_list[idx] | default(value="false") | trim == "true" %}
{%-   set table        = raw_table | lower | replace(from="-", to="_") | trim %}

{%-   if table != "" %}

-- ----------------------------------------------------------------------------
-- {{ cname }} ({{ kind_code }})
--   Local class:          {{ class_iri }}
--   Public anchor:        {{ anchor }}
--   Materialization kind: {{ kind_iri }}
--   SHACL shape:          {{ shape_iri }}
{%-     if class_desc != "" %}
--   {{ class_desc }}
{%-     endif %}
-- ----------------------------------------------------------------------------

{#- Collect all column lines into a list so we can emit commas between them
    (and only between them — no trailing comma). Tera's `set` is loop-local,
    so we use `set_global` to thread accumulators through nested loops. -#}
{%-     set_global columns = ["id          UUID        PRIMARY KEY DEFAULT gen_random_uuid()"] %}
{%-     set_global column_comments = [""] %}

{%-     if requires_audit %}
{%-       set_global columns = columns | concat(with="created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()") %}
{%-       set_global columns = columns | concat(with="updated_at  TIMESTAMPTZ") %}
{%-       set_global column_comments = column_comments | concat(with="") %}
{%-       set_global column_comments = column_comments | concat(with="") %}
{%-     endif %}

{%-     if tuples_str != "" %}
{%-       set tuples = tuples_str | split(pat=",") %}
{%-       for tuple in tuples %}
{%-         set parts    = tuple | split(pat="::") %}
{%-         set col_raw  = parts[0] | default(value="") | trim %}
{%-         set ptype    = parts[1] | default(value="TEXT") | trim %}
{%-         set preq     = parts[2] | default(value="false") | trim %}
{%-         set pfk      = parts[3] | default(value="") | trim | lower | replace(from="-", to="_") %}
{%-         set pdesc    = parts[4] | default(value="") | trim %}
{%-         set col      = col_raw | lower | replace(from="-", to="_") %}
{%-         if col != "" %}
{%-           set notnull = "" %}
{%-           if preq == "true" %}{% set notnull = " NOT NULL" %}{% endif %}
{%-           set fk_ref = "" %}
{%-           if pfk != "" %}{% set fk_ref = " REFERENCES " ~ pfk ~ "(id)" %}{% endif %}
{%-           set col_line = col ~ " " ~ ptype ~ notnull ~ fk_ref %}
{%-           set_global columns = columns | concat(with=col_line) %}
{%-           set_global column_comments = column_comments | concat(with=pdesc) %}
{%-         endif %}
{%-       endfor %}
{%-     endif %}

{%-     if requires_owner %}
{%-       set_global columns = columns | concat(with="created_by  UUID NOT NULL REFERENCES auth.users(id)") %}
{%-       set_global column_comments = column_comments | concat(with="") %}
{%-     endif %}

CREATE TABLE IF NOT EXISTS {{ table }} (
{%-     for column in columns %}
{%-       set ccmt = column_comments[loop.index0] | default(value="") %}
{%-       if ccmt != "" %}
  -- {{ ccmt }}
{%-       endif %}
  {{ column }}{% if not loop.last %},{% endif %}
{%-     endfor %}
);

ALTER TABLE {{ table }} ENABLE ROW LEVEL SECURITY;

{%-     if requires_audit %}
DROP TRIGGER IF EXISTS set_{{ table }}_updated_at ON {{ table }};
CREATE TRIGGER set_{{ table }}_updated_at
  BEFORE UPDATE ON {{ table }}
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();
{%-     endif %}

-- (RLS policies for this table are emitted by supabase-rls.tera consuming
--  extract-odrl-policies.rq. Without a policy, the table is locked.)
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of generated migration. Every table above passed all admissibility gates.
-- Refused candidates appear in supabase-materialization-refusals.sql, not here.
-- =============================================================================

{#-
  supabase-migration.tera — Generated Supabase migration SQL for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --target zoela-mobile

  ggen v5 rendering model: renders once per SELECT row.
  migration_aggregated.rq returns ONE row with pipe-delimited aggregates,
  so this template renders exactly once and produces the complete migration file.

  SPARQL variables from migration_aggregated.rq (all pipe-delimited):
    ?classNames        — OWL class local names  (e.g. "PersonProfile|Household")
    ?tableNames        — Postgres table names    (e.g. "person_profiles|households")
    ?classIris         — full IRI for each class (for source comment)
    ?classDescriptions — rdfs:comment for each class

    Per-property variables (every prop from every class, in class order):
    ?propClasses       — which class each property belongs to
    ?propColumns       — skos:notation column name
    ?propSqlTypes      — mapped Postgres type (TEXT, UUID, TIMESTAMPTZ, INTEGER…)
    ?propRequired      — "true" or "false"
    ?propDescriptions  — rdfs:comment values
    ?propFkTables      — foreign-key target table if property is owl:ObjectProperty,
                         empty string otherwise
-#}
-- Generated from ontology/zoela/*.ttl — DO NOT EDIT
-- Regenerate with: ggen sync --target zoela-mobile
--
-- Architecture:
--   Tier 1 — ontology/zoela/*.ttl                (source of truth)
--   Tier 2 — ggen sync                           (manufacturing step)
--   Tier 3 — supabase/migrations/zoela_init.sql  (this file, applied by CLI)

{%- set class_name_list        = classNames        | split(pat="|") %}
{%- set table_name_list        = tableNames        | split(pat="|") %}
{%- set class_iri_list         = classIris         | split(pat="|") %}
{%- set class_description_list = classDescriptions | split(pat="|") %}
{%- set prop_class_list        = propClasses       | split(pat="|") %}
{%- set prop_column_list       = propColumns       | split(pat="|") %}
{%- set prop_sql_type_list     = propSqlTypes      | split(pat="|") %}
{%- set prop_required_list     = propRequired      | split(pat="|") %}
{%- set prop_description_list  = propDescriptions  | split(pat="|") %}
{%- set prop_fk_table_list     = propFkTables      | split(pat="|") %}

-- ============================================================================
-- Shared helper: updated_at trigger function (idempotent)
-- ============================================================================
CREATE OR REPLACE FUNCTION set_updated_at()
  RETURNS TRIGGER
  LANGUAGE plpgsql
AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;

{% for class_name in class_name_list %}
{%- set idx       = loop.index0 %}
{%- set table     = table_name_list[idx]        | default(value="") %}
{%- set iri       = class_iri_list[idx]         | default(value="") %}
{%- set class_desc = class_description_list[idx] | default(value="") %}
{%- if class_name | trim != "" and table | trim != "" %}

-- ============================================================================
-- Table: {{ table | trim }}
-- Source: {{ iri | trim }}
-- {{ class_desc | trim }}
-- ============================================================================

CREATE TABLE IF NOT EXISTS {{ table | trim }} (
  id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  created_at  TIMESTAMPTZ NOT NULL    DEFAULT NOW(),
  updated_at  TIMESTAMPTZ,
{%- for prop_name in prop_column_list %}
{%- set pidx     = loop.index0 %}
{%- set owner    = prop_class_list[pidx]      | default(value="") %}
{%- set col      = prop_column_list[pidx]     | default(value="") %}
{%- set sql_type = prop_sql_type_list[pidx]   | default(value="TEXT") %}
{%- set req      = prop_required_list[pidx]   | default(value="false") %}
{%- set pdesc    = prop_description_list[pidx] | default(value="") %}
{%- set fk_table = prop_fk_table_list[pidx]   | default(value="") %}
{%- if owner | trim == class_name | trim and col | trim != "" %}
  -- {{ pdesc | trim }}
  {{ col | trim | pad_start(width=20) }} {{ sql_type | trim }}{% if req | trim == "true" %} NOT NULL{% endif %}{% if fk_table | trim != "" %} REFERENCES {{ fk_table | trim }}(id){% endif %},
{%- endif %}
{%- endfor %}
  created_by  UUID        REFERENCES profiles(id)
);

-- Enable Row Level Security
ALTER TABLE {{ table | trim }} ENABLE ROW LEVEL SECURITY;

-- Audit trigger: keep updated_at current
CREATE TRIGGER set_{{ table | trim }}_updated_at
  BEFORE UPDATE ON {{ table | trim }}
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();

-- Default RLS policy: authenticated users see all rows (tighten per domain policy)
CREATE POLICY "authenticated_read_{{ table | trim }}"
  ON {{ table | trim }}
  FOR SELECT
  TO authenticated
  USING (true);

CREATE POLICY "authenticated_insert_{{ table | trim }}"
  ON {{ table | trim }}
  FOR INSERT
  TO authenticated
  WITH CHECK (auth.uid() = created_by);

CREATE POLICY "owner_update_{{ table | trim }}"
  ON {{ table | trim }}
  FOR UPDATE
  TO authenticated
  USING (auth.uid() = created_by);
{%- endif %}
{%- endfor %}

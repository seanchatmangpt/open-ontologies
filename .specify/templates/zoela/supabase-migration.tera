{#-
  supabase-migration.tera — Public-vocab-driven Supabase migration SQL

  Renders ONLY admitted materializations. The extractor
  (extract-public-materializations.rq) attaches a ?materializationStatus
  per class:
    admitted, refused_missing_shape, refused_no_columns,
    refused_missing_datatype, refused_duplicate_columns,
    refused_missing_policy.
  This template renders CREATE TABLE blocks only for status == "admitted".
  Every refused class is reported in the migration's leading audit comment.

  Per the Public Vocabulary Materialization Policy: a SQL table appears
  here only when ALL four admission conditions hold —
    (1) class specializes a public anchor                   (TTL rdfs:subClassOf+)
    (2) SHACL shape declares required props                 (public-role-shapes.ttl)
    (3) ODRL policy declares access                         (zoela-supabase-rls.ttl)
    (4) public/PROV/OCEL role requires persistence          (emitsSql=true on kind)

  RLS rules are NOT emitted here. They are rendered by supabase-rls.tera
  (P0-B.7b) which consumes extract-odrl-policies.rq. This template only
  enables RLS on the table (so it locks by default) without any policies.

  Multi-kind dedupe: when a class is anchored to multiple materialization
  kinds (e.g. prov:Entity AND schema:Action), the template emits ONE table
  per class, choosing the first admitted kind in extraction order.

  Property bindings come packed in ?classColumnTuples with this layout:
    outer separator = "@@@"  (between classes)
    inner separator = ","    (between properties of a single class)
    field separator = "::"   (within a single tuple)
    tuple layout    = column_name::sql_type::required::fk_table::description
-#}
-- =============================================================================
-- ZOE LA Supabase Migration — generated from admissibility-gated extraction
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from:
--   ontology/zoela/*.ttl                                    (church-service domain)
--   ontology/profiles/zoela-supabase-materialization.ttl    (kinds + emitsSql)
--   ontology/profiles/public-role-shapes.ttl                (SHACL contracts)
--   ontology/profiles/zoela-supabase-rls.ttl                (ODRL → RLS mapping)
-- Regenerate with: ggen sync --rule zoela-public-materialization
--
-- Doctrine: A table appears here only when ALL four admission conditions
-- hold: public-anchor specialization, SHACL shape, ODRL policy, and
-- ggen:emitsSql=true on the materialization kind. See:
--   memory/feedback_public_vocab_materialization.md
-- =============================================================================

CREATE OR REPLACE FUNCTION set_updated_at()
  RETURNS TRIGGER
  LANGUAGE plpgsql
AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;

{%- set class_name_list   = classNames               | split(pat="|") %}
{%- set class_iri_list    = classIris                | split(pat="|") %}
{%- set table_name_list   = tableNames               | split(pat="|") %}
{%- set class_desc_list   = classDescriptions        | split(pat="|") %}
{%- set anchor_list       = publicAnchorIris         | split(pat="|") %}
{%- set kind_list         = materializationKinds     | split(pat="|") %}
{%- set kind_code_list    = materializationCodes     | split(pat="|") %}
{%- set owner_list        = requiresOwner            | split(pat="|") %}
{%- set audit_list        = requiresAuditTrail       | split(pat="|") %}
{%- set shape_list        = shapeIris                | split(pat="|") %}
{%- set status_list       = materializationStatuses  | split(pat="|") %}
{%- set tuples_list       = classColumnTuples        | split(pat="@@@") %}

-- ----------------------------------------------------------------------------
-- Admissibility audit (P0-B.4d):
{%- set admitted_count   = 0 %}
{%- set refused_count    = 0 %}
{%- for status in status_list %}
{%-   if status | trim == "admitted" %}
{%-     set_global admitted_count = admitted_count + 1 %}
{%-   else %}
{%-     set_global refused_count = refused_count + 1 %}
{%-   endif %}
{%- endfor %}
-- Total materialization candidates: {{ status_list | length }}
-- Admitted (this file emits these):  {{ admitted_count }}
-- Refused  (audited but skipped):    {{ refused_count }}
--
-- Refused candidates:
{%- for class_name in class_name_list %}
{%-   set idx = loop.index0 %}
{%-   set st  = status_list[idx] | default(value="") | trim %}
{%-   set kc  = kind_code_list[idx] | default(value="") | trim %}
{%-   if st != "admitted" %}
--   {{ class_name | trim }}::{{ kc }} — {{ st }}
{%-   endif %}
{%- endfor %}
-- ----------------------------------------------------------------------------

{# Dedupe: emit one CREATE TABLE per unique (class_name) — first admitted wins -#}
{%- set seen_classes = [] %}
{%- for class_name in class_name_list %}
{%-   set idx = loop.index0 %}
{%-   set status = status_list[idx] | default(value="") | trim %}
{%-   set cname  = class_name | trim %}

{%-   if status == "admitted" and cname != "" and cname not in seen_classes %}
{%-     set _ = seen_classes | concat(with=cname) %}
{%-     set raw_table   = table_name_list[idx] | default(value="") | trim %}
{%-     set class_iri   = class_iri_list[idx]  | default(value="") | trim %}
{%-     set class_desc  = class_desc_list[idx] | default(value="") | trim %}
{%-     set anchor      = anchor_list[idx]     | default(value="") | trim %}
{%-     set kind_iri    = kind_list[idx]       | default(value="") | trim %}
{%-     set kind_code   = kind_code_list[idx]  | default(value="") | trim %}
{%-     set shape_iri   = shape_list[idx]      | default(value="") | trim %}
{%-     set tuples_str  = tuples_list[idx]     | default(value="") | trim %}
{%-     set requires_owner = owner_list[idx] | default(value="false") | trim == "true" %}
{%-     set requires_audit = audit_list[idx] | default(value="false") | trim == "true" %}
{%-     set table       = raw_table | lower | replace(from="-", to="_") | trim %}

{%-     if table != "" and tuples_str != "" %}

-- ----------------------------------------------------------------------------
-- {{ cname }} ({{ kind_code }})
--   Local class:          {{ class_iri }}
--   Public anchor:        {{ anchor }}
--   Materialization kind: {{ kind_iri }}
--   SHACL shape:          {{ shape_iri }}
{%-       if class_desc != "" %}
--   {{ class_desc }}
{%-       endif %}
-- ----------------------------------------------------------------------------

CREATE TABLE IF NOT EXISTS {{ table }} (
  id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
{%-       if requires_audit %}
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ,
{%-       endif %}
{%-       set tuples = tuples_str | split(pat=",") %}
{%-       for tuple in tuples %}
{%-         set parts    = tuple | split(pat="::") %}
{%-         set col_raw  = parts[0] | default(value="") | trim %}
{%-         set ptype    = parts[1] | default(value="TEXT") | trim %}
{%-         set preq     = parts[2] | default(value="false") | trim %}
{%-         set pfk      = parts[3] | default(value="") | trim | lower | replace(from="-", to="_") %}
{%-         set pdesc    = parts[4] | default(value="") | trim %}
{%-         set col      = col_raw | lower | replace(from="-", to="_") %}
{%-         if col != "" %}
{%-           if pdesc != "" %}
  -- {{ pdesc }}
{%-           endif %}
  {{ col }} {{ ptype }}{% if preq == "true" %} NOT NULL{% endif %}{% if pfk != "" %} REFERENCES {{ pfk }}(id){% endif %},
{%-         endif %}
{%-       endfor %}
{%-       if requires_owner %}
  created_by  UUID NOT NULL REFERENCES auth.users(id)
{%-       else %}
  -- (no owner: this materialization kind has requiresOwner=false)
  _admission_marker  TEXT
{%-       endif %}
);

ALTER TABLE {{ table }} ENABLE ROW LEVEL SECURITY;

{%-       if requires_audit %}
CREATE TRIGGER set_{{ table }}_updated_at
  BEFORE UPDATE ON {{ table }}
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();
{%-       endif %}

-- (RLS policies for this table are emitted by supabase-rls.tera consuming
--  extract-odrl-policies.rq. Without a policy, the table is locked.)
{%-     endif %}
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of generated migration. Refused candidates appear in the leading audit
-- comment block. To admit a refused class:
--   refused_missing_shape       → add a SHACL NodeShape targeting its anchor
--   refused_no_columns          → add owl:DatatypeProperty / owl:ObjectProperty
--                                 with rdfs:domain and skos:notation
--   refused_missing_datatype    → add rdfs:range to every property
--   refused_duplicate_columns   → ensure all skos:notation values within the
--                                 class normalize uniquely (no case/hyphen clash)
--   refused_missing_policy      → add an ODRL permission in policy.ttl whose
--                                 action has ggen:rlsTargetKind pointing here
-- =============================================================================

{#-
  route-stage-gate.tera — Generated route stage gate functions for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-service-routes

  ggen v5 rendering model: renders once per SELECT row.
  extract-service-routes.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited):
    ?stageCodes         — skos:notation per stage
    ?stageLabels        — rdfs:label per stage
    ?stageRouteCodes    — route code each stage belongs to
    ?stageOrders        — integer order per stage (0 if absent)
    ?stageIsEntries     — "true"/"false" per stage
    ?stageIsTerminals   — "true"/"false" per stage
    ?stagePredCodes     — predecessor stage code (empty string if absent)
    ?stageRoleCodes     — required role code (empty string if absent)
    ?stageConsentCodes  — required consent code (empty string if absent)
    ?stageReceiptTypes  — completion receipt type (empty string if absent)
    ?stageOcelTypes     — OCEL event type (empty string if absent)
    ?stageTimeouts      — timeout hours (empty string if absent)
-#}
// Generated from ontology/zoela/*.ttl — DO NOT EDIT
// Regenerate with: ggen sync --rule zoela-service-routes
//
// Route stage gate functions for ZOE LA Mobile
// Source: ontology/zoela/routes.ttl → extract-service-routes.rq → route-stage-gate.tera

{%- set stage_code_list         = stageCodes        | split(pat="|") %}
{%- set stage_label_list        = stageLabels       | split(pat="|") %}
{%- set stage_route_code_list   = stageRouteCodes   | split(pat="|") %}
{%- set stage_order_list        = stageOrders       | split(pat="|") %}
{%- set stage_is_entry_list     = stageIsEntries    | split(pat="|") %}
{%- set stage_is_terminal_list  = stageIsTerminals  | split(pat="|") %}
{%- set stage_pred_code_list    = stagePredCodes    | split(pat="|") %}
{%- set stage_role_code_list    = stageRoleCodes    | split(pat="|") %}
{%- set stage_consent_code_list = stageConsentCodes | split(pat="|") %}
{%- set stage_receipt_type_list = stageReceiptTypes | split(pat="|") %}
{%- set stage_ocel_type_list    = stageOcelTypes    | split(pat="|") %}
{%- set stage_timeout_list      = stageTimeouts     | split(pat="|") %}

export interface RouteStageGate {
  routeCode: string;
  stageCode: string;
  stageLabel: string;
  stageOrder: number;
  isEntry: boolean;
  isTerminal: boolean;
  predecessorCode?: string;
  requiredRoleCode?: string;
  requiredConsentCode?: string;
  completionReceiptType?: string;
  ocelEventType?: string;
  timeoutHours?: number;
}

export const ROUTE_STAGE_GATES: RouteStageGate[] = [
{% for stage_code in stage_code_list %}
{%- set sidx          = loop.index0 %}
{%- set slabel        = stage_label_list[sidx]        | default(value="") | trim %}
{%- set sroutecode    = stage_route_code_list[sidx]   | default(value="") | trim %}
{%- set sorder        = stage_order_list[sidx]        | default(value="0") | trim %}
{%- set sis_entry     = stage_is_entry_list[sidx]     | default(value="false") | trim %}
{%- set sis_terminal  = stage_is_terminal_list[sidx]  | default(value="false") | trim %}
{%- set spred         = stage_pred_code_list[sidx]    | default(value="") | trim %}
{%- set srole         = stage_role_code_list[sidx]    | default(value="") | trim %}
{%- set sconsent      = stage_consent_code_list[sidx] | default(value="") | trim %}
{%- set sreceipt      = stage_receipt_type_list[sidx] | default(value="") | trim %}
{%- set socel         = stage_ocel_type_list[sidx]    | default(value="") | trim %}
{%- set stimeout      = stage_timeout_list[sidx]      | default(value="") | trim %}
{%- if stage_code | trim != "" %}
  {
    routeCode: '{{ sroutecode }}',
    stageCode: '{{ stage_code | trim }}',
    stageLabel: '{{ slabel }}',
    stageOrder: {{ sorder }},
    isEntry: {{ sis_entry }},
    isTerminal: {{ sis_terminal }},
    {% if spred != "" %}predecessorCode: '{{ spred }}',{% endif %}
    {% if srole != "" %}requiredRoleCode: '{{ srole }}',{% endif %}
    {% if sconsent != "" %}requiredConsentCode: '{{ sconsent }}',{% endif %}
    {% if sreceipt != "" %}completionReceiptType: '{{ sreceipt }}',{% endif %}
    {% if socel != "" %}ocelEventType: '{{ socel }}',{% endif %}
    {% if stimeout != "" %}timeoutHours: {{ stimeout }},{% endif %}
  },
{%- endif %}
{% endfor %}
];

export function getStageGate(routeCode: string, stageCode: string): RouteStageGate | undefined {
  return ROUTE_STAGE_GATES.find(g => g.routeCode === routeCode && g.stageCode === stageCode);
}

export function getEntryStage(routeCode: string): RouteStageGate | undefined {
  return ROUTE_STAGE_GATES.find(g => g.routeCode === routeCode && g.isEntry);
}

export function getNextStages(routeCode: string, currentStageCode: string): RouteStageGate[] {
  return ROUTE_STAGE_GATES.filter(
    g => g.routeCode === routeCode && g.predecessorCode === currentStageCode
  );
}

export function isGateBlocked(gate: RouteStageGate, context: {
  actorRoleCode?: string;
  grantedConsentCodes?: string[];
}): { blocked: boolean; reason?: string } {
  if (gate.requiredRoleCode && context.actorRoleCode !== gate.requiredRoleCode) {
    return { blocked: true, reason: `Requires role: ${gate.requiredRoleCode}` };
  }
  if (gate.requiredConsentCode && !context.grantedConsentCodes?.includes(gate.requiredConsentCode)) {
    return { blocked: true, reason: `Missing consent: ${gate.requiredConsentCode}` };
  }
  return { blocked: false };
}

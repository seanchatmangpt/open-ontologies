{#-
  supabase-columns.tera — ALTER TABLE ADD COLUMN per body property

  P0-B.4e: appends body columns to the bare tables emitted by
  supabase-migration.tera. Each input row from
  extract-public-materialization-columns.rq becomes exactly one
  `ALTER TABLE ... ADD COLUMN IF NOT EXISTS ...` statement.

  Doctrine:
    - The extractor emits one (table, column, type, fk?, description) row
      per body property. The template just formats. No template-side dedupe
      or admission logic.
    - Tables emitted by supabase-migration.tera have id + audit + owner.
      This template adds the body columns afterward.
    - `IF NOT EXISTS` lets the migration replay safely after a partial
      apply, but the receipt + ggen sync incremental cache should make
      replays rare.
-#}
-- =============================================================================
-- ZOE LA Supabase Body Columns — generated from admissibility-gated extraction
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from:
--   .specify/queries/zoela/extract-public-materialization-columns.rq
--
-- Doctrine: one ALTER TABLE ADD COLUMN per admitted (class, property) tuple.
-- Tables themselves come from zoela-tables.sql; this file adds body columns.
-- Run AFTER zoela-tables.sql.
-- =============================================================================

{%- set col_table_list   = colTables       | split(pat="|") %}
{%- set col_name_list    = colNames        | split(pat="|") %}
{%- set col_type_list    = colSqlTypes     | split(pat="|") %}
{%- set col_fk_list      = colFkTables     | split(pat="|") %}
{%- set col_desc_list    = colDescriptions | split(pat="|") %}
{%- set col_class_list   = colClassIris    | split(pat="|") %}

{%- set col_row_count = 0 %}
{%- for n in col_name_list %}
{%-   if n | trim != "" %}{% set_global col_row_count = col_row_count + 1 %}{% endif %}
{%- endfor %}

-- ----------------------------------------------------------------------------
-- Body column rows: {{ col_row_count }}
-- ----------------------------------------------------------------------------

{%- for raw_name in col_name_list %}
{%-   set idx       = loop.index0 %}
{%-   set raw_tbl   = col_table_list[idx] | default(value="") | trim %}
{%-   set raw_col   = raw_name            | default(value="") | trim %}
{%-   set raw_type  = col_type_list[idx]  | default(value="TEXT") | trim %}
{%-   set raw_fk    = col_fk_list[idx]    | default(value="") | trim %}
{%-   set raw_desc  = col_desc_list[idx]  | default(value="") | trim %}
{%-   set raw_class = col_class_list[idx] | default(value="") | trim %}
{%-   set table     = raw_tbl | lower | replace(from="-", to="_") %}
{%-   set column    = raw_col | lower | replace(from="-", to="_") %}
{%-   set fk_table  = raw_fk  | lower | replace(from="-", to="_") %}

{%-   if table != "" and column != "" %}
{%-     set fk_clause = "" %}
{%-     if fk_table != "" %}{% set fk_clause = " REFERENCES " ~ fk_table ~ "(id)" %}{% endif %}

{%-     if raw_desc != "" %}
-- {{ raw_desc }} (from {{ raw_class }})
{%-     else %}
-- (from {{ raw_class }})
{%-     endif %}
ALTER TABLE {{ table }} ADD COLUMN IF NOT EXISTS {{ column }} {{ raw_type }}{{ fk_clause }};
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of body column additions.
-- =============================================================================

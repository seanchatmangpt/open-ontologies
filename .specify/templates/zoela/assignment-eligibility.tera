{#-
  assignment-eligibility.tera — Generated volunteer assignment eligibility rules

  Generated by ggen from ontology/zoela/routes.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-assignment-eligibility

  ggen v5 rendering model: renders once per SELECT row.
  extract-assignment-eligibility.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited, skills/roles semicolon-delimited within):
    ?route_labels        — display name per route
    ?min_hours_list      — minimum volunteer hours per route
    ?requires_bgc_list   — "true"/"false" per route
    ?req_skill_labels    — semicolon-delimited required skills per route
    ?eligible_role_codes — semicolon-delimited eligible role codes per route
-#}
// Generated from ontology/zoela/routes.ttl — DO NOT EDIT
// Regenerate with: ggen sync --rule zoela-assignment-eligibility
//
// Volunteer assignment eligibility rules for ZOE LA Mobile
// Source: ontology/zoela/routes.ttl → extract-assignment-eligibility.rq → assignment-eligibility.tera

{%- set route_name_list = route_labels       | split(pat="|") %}
{%- set min_hours_arr   = min_hours_list      | split(pat="|") %}
{%- set bgc_arr         = requires_bgc_list   | split(pat="|") %}
{%- set skills_arr      = req_skill_labels    | split(pat="|") %}
{%- set roles_arr       = eligible_role_codes | split(pat="|") %}

export interface AssignmentRule {
  routeName: string;
  minimumHours: number;
  requiresBackgroundCheck: boolean;
  requiredSkills: string[];
  eligibleRoles: string[];
}

export const ASSIGNMENT_RULES: AssignmentRule[] = [
{% for route_name in route_name_list %}
{%- set i       = loop.index0 %}
{%- set min_h   = min_hours_arr[i] | default(value="0")     | trim %}
{%- set req_bgc = bgc_arr[i]       | default(value="false") | trim %}
{%- set skills  = skills_arr[i]    | default(value="")      | trim %}
{%- set roles   = roles_arr[i]     | default(value="")      | trim %}
{%- if route_name | trim != "" %}
  {
    routeName: "{{ route_name | trim }}",
    minimumHours: {{ min_h }},
    requiresBackgroundCheck: {{ req_bgc }},
    requiredSkills: [{% if skills != "" %}"{{ skills | replace(from=";", to='", "') }}"{% endif %}],
    eligibleRoles: [{% if roles != "" %}"{{ roles | replace(from=";", to='", "') }}"{% endif %}],
  },
{%- endif %}
{% endfor %}
];

export function isEligible(roleCode: string, routeName: string): boolean {
  const rule = ASSIGNMENT_RULES.find(r => r.routeName === routeName);
  if (!rule) return false;
  return rule.eligibleRoles.includes(roleCode);
}

export function getRouteRule(routeName: string): AssignmentRule | undefined {
  return ASSIGNMENT_RULES.find(r => r.routeName === routeName);
}

{% if row.is_admin_only == "true" %}// ADMIN ONLY{% endif %}
export function {{ row.nav_route | default(value=row.screen_id) }}Screen() {
  const navigation = useNavigation();
  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>{{ row.screen_label }}</Text>
      {/* Object type: {{ row.primary_object_type }} */}
      {/* Generated from ontology/zoela/navigation.ttl */}
    </ScrollView>
  );
}

{% endfor %}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#fff' },

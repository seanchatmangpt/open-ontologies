{#-
  expo-screen.tera — screen registry bundle

  ggen v5 per-rule rendering model: this template runs ONCE for the rule
  and writes ONCE to `output_file`. The query (extract-screens.rq) is
  shaped to return ONE aggregated row with every screen packed into
  pipe-delimited bindings. We split and loop here, emitting every screen
  as a separate export in one file.

  Doctrine: this template renders facts. No template-side dedupe / role
  filtering / admission. The query is the only place where rows can be
  excluded or sorted.

  Consumed pipe-delimited bindings (each one screen per "|"):
    screenIds, screenLabels, navRoutes, parentTabCodes, screenStacks,
    requiredRoles, primaryObjectTypes, primaryRouteCategories,
    isAdminOnlys, screenOrders
-#}
// ============================================================
// DO NOT EDIT THIS FILE
//
// This file is auto-generated by ggen from:
//   ontology/zoela/navigation.ttl + extract-screens.rq
//
// Regenerate with: ggen sync --rule zoela-screens
// Every export below corresponds to one zoe:AppScreen instance.
// ============================================================

import React from 'react';
import { ScrollView, Text, StyleSheet } from 'react-native';

{%- set id_list       = screenIds              | split(pat="|") %}
{%- set label_list    = screenLabels           | split(pat="|") %}
{%- set route_list    = navRoutes              | split(pat="|") %}
{%- set tab_list      = parentTabCodes         | split(pat="|") %}
{%- set stack_list    = screenStacks           | split(pat="|") %}
{%- set role_list     = requiredRoles          | split(pat="|") %}
{%- set obj_list      = primaryObjectTypes     | split(pat="|") %}
{%- set cat_list      = primaryRouteCategories | split(pat="|") %}
{%- set admin_list    = isAdminOnlys           | split(pat="|") %}
{%- set order_list    = screenOrders           | split(pat="|") %}

{%- set screen_count = 0 %}
{%- for s in id_list %}
{%-   if s | trim != "" %}{% set_global screen_count = screen_count + 1 %}{% endif %}
{%- endfor %}

// Screen exports: {{ screen_count }}

{%- for raw_id in id_list %}
{%-   set idx       = loop.index0 %}
{%-   set sid       = raw_id                          | default(value="") | trim %}
{%-   set slabel    = label_list[idx]                 | default(value="") | trim %}
{%-   set sroute    = route_list[idx]                 | default(value="") | trim %}
{%-   set stab      = tab_list[idx]                   | default(value="HOME") | trim %}
{%-   set sstack    = stack_list[idx]                 | default(value="MainStack") | trim %}
{%-   set srole     = role_list[idx]                  | default(value="MEMBER") | trim %}
{%-   set sobj      = obj_list[idx]                   | default(value="") | trim %}
{%-   set scat      = cat_list[idx]                   | default(value="") | trim %}
{%-   set sadmin    = admin_list[idx]                 | default(value="false") | trim %}

{%-   if sid != "" %}
{#- Component name: prefer the explicit navRoute, fall back to screen id. -#}
{%-     if sroute != "" %}{% set comp_base = sroute %}{% else %}{% set comp_base = sid %}{% endif %}
{%-     set comp_name = comp_base ~ "Screen" %}

// ----------------------------------------------------------------
// {{ slabel }}
//   id:       {{ sid }}
//   nav:      {{ sroute }}
//   tab:      {{ stab }}  stack: {{ sstack }}
//   role:     {{ srole }}{% if sadmin == "true" %}  ADMIN-ONLY{% endif %}
{%-     if sobj != "" %}
//   object:   {{ sobj }}
{%-     endif %}
{%-     if scat != "" %}
//   category: {{ scat }}
{%-     endif %}
// ----------------------------------------------------------------
export function {{ comp_name }}() {
  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>{{ slabel }}</Text>
      <Text style={styles.subtitle}>{{ stab }} · {{ srole }}{% if sadmin == "true" %} · admin{% endif %}</Text>
    </ScrollView>
  );
}
{%-   endif %}
{%- endfor %}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#fff' },
  title:     { fontSize: 24, fontWeight: 'bold', padding: 16 },
  subtitle:  { fontSize: 12, color: '#666', paddingHorizontal: 16, paddingBottom: 8 },
});

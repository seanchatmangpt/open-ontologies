{#-
  expo-navigation-stack.tera — one Navigator per tab, all in one file.

  Renders once per rule and writes once. extract-navigation.rq packs every
  tab and its screens into ONE aggregated row; this template splits and
  loops.

  Doctrine: no template-side filtering. The query controls which tabs and
  which screens appear; this just renders.

  Bindings (pipe-delimited, "@@@" between tabs, "||" between screens, "|"
  between screen fields):
    tabCodes          — "HOME|GROUPS|..."
    tabLabels         — "Home|Connect Groups|..."
    tabScreensBundle  — "<tab1-screens>@@@<tab2-screens>@@@..."
                        where each tab's screens are "||"-separated, and
                        each screen entry is "id|navRoute|stack|order|isAdmin"
-#}
// Generated by CodeManufactory — do not edit
// Source: ontology/zoela/navigation.ttl + extract-navigation.rq
// Regenerate: ggen sync --rule zoela-navigation

import { createNativeStackNavigator } from '@react-navigation/native-stack';
import React from 'react';

export type RootStackParamList = Record<string, { routeId?: string } | undefined>;

{%- set tab_code_list  = tabCodes         | split(pat="|") %}
{%- set tab_label_list = tabLabels        | split(pat="|") %}
{%- set tab_screens_list = tabScreensBundle | split(pat="@@@") %}

{%- set tab_count = 0 %}
{%- for c in tab_code_list %}
{%-   if c | trim != "" %}{% set_global tab_count = tab_count + 1 %}{% endif %}
{%- endfor %}

// Tab navigators: {{ tab_count }}

{%- for raw_code in tab_code_list %}
{%-   set idx       = loop.index0 %}
{%-   set tab_code  = raw_code                 | default(value="") | trim %}
{%-   set tab_label = tab_label_list[idx]      | default(value="") | trim %}
{%-   set tab_bundle = tab_screens_list[idx]   | default(value="") %}
{%-   set tab_key   = tab_code | replace(from="-", to="") | replace(from=" ", to="") %}

{%-   if tab_code != "" %}

// ----------------------------------------------------------------
// Tab: {{ tab_label }} ({{ tab_code }})
// ----------------------------------------------------------------
const {{ tab_key }}Stack = createNativeStackNavigator<RootStackParamList>();

export function {{ tab_key }}Navigator() {
  return (
    <{{ tab_key }}Stack.Navigator>
{%-     if tab_bundle | trim != "" %}
{%-       set screen_entries = tab_bundle | split(pat="||") %}
{%-       for entry in screen_entries %}
{%-         set fields    = entry | split(pat="|") %}
{%-         set screen_id = fields[0] | default(value="") | trim %}
{%-         set nav_route = fields[1] | default(value="") | trim %}
{%-         set is_admin  = fields[4] | default(value="false") | trim %}
{%-         if nav_route != "" %}
      {/* {% if is_admin == "true" %}ADMIN ONLY · {% endif %}{{ screen_id }} */}
      <{{ tab_key }}Stack.Screen name="{{ nav_route }}" getComponent={() => require('./screens/{{ nav_route }}').default} />
{%-         elif screen_id != "" %}
      {/* {% if is_admin == "true" %}ADMIN ONLY · {% endif %}{{ screen_id }} */}
      <{{ tab_key }}Stack.Screen name="{{ screen_id }}" getComponent={() => require('./screens/{{ screen_id }}').default} />
{%-         endif %}
{%-       endfor %}
{%-     endif %}
    </{{ tab_key }}Stack.Navigator>
  );
}
{%-   endif %}
{%- endfor %}

{#-
  expo-navigation-stack.tera — Expo React Navigation stack navigator
  Generated by CodeManufactory from ontology/zoela/navigation.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-navigation

  ggen v5 per-row rendering model: renders once per SELECT row.
  extract-navigation.rq returns one row per tab (GROUP BY tab_code).

  SPARQL variables available directly:
    tab_code   — skos:notation for the tab (e.g. "HOME", "ROUTES")
    tab_label  — rdfs:label for the tab
    screens    — "||"-delimited screen entries (may be absent if tab has no screens)
                 each entry: screen_id|nav_route|stack|order|is_admin
-#}
// Generated by CodeManufactory — do not edit
// Source: ontology/zoela/navigation.ttl + extract-navigation.rq
// Regenerate: ggen sync --rule zoela-navigation
// Tab: {{ tab_label }} ({{ tab_code }})

import { createNativeStackNavigator } from '@react-navigation/native-stack';
import React from 'react';

export type RootStackParamList = Record<string, { routeId?: string } | undefined>;

{%- set tab_key = tab_code | replace(from="-", to="") | replace(from=" ", to="") %}
{%- set screen_list = screens | default(value="") %}
{%- set screen_entries = screen_list | split(pat="||") %}

const {{ tab_key }}Stack = createNativeStackNavigator<RootStackParamList>();

export function {{ tab_key }}Navigator() {
  return (
    <{{ tab_key }}Stack.Navigator>
{%- for entry in screen_entries %}
{%- set fields = entry | split(pat="|") %}
{%- set screen_id = fields[0] | default(value="") | trim %}
{%- set nav_route = fields[1] | default(value="") | trim %}
{%- set is_admin  = fields[4] | default(value="false") | trim %}
{%- if nav_route %}
      {/* {% if is_admin == "true" %}ADMIN ONLY — {% endif %}screen_id: {{ screen_id }} */}
      <{{ tab_key }}Stack.Screen name="{{ nav_route }}" getComponent={() => require('./screens/{{ nav_route }}').default} />
{%- elif screen_id %}
      <{{ tab_key }}Stack.Screen name="{{ screen_id }}" getComponent={() => require('./screens/{{ screen_id }}').default} />
{%- endif %}
{%- endfor %}
    </{{ tab_key }}Stack.Navigator>
  );
}

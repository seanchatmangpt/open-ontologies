{#-
  supabase-legacy-coverage.tera — emits CREATE TABLE / ALTER / CREATE POLICY
  for every legacy spec declared in zoela-legacy-coverage.ttl.

  Renders once. Three loops:
    1. Tables   — bundle entries: "table###col|col|...###idx|idx|..."
    2. Alters   — bundle entries: "table###col|col|..."
    3. Policies — bundle entries: "name|table|op|using|check"
-#}
-- =============================================================================
-- ZOE LA Supabase Legacy-Coverage — generated from declarative profile
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from:
--   ontology/profiles/zoela-legacy-coverage.ttl
-- Regenerate with: ggen sync --rule zoela-legacy-coverage
--
-- Holds every table + RLS not yet reachable from the public-vocab admission
-- chain (campuses, consent_records, group_interests, group_memberships,
-- group_invites, ocel_events) plus extra columns for partially-admitted
-- tables (persons, connect_groups).
-- =============================================================================

-- ----------------------------------------------------------------------------
-- § 1  Tables
-- ----------------------------------------------------------------------------

{%- set table_entries = tableBundle | split(pat="@@@") %}
{%- for entry in table_entries %}
{%-   set parts = entry | split(pat="###") %}
{%-   set tname = parts[0] | default(value="") | trim %}
{%-   set tcols_bundle = parts[1] | default(value="") %}
{%-   set tidxs_bundle = parts[2] | default(value="") %}
{%-   if tname != "" %}

CREATE TABLE IF NOT EXISTS {{ tname }} (
  id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ
{%-     if tcols_bundle | trim != "" %}
{%-       set tcols = tcols_bundle | split(pat="|||") %}
{%-       for c in tcols %}
{%-         set c_trim = c | trim %}
{%-         if c_trim != "" %},
  {{ c_trim }}
{%-         endif %}
{%-       endfor %}
{%-     endif %}
);

ALTER TABLE {{ tname }} ENABLE ROW LEVEL SECURITY;
DROP TRIGGER IF EXISTS set_{{ tname }}_updated_at ON {{ tname }};
CREATE TRIGGER set_{{ tname }}_updated_at
  BEFORE UPDATE ON {{ tname }}
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();

{%-     if tidxs_bundle | trim != "" %}
{%-       set tidxs = tidxs_bundle | split(pat="|||") %}
{%-       for i in tidxs %}
{%-         set i_trim = i | trim %}
{%-         if i_trim != "" %}
{{ i_trim }};
{%-         endif %}
{%-       endfor %}
{%-     endif %}
{%-   endif %}
{%- endfor %}

-- ----------------------------------------------------------------------------
-- § 2  Alters (extra columns on partially-admitted tables)
-- ----------------------------------------------------------------------------

{%- set alter_entries = alterBundle | split(pat="@@@") %}
{%- for entry in alter_entries %}
{%-   set parts = entry | split(pat="###") %}
{%-   set atable = parts[0] | default(value="") | trim %}
{%-   set acols_bundle = parts[1] | default(value="") %}
{%-   if atable != "" and acols_bundle | trim != "" %}

-- ALTER {{ atable }}
{%-     set acols = acols_bundle | split(pat="|||") %}
{%-     for c in acols %}
{%-       set c_trim = c | trim %}
{%-       if c_trim != "" %}
ALTER TABLE {{ atable }} ADD COLUMN IF NOT EXISTS {{ c_trim }};
{%-       endif %}
{%-     endfor %}
{%-   endif %}
{%- endfor %}

-- ----------------------------------------------------------------------------
-- § 3  Policies (legacy RLS not yet driven by the ODRL chain)
-- ----------------------------------------------------------------------------

{%- set policy_entries = policyBundle | split(pat="@@@") %}
{%- for entry in policy_entries %}
{%-   set parts = entry | split(pat="|") %}
{%-   set pname  = parts[0] | default(value="") | trim %}
{%-   set ptable = parts[1] | default(value="") | trim %}
{%-   set pop    = parts[2] | default(value="SELECT") | trim | upper %}
{%-   set pusing = parts[3] | default(value="") | trim %}
{%-   set pcheck = parts[4] | default(value="") | trim %}
{%-   set needs_using = pop == "SELECT" or pop == "DELETE" or pop == "UPDATE" or pop == "ALL" %}
{%-   set needs_check = pop == "INSERT" or pop == "UPDATE" or pop == "ALL" %}
{%-   if pname != "" and ptable != "" %}

DROP POLICY IF EXISTS "{{ pname }}__{{ pop | lower }}__{{ ptable }}" ON {{ ptable }};
CREATE POLICY "{{ pname }}__{{ pop | lower }}__{{ ptable }}"
  ON {{ ptable }}
  FOR {{ pop }}
  TO authenticated
{%-     if needs_using and pusing != "" %}
  USING ({{ pusing }})
{%-     elif needs_using %}
  USING (true)
{%-     endif %}
{%-     if needs_check and pcheck != "" %}
  WITH CHECK ({{ pcheck }})
{%-     elif needs_check %}
  WITH CHECK (true)
{%-     endif %}
  ;
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of legacy coverage.
-- =============================================================================

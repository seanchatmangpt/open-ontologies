{#-
  supabase-bridge-table.tera — Generated bridge table SQL for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-bridge-tables

  ggen v5 rendering model: renders once per SELECT row.
  extract-bridge-tables.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited):
    ?tableNames    — snake_case table names
    ?tableLabels   — rdfs:label per bridge table
    ?tableComments — rdfs:comment per bridge table
    ?propTables    — table name repeated per column
    ?colNames      — column skos:notation values
    ?colTypes      — short type name per column
    ?colNullable   — "true"/"false" per column
-#}
-- Generated from ontology/zoela/*.ttl — DO NOT EDIT
-- Regenerate with: ggen sync --rule zoela-bridge-tables

{%- set table_name_list    = tableNames    | split(pat="|") %}
{%- set table_label_list   = tableLabels   | split(pat="|") %}
{%- set table_comment_list = tableComments | split(pat="|") %}
{%- set prop_table_list    = propTables    | split(pat="|") %}
{%- set col_name_list      = colNames      | split(pat="|") %}
{%- set col_type_list      = colTypes      | split(pat="|") %}
{%- set col_nullable_list  = colNullable   | split(pat="|") %}

{% for table_name in table_name_list %}
{%- set tidx    = loop.index0 %}
{%- set tlabel  = table_label_list[tidx]   | default(value="") %}
{%- set tcomment = table_comment_list[tidx] | default(value="") %}
{%- if table_name | trim != "" %}

-- ============================================================================
-- Bridge table: {{ tlabel | trim }}
-- {{ tcomment | trim }}
-- ============================================================================
CREATE TABLE IF NOT EXISTS {{ table_name | trim }} (
  id         UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  created_at TIMESTAMPTZ NOT NULL    DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL    DEFAULT NOW(),
{%- for col_name in col_name_list %}
{%- set cidx     = loop.index0 %}
{%- set owner    = prop_table_list[cidx] | default(value="") %}
{%- set ctype    = col_type_list[cidx]   | default(value="string") %}
{%- set nullable = col_nullable_list[cidx] | default(value="true") %}
{%- if owner | trim == table_name | trim and col_name | trim != "" %}
  {{ col_name | trim }}  {% if ctype | trim == "integer" %}INTEGER{% elif ctype | trim == "decimal" %}NUMERIC{% elif ctype | trim == "boolean" %}BOOLEAN{% elif ctype | trim == "date" %}TIMESTAMPTZ{% else %}TEXT{% endif %}{% if nullable | trim != "true" %} NOT NULL{% endif %},
{%- endif %}
{%- endfor %}
  UNIQUE ({% set first_cols = [] %}{%- for col_name in col_name_list %}{%- set cidx = loop.index0 %}{%- set owner = prop_table_list[cidx] | default(value="") %}{%- if owner | trim == table_name | trim and col_name | trim != "" and loop.index <= 2 %}{{ col_name | trim }}{% if loop.index < 2 %}, {% endif %}{% endif %}{%- endfor %})
);

ALTER TABLE {{ table_name | trim }} ENABLE ROW LEVEL SECURITY;

CREATE TRIGGER set_{{ table_name | trim }}_updated_at
  BEFORE UPDATE ON {{ table_name | trim }}
  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

{%- endif %}
{%- endfor %}

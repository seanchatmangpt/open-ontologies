// wasm4pm process mining integration
export function toOcelEventLog(events: Array<{type: string; objectId: string; timestamp: string}>) {
  return {
    ocel_version: '2.0',
    ocel_global_event: { ocel_activity: '__INVALID__' },
    ocel_global_object: { ocel_type: '__INVALID__' },
    ocel_global_log: {
      ocel_attribute_names: ZOELA_OCEL_SCHEMA.eventAttributes,
      ocel_object_types: ZOELA_OCEL_SCHEMA.objectTypes,
    },
    ocel_events: events.reduce((acc, e) => ({
      ...acc,
      [`${e.objectId}-${e.timestamp}`]: {
        ocel_activity: e.type,
        ocel_timestamp: e.timestamp,
        ocel_omap: [e.objectId],
        ocel_vmap: {},
      }
    }), {}),
    ocel_objects: {},
  };

{#-
  role-access.tera — Generated ZOE LA role permission constants

  Generated by ggen from ontology/zoela/roles.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-roles

  ggen v5 rendering model: renders once per SELECT row.
  extract-role-requirements.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited):
    ?role_codes          — skos:notation per role
    ?role_labels         — rdfs:label per role
    ?permission_levels   — permissionLevel integer per role
    ?can_view_sensitives — "true"/"false" per role
    ?can_create_receipts — "true"/"false" per role
    ?can_assign_vols     — "true"/"false" per role
    ?req_trainings       — "true"/"false" per role
    ?req_bgcs            — "true"/"false" per role
-#}
// Generated from ontology/zoela/roles.ttl — DO NOT EDIT
// Regenerate with: ggen sync --rule zoela-roles
//
// Role permission constants for ZOE LA Mobile access control
// Source: ontology/zoela/roles.ttl → extract-role-requirements.rq → role-access.tera

{%- set code_list       = role_codes          | split(pat="|") %}
{%- set label_list      = role_labels         | split(pat="|") %}
{%- set perm_list       = permission_levels   | split(pat="|") %}
{%- set view_list       = can_view_sensitives | split(pat="|") %}
{%- set receipt_list    = can_create_receipts | split(pat="|") %}
{%- set assign_list     = can_assign_vols     | split(pat="|") %}
{%- set training_list   = req_trainings       | split(pat="|") %}
{%- set bgc_list        = req_bgcs            | split(pat="|") %}

export interface ZoeRole {
  code: string;
  label: string;
  permissionLevel: number;
  canViewSensitive: boolean;
  canCreateReceipts: boolean;
  canAssignVolunteers: boolean;
  requiresTraining: boolean;
  requiresBackgroundCheck: boolean;
}

export const ZOE_ROLES: Record<string, ZoeRole> = {
{% for code in code_list %}
{%- set i           = loop.index0 %}
{%- set label       = label_list[i]      | default(value="")      | trim %}
{%- set perm        = perm_list[i]       | default(value="1")     | trim %}
{%- set can_view    = view_list[i]       | default(value="false") | trim %}
{%- set can_receipt = receipt_list[i]    | default(value="false") | trim %}
{%- set can_assign  = assign_list[i]     | default(value="false") | trim %}
{%- set req_train   = training_list[i]   | default(value="false") | trim %}
{%- set req_bgc     = bgc_list[i]        | default(value="false") | trim %}
{%- if code | trim != "" %}
  '{{ code | trim }}': {
    code: '{{ code | trim }}',
    label: '{{ label }}',
    permissionLevel: {{ perm }},
    canViewSensitive: {{ can_view }},
    canCreateReceipts: {{ can_receipt }},
    canAssignVolunteers: {{ can_assign }},
    requiresTraining: {{ req_train }},
    requiresBackgroundCheck: {{ req_bgc }},
  },
{%- endif %}
{% endfor %}
};

export function hasRequiredRole(actorRole: string, requiredRole: string): boolean {
  const actor = ZOE_ROLES[actorRole];
  const required = ZOE_ROLES[requiredRole];
  if (!actor || !required) return false;
  return actor.permissionLevel >= required.permissionLevel;
}

export function canPerform(roleCode: string, capability: keyof ZoeRole): boolean {
  const role = ZOE_ROLES[roleCode];
  if (!role) return false;
  return role[capability] as boolean;
}

{#-
  admin-detail-screen.tera — admin detail-screen registry bundle

  Renders once per rule. extract-admin-screens.rq returns ONE aggregated
  row with every admin screen packed into pipe-delimited bindings.
  Template splits and loops to emit every admin detail screen in one file.
-#}
// ============================================================
// DO NOT EDIT — generated by ggen from
//   ontology/zoela/navigation.ttl + extract-admin-screens.rq
// Regenerate: ggen sync --rule zoela-admin-detail
// ============================================================

import React from 'react';
import { ScrollView, Text, View, StyleSheet } from 'react-native';

{%- set id_list    = screenIds              | split(pat="|") %}
{%- set label_list = screenLabels           | split(pat="|") %}
{%- set route_list = navRoutes              | split(pat="|") %}
{%- set tab_list   = parentTabCodes         | split(pat="|") %}
{%- set stack_list = screenStacks           | split(pat="|") %}
{%- set role_list  = requiredRoles          | split(pat="|") %}
{%- set obj_list   = primaryObjectTypes     | split(pat="|") %}

{%- set detail_count = 0 %}
{%- for s in id_list %}
{%-   if s | trim != "" %}{% set_global detail_count = detail_count + 1 %}{% endif %}
{%- endfor %}

// Admin detail screens: {{ detail_count }}

{%- for raw_id in id_list %}
{%-   set idx    = loop.index0 %}
{%-   set sid    = raw_id              | default(value="") | trim %}
{%-   set slabel = label_list[idx]     | default(value="") | trim %}
{%-   set sroute = route_list[idx]     | default(value="") | trim %}
{%-   set stab   = tab_list[idx]       | default(value="") | trim %}
{%-   set sstack = stack_list[idx]     | default(value="") | trim %}
{%-   set srole  = role_list[idx]      | default(value="") | trim %}
{%-   set sobj   = obj_list[idx]       | default(value="") | trim %}

{%-   if sid != "" %}
{%-     if sroute != "" %}{% set comp_base = sroute %}{% else %}{% set comp_base = sid %}{% endif %}
{%-     set comp_clean = comp_base | replace(from="/", to="_") | replace(from="-", to="_") %}
{%-     set comp_name = comp_clean ~ "DetailScreen" %}

// ----------------------------------------------------------------
// {{ slabel }}
//   tab:    {{ stab }} · stack: {{ sstack }} · role: {{ srole }}
//   object: {{ sobj }}
// ----------------------------------------------------------------
export function {{ comp_name }}() {
  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>{{ slabel }}</Text>
      <View style={styles.content}>
        <Text style={styles.placeholder}>{{ sobj }} detail view</Text>
      </View>
    </ScrollView>
  );
}
{%-   endif %}
{%- endfor %}

const styles = StyleSheet.create({
  container:   { flex: 1, backgroundColor: '#fff' },
  content:     { padding: 16 },
  title:       { fontSize: 22, fontWeight: '700', paddingHorizontal: 16, paddingTop: 16, marginBottom: 8 },
  placeholder: { fontSize: 14, color: '#666', fontStyle: 'italic' },
});

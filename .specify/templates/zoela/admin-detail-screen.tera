{#-
  admin-detail-screen.tera — Generated admin detail screen components for ZOE LA Mobile

  Generated by ggen from ontology/zoela/navigation.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-admin-screens

  ggen v5 rendering model: renders once per SELECT row.
  extract-screens.rq returns one row per AppScreen with is_admin_only = "true".

  SPARQL variables per row:
    screen_id           — skos:notation (e.g. "ADMIN_NEEDS")
    screen_label        — rdfs:label (e.g. "Admin Needs Detail")
    nav_route           — navigation route identifier
    parent_tab_code     — parent tab code (default: "HOME")
    screen_stack        — navigation stack (default: "MainStack")
    required_role       — minimum role code (default: "MEMBER")
    primary_object_type — object type this screen displays
    primary_route_category — service route category
    is_admin_only       — "true" / "false"
    screen_order        — display order integer string
-#}
// Generated by CodeManufactory — do not edit
// Source: ontology/zoela/navigation.ttl + extract-screens.rq
// Regenerate with: ggen sync --rule zoela-admin-screens

import React from 'react';
import { ScrollView, Text, View, StyleSheet } from 'react-native';

{% for row in rows %}
{% if row.is_admin_only == "true" %}
// Admin Detail: {{ row.screen_label }}
// Object type:  {{ row.primary_object_type }}
// Route:        {{ row.nav_route | default(value=row.screen_id) }}
export function {{ row.nav_route | default(value=row.screen_id) | replace(from="/", to="_") | replace(from="-", to="_") }}DetailScreen() {
  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>{{ row.screen_label }}</Text>
      {/* Tab: {{ row.parent_tab_code }} */}
      {/* Stack: {{ row.screen_stack }} */}
      {/* Required role: {{ row.required_role }} */}
      {/* Object type: {{ row.primary_object_type }} */}
      <View style={styles.content}>
        <Text style={styles.placeholder}>
          {{ row.primary_object_type }} detail view
        </Text>
      </View>
    </ScrollView>
  );
}

{% endif %}
{% endfor %}

const styles = StyleSheet.create({
  container:   { flex: 1, backgroundColor: '#fff' },
  content:     { padding: 16 },
  title:       { fontSize: 22, fontWeight: '700', paddingHorizontal: 16, paddingTop: 16, marginBottom: 8 },
  placeholder: { fontSize: 14, color: '#666', fontStyle: 'italic' },
});

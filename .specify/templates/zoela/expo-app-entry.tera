{#-
  expo-app-entry.tera — apps/mobile/App.tsx

  Mounts the manifest-declared entry screen and runs an in-app RLS probe
  against push_notification (admitted table) so misconfigurations surface
  immediately on app load.
-#}
// ============================================================
// DO NOT EDIT — generated by ggen from
//   ontology/profiles/zoela-expo-app.ttl + extract-expo-runtime-config.rq
// Regenerate: ggen sync --rule zoela-expo-app-entry
// ============================================================

import React, { useEffect, useState } from 'react';
import { ScrollView, Text, StyleSheet, View } from 'react-native';
import { SafeAreaView, SafeAreaProvider } from 'react-native-safe-area-context';
import { StatusBar } from 'expo-status-bar';
import { {{ entryScreenComponent }} } from '{{ entryScreenImportPath }}';
import { supabase, supabaseConfig } from './src/lib/supabaseClient';

interface ProbeResult {
  table: string;
  status: 'pending' | 'rls_blocked_ok' | 'rls_permissive_warn' | 'error';
  detail: string;
}

async function probePushNotificationRls(): Promise<ProbeResult> {
  try {
    const { data, error } = await supabase
      .from('push_notification')
      .select('id')
      .limit(1);

    if (error) {
      if (
        error.code === '42501' ||
        error.message?.toLowerCase().includes('permission')
      ) {
        return {
          table: 'push_notification',
          status: 'rls_blocked_ok',
          detail: `Anon SELECT denied by RLS: ${error.message}`,
        };
      }
      return {
        table: 'push_notification',
        status: 'error',
        detail: `${error.code ?? '?'}: ${error.message}`,
      };
    }
    if (!data || data.length === 0) {
      return {
        table: 'push_notification',
        status: 'rls_blocked_ok',
        detail: 'Anon SELECT returned 0 rows (RLS default-deny working).',
      };
    }
    return {
      table: 'push_notification',
      status: 'rls_permissive_warn',
      detail: `Anon SELECT returned ${data.length} rows — RLS is too permissive.`,
    };
  } catch (e: unknown) {
    const msg = e instanceof Error ? e.message : String(e);
    return {
      table: 'push_notification',
      status: 'error',
      detail: `Connection error: ${msg}`,
    };
  }
}

export default function App() {
  const [probe, setProbe] = useState<ProbeResult>({
    table: 'push_notification',
    status: 'pending',
    detail: 'Probing…',
  });

  useEffect(() => {
    probePushNotificationRls().then(setProbe);
  }, []);

  const probeColor =
    probe.status === 'rls_blocked_ok' ? '#0a7f33'
    : probe.status === 'rls_permissive_warn' ? '#b06b00'
    : probe.status === 'error' ? '#a91c1c'
    : '#555';

  return (
    <SafeAreaProvider>
      <SafeAreaView style={styles.root}>
        <StatusBar style="auto" />
        <ScrollView contentContainerStyle={styles.scroll}>
          <View style={styles.header}>
            <Text style={styles.title}>{{ appName }}</Text>
            <Text style={styles.subtitle}>
              Generated screens · Supabase {supabaseConfig.isLocal ? 'local' : 'remote'}
            </Text>
            <Text style={[styles.probe, { color: probeColor }]}>
              {probe.status}: {probe.detail}
            </Text>
          </View>

          <{{ entryScreenComponent }} />
        </ScrollView>
      </SafeAreaView>
    </SafeAreaProvider>
  );
}

const styles = StyleSheet.create({
  root:     { flex: 1, backgroundColor: '#fff' },
  scroll:   { flexGrow: 1 },
  header:   { padding: 16, borderBottomWidth: 1, borderBottomColor: '#eee' },
  title:    { fontSize: 28, fontWeight: 'bold' },
  subtitle: { fontSize: 14, color: '#666', marginTop: 4 },
  probe:    { fontSize: 12, marginTop: 8, fontFamily: 'monospace' },
});

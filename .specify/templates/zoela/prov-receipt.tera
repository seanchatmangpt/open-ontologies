{#-
  prov-receipt.tera — Generated PROV-O receipt emitters for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-receipts

  ggen v5 rendering model: renders once per SELECT row.
  extract-receipt-models.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited):
    ?receiptCodes       — receipt type code per model
    ?receiptLabels      — human-readable label per model
    ?receiptDefinitions — definition per model (empty string if absent)
    ?ocelEventTypes     — OCEL event type emitted (empty string if absent)
    ?usedInRoutes       — route code that uses each receipt (empty string if absent)
-#}
// Generated from ontology/zoela/*.ttl — DO NOT EDIT
// Regenerate with: ggen sync --rule zoela-receipts
//
// PROV-O receipt emitters for ZOE LA Mobile
// Source: ontology/zoela/*.ttl → extract-receipt-models.rq → prov-receipt.tera
import { blake3Hash } from '../utils/crypto';

{%- set receipt_code_list  = receiptCodes        | split(pat="|") %}
{%- set receipt_label_list = receiptLabels       | split(pat="|") %}
{%- set receipt_def_list   = receiptDefinitions  | split(pat="|") %}
{%- set ocel_type_list     = ocelEventTypes      | split(pat="|") %}
{%- set route_list         = usedInRoutes        | split(pat="|") %}

{% for receipt_code in receipt_code_list %}
{%- set ridx   = loop.index0 %}
{%- set rlabel = receipt_label_list[ridx] | default(value="") | trim %}
{%- set rdef   = receipt_def_list[ridx]   | default(value="") | trim %}
{%- set rocel  = ocel_type_list[ridx]     | default(value="receipt.emitted") | trim %}
{%- set rroute = route_list[ridx]         | default(value="") | trim %}
{%- set rcode  = receipt_code | trim %}
{%- if rcode != "" %}

// {{ rlabel }}
{%- if rdef != "" %}
// {{ rdef }}
{%- endif %}
{%- if rroute != "" %}
// Used in route: {{ rroute }}
{%- endif %}
// PROV-O subclass of prov:Entity
export interface {{ rcode | replace(from=".", to="_") | replace(from="-", to="_") | title | replace(from=" ", to="") }}Receipt {
  receiptId: string;
  routeInstanceId: string;
  subjectId: string;
  subjectType: string;
  campusId: string;
  ministryCode: string;
  routeStageCode: string;
  evidenceIds: string[];
  actorId: string;
  issuedAt: string; // ISO 8601
  blake3Hash: string;
  ocelEventType: '{{ rocel }}';
}

export function emit{{ rcode | replace(from=".", to="_") | replace(from="-", to="_") | title | replace(from=" ", to="") }}Receipt(
  params: Omit<{{ rcode | replace(from=".", to="_") | replace(from="-", to="_") | title | replace(from=" ", to="") }}Receipt, 'receiptId' | 'issuedAt' | 'blake3Hash'>
): {{ rcode | replace(from=".", to="_") | replace(from="-", to="_") | title | replace(from=" ", to="") }}Receipt {
  const issuedAt = new Date().toISOString();
  const payload = JSON.stringify({ ...params, issuedAt });
  return {
    ...params,
    receiptId: crypto.randomUUID(),
    issuedAt,
    blake3Hash: blake3Hash(payload),
    ocelEventType: '{{ rocel }}',
  };
}
{%- endif %}
{% endfor %}

{#-
  typescript-types.tera — Generated TypeScript interfaces for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --target zoela-mobile

  ggen v5 rendering model: renders once per SELECT row.
  classes_aggregated.rq returns ONE row with pipe-delimited aggregates,
  so this template renders exactly once and produces the complete file.

  SPARQL variables from classes_aggregated.rq (all pipe-delimited):
    ?classNames        — zoe: local names (e.g. "PersonProfile|Household")
    ?classDescriptions — rdfs:comment values for each class
    ?classIris         — full IRI for each class
    ?propClasses       — class owner for each property (repeated per prop)
    ?propNames         — property local names
    ?propColumns       — skos:notation column names
    ?propDescriptions  — rdfs:comment values
    ?propRanges        — xsd: type IRIs (full, e.g. "http://...#string")
    ?propRequired      — "true" or "false" per property
    ?propTsTypes       — mapped TypeScript type (string|number|boolean|UUID)

  schemeNames        — SKOS ConceptScheme local names (pipe-delimited)
  schemeDescriptions — rdfs:comment for each scheme
  conceptSchemes     — which scheme each concept belongs to (pipe-delimited)
  conceptValues      — skos:notation or local name for each concept
-#}
// Generated from ontology/zoela/*.ttl — DO NOT EDIT
// Regenerate with: ggen sync --target zoela-mobile
//
// Architecture:
//   Tier 1 — ontology/zoela/*.ttl           (source of truth)
//   Tier 2 — ggen sync                      (manufacturing step)
//   Tier 3 — src/types/zoela.ts             (this file, imported by app)

{%- set class_name_list        = classNames        | split(pat="|") %}
{%- set class_description_list = classDescriptions | split(pat="|") %}
{%- set class_iri_list         = classIris         | split(pat="|") %}
{%- set prop_class_list        = propClasses       | split(pat="|") %}
{%- set prop_name_list         = propNames         | split(pat="|") %}
{%- set prop_column_list       = propColumns       | split(pat="|") %}
{%- set prop_description_list  = propDescriptions  | split(pat="|") %}
{%- set prop_ts_type_list      = propTsTypes       | split(pat="|") %}
{%- set prop_required_list     = propRequired      | split(pat="|") %}

{%- set scheme_name_list        = schemeNames        | split(pat="|") %}
{%- set scheme_description_list = schemeDescriptions | split(pat="|") %}
{%- set concept_scheme_list     = conceptSchemes     | split(pat="|") %}
{%- set concept_value_list      = conceptValues      | split(pat="|") %}

// ============================================================================
// Shared base fields injected into every generated interface
// ============================================================================
export interface ZoelaBase {
  /** Surrogate primary key (UUID v4) */
  id: string;
  /** Row creation timestamp (ISO-8601) */
  created_at: string;
  /** Row last-update timestamp (ISO-8601) — set by Supabase trigger */
  updated_at?: string;
}

// ============================================================================
// Domain interfaces — one per OWL class in ontology/zoela/*.ttl
// ============================================================================
{% for class_name in class_name_list %}
{%- set idx = loop.index0 %}
{%- set class_desc = class_description_list[idx] | default(value="") %}
{%- if class_name | trim != "" %}

/** {{ class_desc | trim }} */
export interface {{ class_name | trim | replace(from=" ", to="") }} extends ZoelaBase {
{%- set_global seen_cols = [] %}
{%- for prop_name in prop_name_list %}
{%- set pidx = loop.index0 %}
{%- set owner  = prop_class_list[pidx]       | default(value="") %}
{%- set col    = prop_column_list[pidx]      | default(value="") %}
{%- set pdesc  = prop_description_list[pidx] | default(value="") %}
{%- set tstype = prop_ts_type_list[pidx]     | default(value="unknown") %}
{%- set req    = prop_required_list[pidx]    | default(value="false") %}
{%- if owner | trim == class_name | trim and col | trim != "" and col | trim not in seen_cols %}
{%- set_global seen_cols = seen_cols | concat(with=col | trim) %}
  /** {{ pdesc | trim }} */
  {{ col | trim }}{% if req | trim != "true" %}?{% endif %}: {{ tstype | trim }};
{%- endif %}
{%- endfor %}
}
{%- endif %}
{%- endfor %}

// ============================================================================
// Enum types from SKOS ConceptSchemes in ontology/zoela/*.ttl
// ============================================================================
{% for scheme_name in scheme_name_list %}
{%- set sidx       = loop.index0 %}
{%- set scheme_desc = scheme_description_list[sidx] | default(value="") %}
{%- if scheme_name | trim != "" %}

/** {{ scheme_desc | trim }} */
export type {{ scheme_name | trim | replace(from=" ", to="") }} =
{%- set found_concepts = [] %}
{%- for concept_value in concept_value_list %}
{%- set cidx   = loop.index0 %}
{%- set cscheme = concept_scheme_list[cidx] | default(value="") %}
{%- if cscheme | trim == scheme_name | trim and concept_value | trim != "" %}
  | '{{ concept_value | trim }}'
{%- endif %}
{%- endfor %}
  | (string & Record<never, never>);  // open union — extend by adding concepts to ontology
{%- endif %}
{%- endfor %}

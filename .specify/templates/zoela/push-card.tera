{#-
  push-card.tera — Generated TypeScript push card configuration for Expo

  Generated by CodeManufactory from:
    ontology/zoela/notifications.ttl
    .specify/queries/zoela/extract-push-card-fields.rq

  Do NOT edit — regenerate with: ggen sync --target zoela-mobile

  ggen v5 rendering model: renders once per SELECT row.
  extract-push-card-fields.rq returns ONE aggregated row with
  pipe-delimited values, so this template renders exactly once
  and produces the complete PUSH_CARDS array.

  SPARQL variables (all pipe-delimited GROUP_CONCAT aggregates):
    card_title      — zoe:cardTitle per template
    card_subtitle   — zoe:cardSubtitle per template (or empty string)
    card_body       — zoe:cardBody per template (or empty string)
    card_action     — zoe:cardAction per template (or empty string)
    card_deep_link  — zoe:cardDeepLink URI per template (or empty string)
    card_priority   — zoe:cardPriority integer per template (or "0")
    route_labels    — pipe-delimited ServiceRoute labels per card (or empty)
-#}
// Generated by CodeManufactory — do not edit
// Source: ontology/zoela/notifications.ttl + extract-push-card-fields.rq

import { PushCard } from '../types/notifications';

{% set titles = card_title | split(pat="|") %}
{% set subtitles = card_subtitle | default(value="") | split(pat="|") %}
{% set bodies = card_body | default(value="") | split(pat="|") %}
{% set actions = card_action | default(value="") | split(pat="|") %}
{% set deep_links = card_deep_link | default(value="") | split(pat="|") %}
{% set priorities = card_priority | default(value="0") | split(pat="|") %}
export const PUSH_CARDS: PushCard[] = [
{% for i in range(end=titles | length) %}
  {
    title: "{{ titles[i] }}",
    subtitle: "{{ subtitles[i] }}",
    body: "{{ bodies[i] }}",
    action: "{{ actions[i] }}",
    deepLink: "{{ deep_links[i] }}",
    priority: {{ priorities[i] }},
  },
{% endfor %}
];

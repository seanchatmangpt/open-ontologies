{#-
  supabase-materialization-refusals.tera — Refused-candidate audit report

  P0-B.4d-fix: every materialization candidate that did NOT pass admissibility
  appears here. The SQL migration template never sees these rows.

  Consumes: extract-public-materialization-refusals.rq

  Reasons surfaced:
    - refused_missing_shape
    - refused_no_body_columns
    - refused_missing_datatype
    - refused_duplicate_columns
    - refused_missing_policy
    - refused_ambiguous_materialization_kind

  The output is a SQL-comment-formatted audit log (safe to commit alongside the
  migration SQL). To machine-read it, scrape the `-- REFUSAL:` lines.
-#}
-- =============================================================================
-- ZOE LA Public-Vocab Materialization — Refusal Audit
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from
--   .specify/queries/zoela/extract-public-materialization-refusals.rq
--
-- Doctrine: a class×kind pair appears in this audit when admissibility cannot
-- be established for the Supabase target runtime. Every refusal is a gate
-- failure upstream of the SQL migration — by construction, none of these rows
-- correspond to tables in 20260518000001_zoela_tables.sql.
--
-- To admit a refused candidate:
--   refused_missing_shape       → add a SHACL NodeShape targeting the anchor
--                                 in ontology/profiles/public-role-shapes.ttl
--   refused_no_body_columns     → declare body properties (owl:DatatypeProperty
--                                 or owl:ObjectProperty) with rdfs:domain and
--                                 skos:notation; or set requiresOwner=true on
--                                 the materialization kind
--   refused_missing_datatype    → add rdfs:range to every property
--   refused_duplicate_columns   → ensure all skos:notation values within the
--                                 class normalize uniquely (lowercase + hyphen
--                                 → underscore must not collide)
--   refused_missing_policy      → add an ODRL permission whose action has
--                                 ggen:rlsTargetKind pointing here
--   refused_ambiguous_materialization_kind
--                               → adjust ggen:materializationPriority so one
--                                 kind ranks strictly higher than the others
--   refused_property_notation_ambiguity
--                               → ensure each property of the class has a
--                                 single skos:notation triple (no rendering
--                                 layer is allowed to pick between competing
--                                 column-name candidates)
-- =============================================================================

{%- set ref_class_iri_list  = refClassIris  | split(pat="|") %}
{%- set ref_class_name_list = refClassNames | split(pat="|") %}
{%- set ref_table_name_list = refTableNames | split(pat="|") %}
{%- set ref_kind_iri_list   = refKindIris   | split(pat="|") %}
{%- set ref_kind_code_list  = refKindCodes  | split(pat="|") %}
{%- set ref_anchor_list     = refAnchors    | split(pat="|") %}
{%- set ref_reason_list     = refReasons    | split(pat="|") %}

{%- set refusal_count = 0 %}
{%- for r in ref_reason_list %}
{%-   if r | trim != "" %}{% set_global refusal_count = refusal_count + 1 %}{% endif %}
{%- endfor %}
-- Refusal count: {{ refusal_count }}
--
{%- if refusal_count == 0 %}
-- No refusals. Every materialization candidate passed admissibility.
{%- else %}
{%-   for ref_reason in ref_reason_list %}
{%-     set idx       = loop.index0 %}
{%-     set rclass    = ref_class_iri_list[idx]  | default(value="") | trim %}
{%-     set rname     = ref_class_name_list[idx] | default(value="") | trim %}
{%-     set rtable    = ref_table_name_list[idx] | default(value="") | trim %}
{%-     set rkind     = ref_kind_iri_list[idx]   | default(value="") | trim %}
{%-     set rkindcode = ref_kind_code_list[idx]  | default(value="") | trim %}
{%-     set ranchor   = ref_anchor_list[idx]     | default(value="") | trim %}
{%-     set rreason   = ref_reason | trim %}
-- REFUSAL: {{ rname }} ({{ rtable }}) × {{ rkindcode }} — {{ rreason }}
--          class:  {{ rclass }}
--          kind:   {{ rkind }}
--          anchor: {{ ranchor }}
--
{%-   endfor %}
{%- endif %}
-- =============================================================================
-- End of refusal audit.
-- =============================================================================

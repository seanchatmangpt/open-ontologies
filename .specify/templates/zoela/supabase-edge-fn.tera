{#-
  supabase-edge-fn.tera — Generated Supabase Edge Function stubs for service route transitions

  Generated by ggen from ontology/zoela/routes.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-service-routes

  ggen v5 rendering model: renders once per SELECT row.
  extract-service-routes.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited GROUP_CONCAT):
    stageCodes         — skos:notation per stage
    stageLabels        — rdfs:label per stage
    stageRouteCodes    — route code each stage belongs to
    stageOrders        — integer order per stage
    stageIsEntries     — "true"/"false" per stage
    stageIsTerminals   — "true"/"false" per stage
    stagePredCodes     — predecessor stage code (empty string if absent)
    stageRoleCodes     — required role code (empty string if absent)
    stageConsentCodes  — required consent code (empty string if absent)
    stageReceiptTypes  — completion receipt type (empty string if absent)
    stageOcelTypes     — OCEL event type (empty string if absent)
    stageTimeouts      — timeout hours (empty string if absent)
-#}
// Generated by CodeManufactory — do not edit
// Source: ontology/zoela/routes.ttl + extract-service-routes.rq
// Regenerate with: ggen sync --rule zoela-service-routes

import { serve } from 'https://deno.land/std@0.168.0/http/server.ts';
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

{%- set stage_code_list       = stageCodes      | split(pat="|") %}
{%- set stage_label_list      = stageLabels     | split(pat="|") %}
{%- set stage_route_code_list = stageRouteCodes | split(pat="|") %}
{%- set stage_consent_list    = stageConsentCodes | split(pat="|") %}
{%- set stage_role_list       = stageRoleCodes  | split(pat="|") %}
{%- set stage_receipt_list    = stageReceiptTypes | split(pat="|") %}

type StageTransitionResult = { ok: boolean; receiptType?: string; error?: string };

const STAGE_HANDLERS: Record<string, (routeId: string, stageId: string, actorId: string) => Promise<StageTransitionResult>> = {
{% for stage_code in stage_code_list %}
{%- set sidx     = loop.index0 %}
{%- set slabel   = stage_label_list[sidx]       | default(value="") | trim %}
{%- set srcode   = stage_route_code_list[sidx]  | default(value="") | trim %}
{%- set sconsent = stage_consent_list[sidx]     | default(value="") | trim %}
{%- set srole    = stage_role_list[sidx]        | default(value="") | trim %}
{%- set sreceipt = stage_receipt_list[sidx]     | default(value="") | trim %}
{%- if stage_code | trim != "" %}
  // Route: {{ srcode }} | Stage: {{ slabel }}
  "{{ srcode }}:{{ stage_code | trim }}": async (routeId, stageId, actorId) => {
    {% if sconsent != "" %}// Requires consent: {{ sconsent }}{% endif %}
    {% if srole != "" %}// Requires role: {{ srole }}{% endif %}
    console.log(`[{{ srcode }}] {{ slabel }} — routeId=${routeId} stageId=${stageId} actor=${actorId}`);
    {% if sreceipt != "" %}return { ok: true, receiptType: '{{ sreceipt }}' };{% else %}return { ok: true };{% endif %}
  },
{%- endif %}
{% endfor %}
};

serve(async (req: Request) => {
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL') ?? '',
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? '',
  );

  let body: { routeCode: string; routeId: string; stageCode: string; actorId: string };
  try {
    body = await req.json();
  } catch {
    return new Response('Invalid JSON body', { status: 400 });
  }

  const { routeCode, routeId, stageCode, actorId } = body;
  const handlerKey = `${routeCode}:${stageCode}`;
  const handler = STAGE_HANDLERS[handlerKey];

  if (!handler) {
    return new Response(
      JSON.stringify({ ok: false, error: `Unknown route:stage — ${handlerKey}` }),
      { status: 404, headers: { 'Content-Type': 'application/json' } },
    );
  }

  const result = await handler(routeId, stageCode, actorId);
  return new Response(JSON.stringify(result), {
    status: result.ok ? 200 : 422,
    headers: { 'Content-Type': 'application/json' },
  });
});

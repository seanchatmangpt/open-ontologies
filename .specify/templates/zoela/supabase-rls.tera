{#-
  supabase-rls.tera — Generated Supabase RLS policy SQL for ZOE LA Mobile

  Generated by ggen from ontology/zoela/*.ttl
  Do NOT edit — regenerate with: ggen sync --rule zoela-rls

  ggen v5 rendering model: renders once per SELECT row.
  extract-rls-policies.rq returns ONE row with pipe-delimited aggregates.

  SPARQL variables (all pipe-delimited):
    ?policyCodes    — skos:notation per policy
    ?policyLabels   — rdfs:label per policy
    ?policyTables   — target table name per policy
    ?permPolicies   — policy code repeated per permission
    ?permCodes      — permission skos:notation
    ?permOps        — SQL operation (SELECT/INSERT/UPDATE/DELETE)
    ?permRoles      — required role code
-#}
-- Generated from ontology/zoela/*.ttl — DO NOT EDIT
-- Regenerate with: ggen sync --rule zoela-rls

{%- set policy_code_list  = policyCodes  | split(pat="|") %}
{%- set policy_label_list = policyLabels | split(pat="|") %}
{%- set policy_table_list = policyTables | split(pat="|") %}
{%- set perm_policy_list  = permPolicies | split(pat="|") %}
{%- set perm_code_list    = permCodes    | split(pat="|") %}
{%- set perm_op_list      = permOps      | split(pat="|") %}
{%- set perm_role_list    = permRoles    | split(pat="|") %}

{% for policy_code in policy_code_list %}
{%- set pidx        = loop.index0 %}
{%- set plabel      = policy_label_list[pidx] | default(value="") %}
{%- set ptable      = policy_table_list[pidx] | default(value="") %}
{%- if policy_code | trim != "" and ptable | trim != "" %}

-- ============================================================================
-- RLS: {{ plabel | trim }}
-- Policy code: {{ policy_code | trim }}
-- ============================================================================
ALTER TABLE {{ ptable | trim }} ENABLE ROW LEVEL SECURITY;

{%- for perm_code in perm_code_list %}
{%- set rridx  = loop.index0 %}
{%- set ppol   = perm_policy_list[rridx] | default(value="") %}
{%- set pop    = perm_op_list[rridx]     | default(value="SELECT") %}
{%- set prole  = perm_role_list[rridx]   | default(value="authenticated") %}
{%- if ppol | trim == policy_code | trim and perm_code | trim != "" %}

CREATE POLICY "{{ policy_code | trim }}_{{ perm_code | trim }}_{{ pop | trim | upper }}"
  ON {{ ptable | trim }}
  FOR {{ pop | trim | upper }}
  TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM person_role_assignments pra
      JOIN roles r ON pra.role_id = r.id
      WHERE pra.person_id = auth.uid()::text
        AND r.role_code = '{{ prole | trim }}'
        AND pra.is_active = true
    )
  );
{%- endif %}
{%- endfor %}

{%- endif %}
{%- endfor %}

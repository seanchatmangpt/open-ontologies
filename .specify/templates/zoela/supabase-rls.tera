{#-
  supabase-rls.tera — ODRL-driven Supabase RLS policy SQL

  P0-B.7b: every CREATE POLICY emitted here corresponds to exactly one ODRL
  permission tuple (policy, action, target table) joined to an admitted
  materialization in zoela-tables.sql. No fallback `authenticated_read`
  policies. No template-side dedupe or admission logic.

  Doctrine:
    - Tera renders facts. Admission belongs upstream.
    - The extractor (extract-odrl-policies.rq) does the policy×action×kind×
      class×table join. The template only formats CREATE POLICY statements.

  Consumes ?rls* pipe-delimited bindings from extract-odrl-policies.rq:
    ?rlsPolicyCodes        — policy skos:notation (e.g. "member_policy")
    ?rlsActionCodes        — action skos:notation (e.g. "view_public_events")
    ?rlsRoles              — ggen:rlsAppliesToRole value ("member", "admin", …)
    ?rlsOperations         — Postgres operation ("SELECT", "INSERT", "UPDATE",
                             "DELETE", "ALL")
    ?rlsConstraints        — SQL fragment for USING() (or empty = no extra
                             constraint beyond the role check)
    ?rlsTargetKindCodes    — materialization-kind notation (for comments)
    ?rlsTargetTables       — local Postgres table name (admitted in zoela-tables.sql)
    ?rlsTargetClasses      — local ZOE class IRI (for comments)
-#}
-- =============================================================================
-- ZOE LA Supabase RLS — generated from ODRL policy chain
-- =============================================================================
-- DO NOT EDIT. Generated by ggen from:
--   ontology/zoela/policy.ttl                            (ODRL policies + actions)
--   ontology/profiles/zoela-supabase-rls.ttl             (action → RLS translation)
--   ontology/profiles/zoela-supabase-materialization.ttl (kinds + priorities)
-- Regenerate with: ggen sync --rule zoela-rls
--
-- Doctrine: every CREATE POLICY below corresponds to exactly one ODRL
-- permission tuple joined to an admitted table. Default-deny applies to any
-- (table, operation, role) combination without a row here — ODRL prohibitions
-- are documented in policy.ttl but NOT rendered (their effect is the absence
-- of a grant).
-- =============================================================================

{%- set policy_code_list  = rlsPolicyCodes      | split(pat="|") %}
{%- set action_code_list  = rlsActionCodes      | split(pat="|") %}
{%- set role_list         = rlsRoles            | split(pat="|") %}
{%- set op_list           = rlsOperations       | split(pat="|") %}
{%- set constraint_list   = rlsConstraints      | split(pat="|") %}
{%- set kind_code_list    = rlsTargetKindCodes  | split(pat="|") %}
{%- set table_list        = rlsTargetTables     | split(pat="|") %}
{%- set class_list        = rlsTargetClasses    | split(pat="|") %}

{%- set rls_row_count = 0 %}
{%- for r in role_list %}
{%-   if r | trim != "" %}{% set_global rls_row_count = rls_row_count + 1 %}{% endif %}
{%- endfor %}

-- ----------------------------------------------------------------------------
-- RLS policy rows: {{ rls_row_count }}
-- (Every row below is an admitted ODRL permission joined to an admitted table.)
-- ----------------------------------------------------------------------------

{%- for raw_role in role_list %}
{%-   set idx       = loop.index0 %}
{%-   set role      = raw_role                            | default(value="") | trim %}
{%-   set pcode     = policy_code_list[idx] | default(value="") | trim %}
{%-   set acode     = action_code_list[idx] | default(value="") | trim %}
{%-   set raw_op    = op_list[idx]          | default(value="SELECT") | trim | upper %}
{%-   set raw_constraint = constraint_list[idx] | default(value="") | trim %}
{%-   set kindcode  = kind_code_list[idx]   | default(value="") | trim %}
{%-   set raw_table = table_list[idx]       | default(value="") | trim %}
{%-   set classiri  = class_list[idx]       | default(value="") | trim %}
{%-   set table     = raw_table | lower | replace(from="-", to="_") %}

{%-   if role != "" and pcode != "" and table != "" and raw_op != "" %}
{#-
  Postgres RLS clause rules:
    FOR SELECT / FOR DELETE   → USING only      (which existing rows are visible)
    FOR INSERT                → WITH CHECK only (validates rows being written)
    FOR UPDATE / FOR ALL      → both            (visibility + write validation)
-#}
{%-     set needs_using = raw_op == "SELECT" or raw_op == "DELETE" or raw_op == "UPDATE" or raw_op == "ALL" %}
{%-     set needs_check = raw_op == "INSERT" or raw_op == "UPDATE" or raw_op == "ALL" %}

-- ----------------------------------------------------------------------------
-- {{ pcode }} → {{ acode }} (FOR {{ raw_op }}) on {{ table }}
--   Role:         {{ role }}
--   Target kind:  {{ kindcode }}
--   Source class: {{ classiri }}
{%-     if raw_constraint != "" %}
--   Constraint:   {{ raw_constraint }}
{%-     endif %}
-- ----------------------------------------------------------------------------
CREATE POLICY "{{ pcode }}__{{ acode }}__{{ raw_op | lower }}__{{ table }}"
  ON {{ table }}
  FOR {{ raw_op }}
  TO authenticated
{%-     if needs_using %}
  USING (
    EXISTS (
      SELECT 1 FROM person_role_assignments pra
      JOIN roles r ON pra.role_id = r.id
      WHERE pra.person_id = auth.uid()::text
        AND r.role_code = '{{ role }}'
        AND pra.is_active = true
    )
{%-       if raw_constraint != "" %}
    AND ({{ raw_constraint }})
{%-       endif %}
  )
{%-     endif %}
{%-     if needs_check %}
{%-       if needs_using %}
{%-       endif %}
  WITH CHECK (
    EXISTS (
      SELECT 1 FROM person_role_assignments pra
      JOIN roles r ON pra.role_id = r.id
      WHERE pra.person_id = auth.uid()::text
        AND r.role_code = '{{ role }}'
        AND pra.is_active = true
    )
{%-       if raw_constraint != "" %}
    AND ({{ raw_constraint }})
{%-       endif %}
  )
{%-     endif %}
  ;
{%-   endif %}
{%- endfor %}

-- =============================================================================
-- End of generated RLS. Default-deny applies to anything not granted above.
-- =============================================================================

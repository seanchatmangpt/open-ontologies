{#-
  expo-readme.tera — apps/mobile/README.md

  Renders a DocPage instance to Markdown. Sections come from the TTL in
  ggen:sectionOrder. Each section line in `secBundle` is
  "heading###level###body".

  Markdown headings: level 2 → "## ", level 3 → "### ", etc. The title is
  emitted as level-1 (#).
-#}
<!--
============================================================
DO NOT EDIT — generated by ggen from
  ontology/profiles/zoela-expo-app.ttl + extract-doc-page.rq
Regenerate: ggen sync --rule zoela-expo-readme
============================================================
-->
# {{ docTitle }}

{{ docSummary }}
{% set sec_entries = secBundle | split(pat="@@@") -%}
{%- for entry in sec_entries %}
{%-   set parts = entry | split(pat="###") %}
{%-   set s_heading = parts[0] | default(value="") | trim %}
{%-   set s_level   = parts[1] | default(value="2") | trim %}
{%-   set s_body_raw = parts[2] | default(value="") %}
{#- TTL body strings come through with JSON-escaped newlines; restore them
    so the rendered Markdown is actually multi-line. -#}
{%-   set s_body = s_body_raw | replace(from="\n", to="
") %}
{%-   if s_heading != "" %}

{% if s_level == "1" %}#{% elif s_level == "2" %}##{% elif s_level == "3" %}###{% elif s_level == "4" %}####{% else %}#####{% endif %} {{ s_heading }}

{{ s_body }}
{%-   endif %}
{%- endfor %}

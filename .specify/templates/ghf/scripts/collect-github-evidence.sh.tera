#!/bin/bash
# collect-github-evidence.sh — Generated by ggen
# Harvest API facts and git hashes for Observed OCEL generation

{%- set repo_list = names | split(pat="|") -%}
{%- set main_repo = repo_list[0] | trim -%}

OUTPUT_FILE=${1:-"observed-ocel.json"}

echo "Collecting evidence for {{ main_repo }}..."

GIT_HASH=$(git rev-parse HEAD)
GIT_STATUS=$(git status --short)
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Basic skeleton for Observed OCEL
# This artifact will be bound by a receipt in the next step.
cat <<EOF > $OUTPUT_FILE
{
  "command_harness": "ghf-evidence-collector",
  "working_directory": "$(pwd)",
  "git_hash": "$GIT_HASH",
  "git_status": "$GIT_STATUS",
  "timestamp": "$TIMESTAMP",
  "repo": "{{ main_repo }}",
  "boundary_type": "git-boundary",
  "actor_basis": "operator"
}
EOF

echo "Observed OCEL evidence captured in $OUTPUT_FILE"

@prefix ex:     <http://example.org/image/> .
@prefix schema: <https://schema.org/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# === Image node ===
ex:img_10
    rdf:type            schema:ImageObject ;
    rdfs:label          "Vintage blue van parked on road with trees in background"@en ;
    schema:name         "img_10.jpg"^^xsd:string ;
    schema:description  "A weathered turquoise Volkswagen Type 2 camper van with a white roof, parked on a dark road surface. Dense green trees form the background, and a few yellow fallen leaves lie on the ground."@en ;
    schema:contentUrl   "img_10.jpg"^^xsd:string ;
    ex:containsObject   ex:img10_obj_1 ,
                        ex:img10_obj_2 ,
                        ex:img10_obj_3 ,
                        ex:img10_obj_4 ,
                        ex:img10_obj_5 ,
                        ex:img10_obj_6 ,
                        ex:img10_obj_7 ,
                        ex:img10_obj_8 ,
                        ex:img10_obj_9 ,
                        ex:img10_obj_10 ,
                        ex:img10_obj_11 ,
                        ex:img10_obj_12 ,
                        ex:img10_obj_13 .

# === Object 1: Van (specific) ===
ex:img10_obj_1
    rdf:type            schema:Thing ;
    rdfs:label          "van"@en ;
    skos:altLabel       "camper van"@en ,
                        "volkswagen"@en ,
                        "VW bus"@en ,
                        "minibus"@en ,
                        "Type 2"@en ;
    schema:category     "vehicle"^^xsd:string ,
                        "van"^^xsd:string ,
                        "vintage vehicle"^^xsd:string ;
    schema:color        "turquoise"^^xsd:string ;
    schema:description  "A weathered turquoise Volkswagen Type 2 camper van with visible rust and patina"@en ;
    ex:condition        "weathered"^^xsd:string ;
    ex:partOf           ex:img_10 ;
    ex:hasComponent     ex:img10_obj_4 ,
                        ex:img10_obj_5 ,
                        ex:img10_obj_6 ,
                        ex:img10_obj_7 ;
    ex:onTopOf          ex:img10_obj_8 ;
    ex:inFrontOf        ex:img10_obj_3 .

# === Object 2: Vehicle (general) ===
ex:img10_obj_2
    rdf:type            schema:Thing ;
    rdfs:label          "vehicle"@en ;
    skos:altLabel       "automobile"@en ,
                        "motor vehicle"@en ,
                        "transport"@en ;
    schema:category     "vehicle"^^xsd:string ,
                        "transportation"^^xsd:string ;
    schema:description  "A motor vehicle present in the scene"@en ;
    ex:partOf           ex:img_10 ;
    ex:moreSpecific     ex:img10_obj_1 .

# === Object 3: Trees (specific) ===
ex:img10_obj_3
    rdf:type            schema:Thing ;
    rdfs:label          "trees"@en ;
    skos:altLabel       "tree"@en ,
                        "woodland"@en ,
                        "greenery"@en ;
    schema:category     "vegetation"^^xsd:string ,
                        "plant"^^xsd:string ,
                        "nature"^^xsd:string ;
    schema:color        "green"^^xsd:string ;
    schema:description  "Dense green trees forming a thick backdrop behind the van"@en ;
    ex:partOf           ex:img_10 ;
    ex:behind           ex:img10_obj_1 ;
    ex:above            ex:img10_obj_8 .

# === Object 4: Windows ===
ex:img10_obj_4
    rdf:type            schema:Thing ;
    rdfs:label          "windows"@en ;
    skos:altLabel       "window"@en ,
                        "glass panes"@en ,
                        "glazing"@en ;
    schema:category     "vehicle part"^^xsd:string ,
                        "component"^^xsd:string ;
    schema:description  "Multiple side windows along the van body, including a rear window"@en ;
    ex:partOf           ex:img_10 ;
    ex:componentOf      ex:img10_obj_1 .

# === Object 5: Tires ===
ex:img10_obj_5
    rdf:type            schema:Thing ;
    rdfs:label          "tires"@en ;
    skos:altLabel       "tire"@en ,
                        "wheels"@en ,
                        "wheel"@en ,
                        "tyres"@en ;
    schema:category     "vehicle part"^^xsd:string ,
                        "component"^^xsd:string ;
    schema:color        "black"^^xsd:string ;
    schema:description  "Black rubber tires visible on the side of the van"@en ;
    ex:partOf           ex:img_10 ;
    ex:componentOf      ex:img10_obj_1 ;
    ex:touches          ex:img10_obj_8 ;
    ex:below            ex:img10_obj_1 .

# === Object 6: Roof ===
ex:img10_obj_6
    rdf:type            schema:Thing ;
    rdfs:label          "roof"@en ;
    skos:altLabel       "van roof"@en ,
                        "pop-top"@en ,
                        "rooftop"@en ;
    schema:category     "vehicle part"^^xsd:string ,
                        "component"^^xsd:string ;
    schema:color        "white"^^xsd:string ;
    schema:description  "White raised roof section on top of the van"@en ;
    ex:partOf           ex:img_10 ;
    ex:componentOf      ex:img10_obj_1 ;
    ex:above            ex:img10_obj_1 .

# === Object 7: Rust / Patina ===
ex:img10_obj_7
    rdf:type            schema:Thing ;
    rdfs:label          "rust"@en ;
    skos:altLabel       "patina"@en ,
                        "corrosion"@en ,
                        "oxidation"@en ,
                        "weathering"@en ;
    schema:category     "surface condition"^^xsd:string ,
                        "wear"^^xsd:string ;
    schema:description  "Visible rust and patina on the lower body panels of the van"@en ;
    ex:partOf           ex:img_10 ;
    ex:componentOf      ex:img10_obj_1 ;
    ex:onSurfaceOf      ex:img10_obj_1 .

# === Object 8: Road surface ===
ex:img10_obj_8
    rdf:type            schema:Thing ;
    rdfs:label          "road"@en ;
    skos:altLabel       "road surface"@en ,
                        "pavement"@en ,
                        "tarmac"@en ,
                        "asphalt"@en ;
    schema:category     "ground"^^xsd:string ,
                        "infrastructure"^^xsd:string ,
                        "surface"^^xsd:string ;
    schema:color        "dark grey"^^xsd:string ;
    schema:description  "Dark asphalt road surface on which the van is parked"@en ;
    ex:partOf           ex:img_10 ;
    ex:below            ex:img10_obj_1 ;
    ex:supports         ex:img10_obj_1 .

# === Object 9: Foliage (general) ===
ex:img10_obj_9
    rdf:type            schema:Thing ;
    rdfs:label          "foliage"@en ;
    skos:altLabel       "leaves"@en ,
                        "vegetation"@en ,
                        "canopy"@en ,
                        "greenery"@en ;
    schema:category     "vegetation"^^xsd:string ,
                        "nature"^^xsd:string ;
    schema:color        "green"^^xsd:string ;
    schema:description  "Dense green foliage covering the trees in the background"@en ;
    ex:partOf           ex:img_10 ;
    ex:moreSpecific     ex:img10_obj_3 ;
    ex:behind           ex:img10_obj_1 .

# === Object 10: Fallen leaves ===
ex:img10_obj_10
    rdf:type            schema:Thing ;
    rdfs:label          "fallen leaves"@en ;

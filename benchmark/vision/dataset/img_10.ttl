# === Object 13: Van body paintwork ===
ex:img10_obj_13
    rdf:type            schema:Thing ;
    rdfs:label          "paintwork"@en ;
    skos:altLabel       "paint"@en ,
                        "body paint"@en ,
                        "finish"@en ,
                        "coating"@en ;
    schema:category     "surface condition"^^xsd:string ,
                        "vehicle part"^^xsd:string ;
    schema:color        "turquoise"^^xsd:string ;

# === Image Node ===

ex:img_8 a schema:ImageObject ;
    schema:name "img_8.jpg" ;
    schema:description "A young fallow deer fawn with white spots standing in a sunlit autumn forest clearing, surrounded by fallen leaves on the ground, with warm golden backlight filtering through bare deciduous trees and a fallen branch overhead." ;
    schema:keywords "deer", "fawn", "fallow deer", "spotted deer", "forest", "woodland", "autumn", "sunlight", "golden hour", "wildlife", "nature", "leaves", "trees", "backlight" ;
    schema:contentLocation "forest clearing" ;
    ex:detectedObjectCount "11"^^xsd:integer ;
    ex:scene "wildlife in autumn forest" ;
    ex:dominantColors "brown, gold, amber, tan, white" ;
    ex:mood "serene, magical, ethereal, peaceful" ;
    ex:lightingCondition "golden hour backlight, warm natural sunlight" ;
    ex:photographicStyle "wildlife portrait, shallow depth of field, bokeh background" .

# === Object 1: Fawn (young deer) ===

ex:img8_obj_1 a schema:Thing ;
    rdf:type ex:Animal ;
    rdfs:label "fawn" ;
    skos:altLabel "baby deer", "young deer", "fallow deer fawn", "spotted fawn" ;
    schema:category "animal" ;
    schema:description "A young fallow deer fawn (Dama dama) with characteristic white spots on brown fur, standing alert in the center foreground. It has large upright ears, dark eyes, and a short muzzle. The fawn is looking slightly to its left with a calm, curious expression." ;
    schema:additionalProperty [
        schema:name "species" ;
        schema:value "Dama dama (fallow deer)"
    ] ;
    schema:additionalProperty [
        schema:name "age" ;
        schema:value "juvenile"
    ] ;
    schema:additionalProperty [
        schema:name "coat pattern" ;
        schema:value "brown with white spots"
    ] ;
    ex:confidence "0.97"^^xsd:decimal ;
    ex:boundingBoxRegion "center-foreground" ;
    ex:spatialRelation [
        rdfs:label "standing on" ;
        ex:target ex:img8_obj_4
    ] ;
    ex:spatialRelation [
        rdfs:label "in front of" ;
        ex:target ex:img8_obj_5
    ] ;
    ex:spatialRelation [
        rdfs:label "below" ;
        ex:target ex:img8_obj_7
    ] ;
    ex:spatialRelation [
        rdfs:label "illuminated by" ;
        ex:target ex:img8_obj_6
    ] ;
    ex:spatialRelation [
        rdfs:label "surrounded by" ;
        ex:target ex:img8_obj_9
    ] .


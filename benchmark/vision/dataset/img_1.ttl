# =============================================================================
# Image-level metadata
# =============================================================================

ex:img_1
    a schema:ImageObject ;
    schema:description "Interior view of an old, abandoned, rusted truck cab overgrown with vegetation. The steering wheel, dashboard, and windshield are visible, with lush green bushes and a large tree seen through the glass and open cabin sides." ;
    schema:keywords "abandoned truck, rusted vehicle, steering wheel, dashboard, windshield, overgrown, vegetation, decay, nature reclaiming, derelict, old truck interior" ;
    schema:contentLocation "outdoor rural or wooded area" ;
    ex:dominantColors "green, brown, rust orange, grey" ;
    ex:mood "melancholic, nature reclaiming" ;
    ex:lightingCondition "natural daylight, overcast or filtered through canopy" ;
    ex:photographicStyle "close-up interior shot, shallow to moderate depth of field" ;
    ex:hasObject ex:img1_obj_1 , ex:img1_obj_2 , ex:img1_obj_3 , ex:img1_obj_4 ,
                 ex:img1_obj_5 , ex:img1_obj_6 , ex:img1_obj_7 , ex:img1_obj_8 ,
                 ex:img1_obj_9 , ex:img1_obj_10 , ex:img1_obj_11 , ex:img1_obj_12 ,
                 ex:img1_obj_13 , ex:img1_obj_14 , ex:img1_obj_15 , ex:img1_obj_16 ,
                 ex:img1_obj_17 , ex:img1_obj_18 , ex:img1_obj_19 , ex:img1_obj_20 ,
                 ex:img1_obj_21 , ex:img1_obj_22 , ex:img1_obj_23 .


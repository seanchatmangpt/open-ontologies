    rdfs:label "slope" ;
    skos:altLabel "hillside", "incline", "gradient", "gentle slope" ;
    schema:category "nature", "landscape" ;
    schema:description "The foreground field rises on a gentle slope from lower-left toward the tree line, indicating the landscape sits on undulating terrain." ;
    ex:confidence "0.78"^^xsd:decimal ;
    ex:boundingBoxRegion "foreground, lower-left to center" ;
    schema:isPartOf ex:img4_obj_4 ;
    ex:spatialRelation [
        rdfs:label "leading up to" ;

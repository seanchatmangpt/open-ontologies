    rdfs:label "clouds" ;
    skos:altLabel "overcast", "cloud cover", "grey clouds", "cloud layer" ;
    schema:category "nature", "landscape" ;
    schema:description "A uniform layer of grey cloud cover blanketing the entire sky. No individual cloud formations are distinguishable; the cover is flat and featureless." ;
    ex:confidence "0.90"^^xsd:decimal ;
    ex:boundingBoxRegion "upper third" ;
    schema:isPartOf ex:img4_obj_1 ;
    ex:spatialRelation [

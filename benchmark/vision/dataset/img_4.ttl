# === Object 12: Landscape ===

ex:img4_obj_12 a schema:Thing ;
    rdfs:label "landscape" ;
    skos:altLabel "scenery", "countryside", "vista", "panorama", "rural landscape" ;
    schema:category "landscape", "nature" ;
    schema:description "The overall rural landscape composition comprising the grassy foreground field, the dense coniferous tree line, misty distant hills, and overcast sky. The scene conveys a moody, quiet atmosphere." ;

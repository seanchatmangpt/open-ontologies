@prefix ex: <http://example.org/image/> .
@prefix schema: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# === Image Node ===

ex:img_4 a schema:ImageObject ;
    schema:name "img_4.jpg" ;
    schema:description "A moody, overcast rural landscape showing a dense row of tall coniferous trees spanning the middle ground, with misty forested hills receding into the background and a dry grassy field in the foreground." ;
    schema:keywords "trees", "forest", "hill", "field", "sky", "grass", "mist", "landscape", "nature", "overcast", "rural", "meadow", "conifer", "pine" ;
    schema:contentLocation "rural countryside" ;
    ex:detectedObjectCount "12"^^xsd:integer ;
    schema:hasPart ex:img4_obj_1 ,
                   ex:img4_obj_2 ,
                   ex:img4_obj_3 ,
                   ex:img4_obj_4 ,
                   ex:img4_obj_5 ,
                   ex:img4_obj_6 ,
                   ex:img4_obj_7 ,
                   ex:img4_obj_8 ,
                   ex:img4_obj_9 ,
                   ex:img4_obj_10 ,
                   ex:img4_obj_11 ,
                   ex:img4_obj_12 .

# === Object 1: Sky ===

ex:img4_obj_1 a schema:Thing ;
    rdfs:label "sky" ;
    skos:altLabel "overcast sky", "grey sky", "cloudy sky", "heavens" ;
    schema:category "landscape", "nature" ;
    schema:description "A flat, grey overcast sky covering the upper third of the image. No sun, blue patches, or cloud detail is visible. The sky is uniformly pale and washed out." ;
    ex:confidence "0.97"^^xsd:decimal ;
    ex:boundingBoxRegion "upper third" ;
    ex:spatialRelation [
        rdfs:label "above" ;
        schema:spatialCoverage ex:img4_obj_2
    ] ;
    ex:spatialRelation [
        rdfs:label "above" ;
        schema:spatialCoverage ex:img4_obj_5
    ] .

# === Object 2: Trees ===

ex:img4_obj_2 a schema:Thing ;
    rdfs:label "trees" ;
    skos:altLabel "tree line", "conifers", "pines", "spruces", "evergreens", "tall trees" ;
    schema:category "nature", "forest", "landscape" ;
    schema:description "A continuous row of tall, dark coniferous trees stretching across the full width of the image in the middle ground. The trees are densely packed with visible straight bare trunks beneath the canopy." ;
    ex:confidence "0.96"^^xsd:decimal ;
    ex:boundingBoxRegion "middle band, full width" ;
    ex:spatialRelation [
        rdfs:label "below" ;
        schema:spatialCoverage ex:img4_obj_1
    ] ;
    ex:spatialRelation [
        rdfs:label "above" ;
        schema:spatialCoverage ex:img4_obj_4
    ] ;
    ex:spatialRelation [
        rdfs:label "in front of" ;
        schema:spatialCoverage ex:img4_obj_5
    ] ;
    schema:isPartOf ex:img4_obj_3 .

# === Object 3: Forest ===

ex:img4_obj_3 a schema:Thing ;
    rdfs:label "forest" ;
    skos:altLabel "woods", "woodland", "tree line", "timber", "coniferous forest", "pine forest" ;
    schema:category "nature", "forest", "landscape" ;
    schema:description "A dense coniferous forest forming a dark band across the middle of the image. The forest includes the main tree line in the middle ground and additional forested areas on the distant hills behind it." ;
    ex:confidence "0.95"^^xsd:decimal ;
    ex:boundingBoxRegion "middle band and background hills" ;
    schema:hasPart ex:img4_obj_2 ,
                   ex:img4_obj_7 ;
    ex:spatialRelation [
        rdfs:label "behind" ;
        schema:spatialCoverage ex:img4_obj_4
    ] ;
    ex:spatialRelation [
        rdfs:label "above" ;
        schema:spatialCoverage ex:img4_obj_4
    ] .

# === Object 4: Field ===

ex:img4_obj_4 a schema:Thing ;
    rdfs:label "field" ;
    skos:altLabel "meadow", "grassland", "pasture", "grassy field", "open field" ;
    schema:category "nature", "landscape" ;
    schema:description "A dry, brownish-green grassy field occupying the lower foreground, sloping gently upward toward the tree line. The grass appears short and dormant, suggesting late autumn or early spring." ;
    ex:confidence "0.95"^^xsd:decimal ;
    ex:boundingBoxRegion "lower third, foreground" ;
    ex:spatialRelation [
        rdfs:label "below" ;
        schema:spatialCoverage ex:img4_obj_2
    ] ;
    ex:spatialRelation [
        rdfs:label "in front of" ;
        schema:spatialCoverage ex:img4_obj_3
    ] ;
    schema:hasPart ex:img4_obj_6 .

# === Object 5: Hill ===

ex:img4_obj_5 a schema:Thing ;
    rdfs:label "hill" ;
    skos:altLabel "hills", "rolling hills", "forested hills", "distant hills", "ridgeline" ;
    schema:category "nature", "landscape" ;
    schema:description "Rolling hills covered in dense forest visible behind and above the main tree line. Multiple layers of hills recede into the background, partially obscured by atmospheric haze." ;
    ex:confidence "0.88"^^xsd:decimal ;
    ex:boundingBoxRegion "background, behind tree line" ;
    ex:spatialRelation [
        rdfs:label "behind" ;
        schema:spatialCoverage ex:img4_obj_2
    ] ;
    ex:spatialRelation [
        rdfs:label "below" ;
        schema:spatialCoverage ex:img4_obj_1
    ] ;
    ex:spatialRelation [
        rdfs:label "partially obscured by" ;
        schema:spatialCoverage ex:img4_obj_8
    ] .

# === Object 6: Grass ===

ex:img4_obj_6 a schema:Thing ;
    rdfs:label "grass" ;
    skos:altLabel "dry grass", "brown grass", "turf", "lawn", "dormant grass" ;
    schema:category "nature", "landscape" ;
    schema:description "Short, dry, brownish-green grass covering the foreground field. The grass appears dormant and rough, typical of late autumn or early spring in a temperate climate." ;
    ex:confidence "0.93"^^xsd:decimal ;
    ex:boundingBoxRegion "lower third, foreground surface" ;
    schema:isPartOf ex:img4_obj_4 ;
    ex:spatialRelation [
        rdfs:label "below" ;
        schema:spatialCoverage ex:img4_obj_2
    ] ;
    ex:spatialRelation [
        rdfs:label "in front of" ;
        schema:spatialCoverage ex:img4_obj_7
    ] .

# === Object 7: Tree trunks ===

ex:img4_obj_7 a schema:Thing ;
    rdfs:label "tree trunks" ;
    skos:altLabel "trunks", "bare trunks", "stems", "boles" ;
    schema:category "nature", "forest" ;
    schema:description "Bare, straight trunks of the coniferous trees visible beneath the canopy. The trunks are dark and slender, indicating mature plantation-style or naturally dense forest growth." ;
    ex:confidence "0.82"^^xsd:decimal ;
    ex:boundingBoxRegion "middle band, lower portion of tree line" ;
    schema:isPartOf ex:img4_obj_2 ,
                    ex:img4_obj_3 ;
    ex:spatialRelation [
        rdfs:label "below" ;
        schema:spatialCoverage ex:img4_obj_9
    ] ;
    ex:spatialRelation [
        rdfs:label "above" ;
        schema:spatialCoverage ex:img4_obj_4
    ] .

# === Object 8: Mist ===

ex:img4_obj_8 a schema:Thing ;
    rdfs:label "mist" ;
    skos:altLabel "haze", "fog", "atmospheric haze", "low cloud" ;
    schema:category "nature", "landscape" ;
    schema:description "A visible layer of mist or atmospheric haze between the main tree line and the distant hills, softening the background and creating depth in the landscape." ;
    ex:confidence "0.83"^^xsd:decimal ;
    ex:boundingBoxRegion "background, between tree line and hills" ;
    ex:spatialRelation [
        rdfs:label "between" ;
        schema:spatialCoverage ex:img4_obj_2 ,
                               ex:img4_obj_5
    ] ;
    ex:spatialRelation [
        rdfs:label "in front of" ;
        schema:spatialCoverage ex:img4_obj_5
    ] .

# === Object 9: Canopy ===

ex:img4_obj_9 a schema:Thing ;
    rdfs:label "canopy" ;
    skos:altLabel "tree canopy", "treetops", "crown", "foliage" ;
    schema:category "nature", "forest" ;
    schema:description "The dark, dense upper canopy of the coniferous tree line forming a jagged silhouette against the overcast sky. The canopy is continuous and darkly coloured." ;
    ex:confidence "0.85"^^xsd:decimal ;
    ex:boundingBoxRegion "upper portion of tree line" ;
    schema:isPartOf ex:img4_obj_2 ;
    ex:spatialRelation [

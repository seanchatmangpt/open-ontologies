    rdfs:label "Frog" ;
    skos:altLabel "toad" , "amphibian" , "tree frog" , "bullfrog" ;
    schema:category "animal" ;
    schema:description "A frog partially submerged in water, heavily covered with duckweed providing natural camouflage. Only the top of its head and bulging eyes protrude above the water surface. The frog's skin is textured and bumpy, blending seamlessly with the surrounding duckweed." ;
    ex:confidence "0.95"^^xsd:decimal ;
    ex:boundingBoxRegion "center of frame" ;
    ex:spatialRelation [
        rdfs:label "centered in" ;
        schema:targetObject ex:img3_obj_12 ;

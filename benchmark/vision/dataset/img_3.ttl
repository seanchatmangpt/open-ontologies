# === Image node ===
ex:img_3
    rdf:type schema:ImageObject ;
    rdfs:label "Frog camouflaged in duckweed-covered pond" ;
    schema:description "A frog partially submerged in still pond water densely covered with duckweed. The frog is heavily camouflaged by duckweed clinging to its head and body, with only its prominent bulging eyes and the top of its head clearly visible above the green-carpeted water surface. A small dark insect is visible on the duckweed near the frog." ;
    schema:keywords "frog, duckweed, camouflage, pond, wildlife, amphibian, green, water surface, macro photography, nature, aquatic" ;
    schema:contentUrl "img_3.jpg" ;
    ex:scene "frog camouflaged in duckweed pond" ;
    ex:dominantColors "green, dark green, brown, black" ;
    ex:mood "serene, hidden, natural camouflage" ;
    ex:lightingCondition "natural daylight, diffused, overcast" ;
    ex:photographicStyle "close-up wildlife photography, shallow depth of field" ;
    schema:hasPart ex:img3_obj_1 ,
                   ex:img3_obj_2 ,
                   ex:img3_obj_3 ,
                   ex:img3_obj_4 ,
                   ex:img3_obj_5 ,
                   ex:img3_obj_6 ,
                   ex:img3_obj_7 ,
                   ex:img3_obj_8 ,
                   ex:img3_obj_9 ,
                   ex:img3_obj_10 ,
                   ex:img3_obj_11 ,
                   ex:img3_obj_12 ,
                   ex:img3_obj_13 .

# === Object 1: Frog ===
ex:img3_obj_1

@prefix ex:     <http://example.org/image/> .
@prefix schema: <http://schema.org/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# === Image Node ===
ex:img_6
    a                schema:ImageObject ;
    rdfs:label       "Two paddlers in a canoe on misty calm water" ;
    schema:description "Two people sitting in a canoe on very calm, teal-green water in foggy conditions, with their reflections clearly visible on the water surface" ;
    schema:keywords  "canoe" , "paddling" , "mist" , "fog" , "calm water" , "reflection" ;
    ex:hasObject     ex:img6_obj_1 , ex:img6_obj_2 , ex:img6_obj_3 ,
                     ex:img6_obj_4 , ex:img6_obj_5 , ex:img6_obj_6 ,
                     ex:img6_obj_7 , ex:img6_obj_8 , ex:img6_obj_9 ,
                     ex:img6_obj_10 , ex:img6_obj_11 , ex:img6_obj_12 .

# === Object 1: Canoe ===
ex:img6_obj_1
    a                schema:Thing ;
    rdfs:label       "canoe"@en ;
    skos:altLabel    "boat"@en , "watercraft"@en , "vessel"@en ;
    schema:category  "watercraft" ;
    ex:confidence    "0.98"^^xsd:decimal ;
    ex:color         "green" ;
    ex:position      "center" ;
    ex:contains      ex:img6_obj_2 , ex:img6_obj_3 .

# === Object 2: Front paddler ===
ex:img6_obj_2
    a                schema:Person ;
    rdfs:label       "front paddler"@en ;
    skos:altLabel    "bow paddler"@en , "forward canoeist"@en ;
    schema:category  "person" ;
    ex:confidence    "0.95"^^xsd:decimal ;
    ex:position      "center-left" ;
    ex:action        "paddling" ;
    ex:holds         ex:img6_obj_5 ;
    ex:sitsIn        ex:img6_obj_1 ;
    ex:inFrontOf     ex:img6_obj_3 .

# === Object 3: Rear paddler ===
ex:img6_obj_3
    a                schema:Person ;
    rdfs:label       "rear paddler"@en ;
    skos:altLabel    "stern paddler"@en , "rear canoeist"@en ;
    schema:category  "person" ;
    ex:confidence    "0.95"^^xsd:decimal ;
    ex:position      "center-right" ;
    ex:action        "sitting" ;
    ex:sitsIn        ex:img6_obj_1 ;
    ex:behind        ex:img6_obj_2 .

# === Object 4: People (general group) ===
ex:img6_obj_4
    a                schema:Thing ;
    rdfs:label       "people"@en ;
    skos:altLabel    "paddlers"@en , "canoeists"@en , "persons"@en ;
    schema:category  "group" ;
    ex:confidence    "0.97"^^xsd:decimal ;
    ex:memberCount   "2"^^xsd:integer ;
    ex:hasMember     ex:img6_obj_2 , ex:img6_obj_3 ;
    ex:onTopOf       ex:img6_obj_1 .

# === Object 5: Paddle ===
ex:img6_obj_5
    a                schema:Thing ;
    rdfs:label       "paddle"@en ;
    skos:altLabel    "oar"@en , "canoe paddle"@en ;
    schema:category  "equipment" ;
    ex:confidence    "0.96"^^xsd:decimal ;
    ex:color         "orange blade with dark shaft" ;
    ex:position      "center-left" ;
    ex:heldBy        ex:img6_obj_2 .

# === Object 6: Water ===
ex:img6_obj_6
    a                schema:Thing ;
    rdfs:label       "water"@en ;
    skos:altLabel    "lake"@en , "calm water"@en , "body of water"@en ;
    schema:category  "natural element" ;
    ex:confidence    "0.99"^^xsd:decimal ;
    ex:color         "teal-green" ;
    ex:state         "calm" ;
    ex:position      "foreground and below" ;
    ex:supports      ex:img6_obj_1 ;
    ex:reflects      ex:img6_obj_1 , ex:img6_obj_2 , ex:img6_obj_3 .

# === Object 7: Mist / Fog ===
ex:img6_obj_7
    a                schema:Thing ;
    rdfs:label       "mist"@en ;
    skos:altLabel    "fog"@en , "haze"@en ;
    schema:category  "weather condition" ;
    ex:confidence    "0.97"^^xsd:decimal ;
    ex:position      "background" ;
    ex:obscures      ex:img6_obj_9 ;
    ex:surrounds     ex:img6_obj_1 , ex:img6_obj_2 , ex:img6_obj_3 .

# === Object 8: Reflection ===
ex:img6_obj_8
    a                schema:Thing ;
    rdfs:label       "reflection"@en ;
    skos:altLabel    "water reflection"@en , "mirror image"@en ;
    schema:category  "visual phenomenon" ;
    ex:confidence    "0.94"^^xsd:decimal ;
    ex:position      "below center" ;
    ex:reflectionOf  ex:img6_obj_1 , ex:img6_obj_2 , ex:img6_obj_3 ;
    ex:visibleOn     ex:img6_obj_6 .

# === Object 9: Sky ===
ex:img6_obj_9
    a                schema:Thing ;
    rdfs:label       "sky"@en ;
    skos:altLabel    "overcast sky"@en , "foggy sky"@en ;
    schema:category  "natural element" ;
    ex:confidence    "0.90"^^xsd:decimal ;
    ex:color         "grey-white" ;
    ex:state         "overcast" ;
    ex:position      "top" ;
    ex:above         ex:img6_obj_6 .

# === Object 10: Horizon ===
ex:img6_obj_10
    a                schema:Thing ;
    rdfs:label       "horizon"@en ;
    skos:altLabel    "horizon line"@en , "waterline"@en ;
    schema:category  "spatial feature" ;
    ex:confidence    "0.85"^^xsd:decimal ;
    ex:position      "center background" ;
    ex:obscuredBy    ex:img6_obj_7 ;
    ex:separates     ex:img6_obj_6 , ex:img6_obj_9 .

# === Object 11: Outdoor clothing ===
ex:img6_obj_11
    a                schema:Thing ;
    rdfs:label       "outdoor clothing"@en ;
    skos:altLabel    "jackets"@en , "rain gear"@en , "waterproof clothing"@en ;
    schema:category  "clothing" ;
    ex:confidence    "0.92"^^xsd:decimal ;
    ex:color         "teal-green" ;
    ex:wornBy        ex:img6_obj_2 , ex:img6_obj_3 .

# === Object 12: Hats ===
ex:img6_obj_12
    a                schema:Thing ;
    rdfs:label       "hat"@en ;
    skos:altLabel    "cap"@en , "headwear"@en ;
    schema:category  "clothing" ;
    ex:confidence    "0.88"^^xsd:decimal ;
    ex:wornBy        ex:img6_obj_2 , ex:img6_obj_3 .

# === Spatial relationships ===
ex:img6_obj_1  ex:floatsOn     ex:img6_obj_6 .
ex:img6_obj_1  ex:surroundedBy ex:img6_obj_7 .
ex:img6_obj_2  ex:leftOf       ex:img6_obj_3 .
ex:img6_obj_3  ex:rightOf      ex:img6_obj_2 .
ex:img6_obj_5  ex:above        ex:img6_obj_6 .
ex:img6_obj_7  ex:above        ex:img6_obj_6 .

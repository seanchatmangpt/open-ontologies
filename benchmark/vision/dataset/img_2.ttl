# === Image node ===
ex:img_2
    a schema:ImageObject ;
    schema:description "A top-down photograph of a creative workspace on a warm-toned wooden desk, featuring an open Apple MacBook Air laptop, an open grid notebook with handwritten notes and wireframe sketches, a black pen, white wired earphones, and a vintage silver camera." ;
    schema:keywords "desk, laptop, notebook, pen, camera, earphones, workspace, wooden table, flat lay, top view, creative workspace, stationery, MacBook, vintage camera, wireframe, sketches, handwriting" ;
    ex:viewpoint "top-down" ;
    ex:containsObject ex:img2_obj_1 , ex:img2_obj_2 , ex:img2_obj_3 , ex:img2_obj_4 , ex:img2_obj_5 , ex:img2_obj_6 , ex:img2_obj_7 , ex:img2_obj_8 , ex:img2_obj_9 , ex:img2_obj_10 , ex:img2_obj_11 , ex:img2_obj_12 .


    ex:shape "cylindrical" ;
    ex:condition "blurred" , "out of focus" ;
    ex:regionBox "0.45,0.18,0.58,0.35" ;
    ex:spatialRelation [ a ex:SpatialRelation ;
        ex:relation "among" ;
        ex:relatedObject ex:img5_obj_8 ] ,
      [ a ex:SpatialRelation ;
        ex:relation "taller than" ;
        ex:relatedObject ex:img5_obj_8 ] ,
      [ a ex:SpatialRelation ;
        ex:relation "in the distance behind" ;
        ex:relatedObject ex:img5_obj_1 ] .


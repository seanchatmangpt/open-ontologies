    rdfs:label "tower" ;
    skos:altLabel "cylindrical tower" , "round tower" , "water tower" , "observation tower" , "tall structure" , "silo" ;
    schema:category "building" , "architecture" , "landmark" , "structure" ;
    schema:description "A cylindrical or round tower rising above the other buildings in the background, slightly right of center, appearing grey or tan." ;

@prefix ex: <http://example.org/image/> .
@prefix schema: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# === Image node ===

ex:img_5 a schema:ImageObject ;
    schema:name "Low-angle boardwalk photograph with buildings in background" ;
    schema:description "A close-up, low-angle photograph taken from the surface of a wooden boardwalk. Weathered wood planks recede into the distance under a clear blue sky. Blurred buildings and a cylindrical tower are visible in the background." ;
    schema:keywords "boardwalk, wooden deck, planks, sky, buildings, tower, shallow depth of field, outdoor, waterfront" ;
    schema:contentUrl "img_5.jpg" ;
    ex:hasObject ex:img5_obj_1 , ex:img5_obj_2 , ex:img5_obj_3 , ex:img5_obj_4 ,
                 ex:img5_obj_5 , ex:img5_obj_6 , ex:img5_obj_7 , ex:img5_obj_8 ,
                 ex:img5_obj_9 , ex:img5_obj_10 , ex:img5_obj_11 , ex:img5_obj_12 ,
                 ex:img5_obj_13 , ex:img5_obj_14 , ex:img5_obj_15 , ex:img5_obj_16 ,
                 ex:img5_obj_17 , ex:img5_obj_18 ;
    ex:dominantColors "tan, light brown, sky blue" ;
    ex:photographicTechnique "low-angle close-up with shallow depth of field" ;
    ex:setting "outdoor, waterfront area" ;
    ex:timeOfDay "daytime" ;
    ex:weather "clear" .

# === Object 1: Boardwalk ===

ex:img5_obj_1 a schema:Thing ;
    rdfs:label "boardwalk" ;
    skos:altLabel "walkway" , "promenade" , "pier" , "wooden walkway" , "waterfront boardwalk" , "deck" ;
    schema:category "structure" , "walkway" , "outdoor structure" ;
    schema:description "A long wooden boardwalk stretching into the distance, made of weathered planks, occupying the lower two-thirds of the image." ;
    ex:confidence "0.97"^^xsd:float ;
    ex:material "wood" ;
    ex:condition "weathered" ;
    ex:dominatesFrame true ;
    ex:regionBox "0.0,0.35,1.0,1.0" ;
    ex:hasPart ex:img5_obj_2 , ex:img5_obj_3 , ex:img5_obj_4 , ex:img5_obj_5 .

# === Object 2: Wood planks ===

ex:img5_obj_2 a schema:Thing ;
    rdfs:label "wood planks" ;
    skos:altLabel "wooden planks" , "deck boards" , "timber planks" , "lumber" , "floorboards" , "plank flooring" , "boards" ;
    schema:category "building material" , "material" , "surface" ;
    schema:description "Individual wooden planks running in parallel lines forming the boardwalk surface, showing natural grain patterns, cracks, and weathering." ;
    ex:confidence "0.98"^^xsd:float ;
    ex:material "wood" ;
    ex:condition "weathered" , "aged" , "cracked" ;
    ex:texture "rough" , "grainy" ;
    ex:color "tan" , "light brown" , "grey-brown" ;
    ex:isPartOf ex:img5_obj_1 .

# === Object 3: Gaps between planks ===

ex:img5_obj_3 a schema:Thing ;
    rdfs:label "gaps between planks" ;
    skos:altLabel "plank gaps" , "board gaps" , "cracks" , "spaces between boards" , "seams" ;
    schema:category "structural feature" , "detail" ;
    schema:description "Narrow gaps running between the individual wood planks, visible as dark lines across the boardwalk surface." ;
    ex:confidence "0.92"^^xsd:float ;
    ex:isPartOf ex:img5_obj_1 ;
    ex:spatialRelation [ a ex:SpatialRelation ;
        ex:relation "between" ;
        ex:relatedObject ex:img5_obj_2 ] .

# === Object 4: Wood grain ===

ex:img5_obj_4 a schema:Thing ;
    rdfs:label "wood grain" ;
    skos:altLabel "grain pattern" , "wood texture" , "grain lines" , "timber grain" ;
    schema:category "texture" , "surface detail" , "natural pattern" ;
    schema:description "Visible natural grain patterns in the wood planks, running lengthwise along each board." ;
    ex:confidence "0.90"^^xsd:float ;
    ex:isPartOf ex:img5_obj_2 .

# === Object 5: Debris on surface ===

ex:img5_obj_5 a schema:Thing ;
    rdfs:label "debris" ;
    skos:altLabel "wood chips" , "splinters" , "fragments" , "dirt" , "grit" , "small particles" ;
    schema:category "debris" , "detail" ;
    schema:description "Small bits of debris, wood chips, and grit scattered on the surface of the boardwalk planks." ;
    ex:confidence "0.80"^^xsd:float ;
    ex:isPartOf ex:img5_obj_1 ;
    ex:spatialRelation [ a ex:SpatialRelation ;
        ex:relation "on top of" ;
        ex:relatedObject ex:img5_obj_2 ] .

# === Object 6: Sky ===

ex:img5_obj_6 a schema:Thing ;
    rdfs:label "sky" ;
    skos:altLabel "blue sky" , "clear sky" , "daytime sky" , "open sky" ;
    schema:category "natural element" , "atmosphere" , "background" ;
    schema:description "Clear blue sky occupying the upper portion of the image, gradient from light blue near the horizon to deeper blue above." ;
    ex:confidence "0.99"^^xsd:float ;
    ex:color "blue" , "light blue" , "sky blue" ;
    ex:condition "clear" , "cloudless" ;
    ex:regionBox "0.0,0.0,1.0,0.35" ;
    ex:spatialRelation [ a ex:SpatialRelation ;
        ex:relation "above" ;
        ex:relatedObject ex:img5_obj_1 ] .

# === Object 7: Horizon line ===

ex:img5_obj_7 a schema:Thing ;
    rdfs:label "horizon" ;
    skos:altLabel "horizon line" , "skyline" , "sky line" ;
    schema:category "visual boundary" , "scene element" ;
    schema:description "The horizon line where the boardwalk surface meets the sky, positioned in the upper third of the image." ;
    ex:confidence "0.93"^^xsd:float ;
    ex:regionBox "0.0,0.30,1.0,0.38" ;
    ex:spatialRelation [ a ex:SpatialRelation ;
        ex:relation "separates" ;
        ex:relatedObject ex:img5_obj_6 ] ,
      [ a ex:SpatialRelation ;
        ex:relation "separates" ;
        ex:relatedObject ex:img5_obj_1 ] .

# === Object 8: Buildings ===

ex:img5_obj_8 a schema:Thing ;
    rdfs:label "buildings" ;
    skos:altLabel "structures" , "constructions" , "edifices" , "built structures" , "background buildings" ;
    schema:category "building" , "architecture" , "structure" ;
    schema:description "Several blurred buildings visible along the horizon in the background, including low-rise structures typical of a waterfront or coastal area." ;
    ex:confidence "0.82"^^xsd:float ;
    ex:condition "blurred" , "out of focus" ;
    ex:regionBox "0.05,0.25,0.95,0.38" ;
    ex:spatialRelation [ a ex:SpatialRelation ;
        ex:relation "behind" ;
        ex:relatedObject ex:img5_obj_1 ] ,
      [ a ex:SpatialRelation ;
        ex:relation "below" ;
        ex:relatedObject ex:img5_obj_6 ] ,
      [ a ex:SpatialRelation ;
        ex:relation "along" ;
        ex:relatedObject ex:img5_obj_7 ] .


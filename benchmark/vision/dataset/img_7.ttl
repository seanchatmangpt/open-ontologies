# ── Image node ──────────────────────────────────────────────────────────
ex:img_7
    rdf:type        schema:ImageObject ;
    rdfs:label      "Aerial view of coastal landscape with ocean, beach, cliffs and residential areas" ;
    schema:description "Bird's-eye aerial photograph looking down at a curved coastline where turquoise-to-deep-blue ocean meets a sandy beach, backed by eroded coastal bluffs, residential developments, and scattered vegetation." ;
    schema:contentLocation "Southern California coast" ;
    ex:viewpoint    "aerial" ;
    ex:hasObject    ex:img7_obj_1 , ex:img7_obj_2 , ex:img7_obj_3 ,
                    ex:img7_obj_4 , ex:img7_obj_5 , ex:img7_obj_6 ,
                    ex:img7_obj_7 , ex:img7_obj_8 , ex:img7_obj_9 ,
                    ex:img7_obj_10 , ex:img7_obj_11 , ex:img7_obj_12 ,
                    ex:img7_obj_13 , ex:img7_obj_14 , ex:img7_obj_15 ,
                    ex:img7_obj_16 , ex:img7_obj_17 , ex:img7_obj_18 ,
                    ex:img7_obj_19 , ex:img7_obj_20 .

# ── obj 1: Ocean ────────────────────────────────────────────────────────
ex:img7_obj_1
    rdf:type        schema:BodyOfWater ;
    rdfs:label      "Ocean"@en ;
    skos:altLabel   "sea"@en , "open water"@en , "Pacific Ocean"@en ;
    schema:category "water body" ;
    ex:confidence   "0.98"^^xsd:decimal ;
    ex:dominantColor "deep blue, turquoise" ;
    ex:spatialRegion "lower-left and lower-right, occupying roughly half the image" ;
    ex:adjacentTo   ex:img7_obj_2 , ex:img7_obj_3 ;
    ex:contains     ex:img7_obj_16 .


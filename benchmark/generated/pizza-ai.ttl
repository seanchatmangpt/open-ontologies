@prefix : <http://www.co-ode.org/ontologies/pizza/pizza.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Pizza Ontology — AI-generated following Manchester tutorial specification
# Generated by Claude via Open Ontologies (AI-native approach)
# =============================================================================

<http://www.co-ode.org/ontologies/pizza/pizza.owl>
    a owl:Ontology ;
    rdfs:label "AI-Generated Pizza Ontology" ;
    rdfs:comment "Pizza ontology generated by Claude following the Manchester Pizza tutorial specification. Covers the same domain as the reference ontology using AI-native modeling." .

# =============================================================================
# Object Properties
# =============================================================================

:hasIngredient a owl:ObjectProperty ;
    rdfs:label "has ingredient" ;
    rdfs:comment "Links a food item to its ingredients" ;
    rdfs:domain :Food ;
    rdfs:range :Food ;
    owl:inverseOf :isIngredientOf .

:isIngredientOf a owl:ObjectProperty ;
    rdfs:label "is ingredient of" ;
    rdfs:comment "Inverse of hasIngredient" ;
    rdfs:domain :Food ;
    rdfs:range :Food ;
    owl:inverseOf :hasIngredient .

:hasTopping a owl:ObjectProperty ;
    rdfs:label "has topping" ;
    rdfs:subPropertyOf :hasIngredient ;
    rdfs:domain :Pizza ;
    rdfs:range :PizzaTopping ;
    owl:inverseOf :isToppingOf .

:isToppingOf a owl:ObjectProperty ;
    rdfs:label "is topping of" ;
    rdfs:subPropertyOf :isIngredientOf ;
    rdfs:domain :PizzaTopping ;
    rdfs:range :Pizza ;
    owl:inverseOf :hasTopping .

:hasBase a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "has base" ;
    rdfs:subPropertyOf :hasIngredient ;
    rdfs:domain :Pizza ;
    rdfs:range :PizzaBase ;
    owl:inverseOf :isBaseOf .

:isBaseOf a owl:ObjectProperty ;
    rdfs:label "is base of" ;
    rdfs:subPropertyOf :isIngredientOf ;
    rdfs:domain :PizzaBase ;
    rdfs:range :Pizza ;
    owl:inverseOf :hasBase .

:hasSpiciness a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "has spiciness" ;
    rdfs:domain :PizzaTopping ;
    rdfs:range :Spiciness .

:hasCountryOfOrigin a owl:ObjectProperty ;
    rdfs:label "has country of origin" ;
    rdfs:domain :Food .

# =============================================================================
# Top-level Classes
# =============================================================================

:DomainConcept a owl:Class ;
    rdfs:label "Domain Concept" ;
    rdfs:comment "Top-level class for all pizza domain concepts" .

:Food a owl:Class ;
    rdfs:subClassOf :DomainConcept ;
    rdfs:label "Food" .

:Pizza a owl:Class ;
    rdfs:subClassOf :Food ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasBase ;
        owl:someValuesFrom :PizzaBase ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :PizzaTopping ] ;
    rdfs:label "Pizza" ;
    rdfs:comment "A food item consisting of a base and toppings" .

:IceCream a owl:Class ;
    rdfs:subClassOf :Food ;
    rdfs:label "Ice Cream" ;
    owl:disjointWith :Pizza .

# =============================================================================
# Pizza Base Classes
# =============================================================================

:PizzaBase a owl:Class ;
    rdfs:subClassOf :Food ;
    rdfs:label "Pizza Base" .

:DeepPanBase a owl:Class ;
    rdfs:subClassOf :PizzaBase ;
    rdfs:label "Deep Pan Base" ;
    owl:disjointWith :ThinAndCrispyBase .

:ThinAndCrispyBase a owl:Class ;
    rdfs:subClassOf :PizzaBase ;
    rdfs:label "Thin and Crispy Base" ;
    owl:disjointWith :DeepPanBase .

# =============================================================================
# Spiciness Value Partition
# =============================================================================

:ValuePartition a owl:Class ;
    rdfs:subClassOf :DomainConcept ;
    rdfs:label "Value Partition" .

:Spiciness a owl:Class ;
    rdfs:subClassOf :ValuePartition ;
    owl:equivalentClass [ a owl:Class ;
        owl:unionOf ( :Hot :Medium :Mild ) ] ;
    rdfs:label "Spiciness" .

:Hot a owl:Class ;
    rdfs:subClassOf :Spiciness ;
    rdfs:label "Hot" ;
    owl:disjointWith :Medium, :Mild .

:Medium a owl:Class ;
    rdfs:subClassOf :Spiciness ;
    rdfs:label "Medium" ;
    owl:disjointWith :Hot, :Mild .

:Mild a owl:Class ;
    rdfs:subClassOf :Spiciness ;
    rdfs:label "Mild" ;
    owl:disjointWith :Hot, :Medium .

# =============================================================================
# Pizza Topping Hierarchy
# =============================================================================

:PizzaTopping a owl:Class ;
    rdfs:subClassOf :Food ;
    rdfs:label "Pizza Topping" .

# --- Cheese Toppings ---

:CheeseTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Mild ] ;
    rdfs:label "Cheese Topping" ;
    owl:disjointWith :FishTopping, :FruitTopping, :HerbSpiceTopping,
        :MeatTopping, :NutTopping, :SauceTopping, :VegetableTopping .

:MozzarellaTopping a owl:Class ;
    rdfs:subClassOf :CheeseTopping ;
    rdfs:label "Mozzarella Topping" ;
    owl:disjointWith :ParmesanTopping, :GorgonzolaTopping, :GoatsCheeseTopping, :FourCheesesTopping .

:ParmesanTopping a owl:Class ;
    rdfs:subClassOf :CheeseTopping ;
    rdfs:label "Parmesan Topping" ;
    owl:disjointWith :MozzarellaTopping, :GorgonzolaTopping, :GoatsCheeseTopping, :FourCheesesTopping .

:GorgonzolaTopping a owl:Class ;
    rdfs:subClassOf :CheeseTopping ;
    rdfs:label "Gorgonzola Topping" ;
    owl:disjointWith :MozzarellaTopping, :ParmesanTopping, :GoatsCheeseTopping, :FourCheesesTopping .

:GoatsCheeseTopping a owl:Class ;
    rdfs:subClassOf :CheeseTopping ;
    rdfs:label "Goats Cheese Topping" ;
    owl:disjointWith :MozzarellaTopping, :ParmesanTopping, :GorgonzolaTopping, :FourCheesesTopping .

:FourCheesesTopping a owl:Class ;
    rdfs:subClassOf :CheeseTopping ;
    rdfs:label "Four Cheeses Topping" ;
    owl:disjointWith :MozzarellaTopping, :ParmesanTopping, :GorgonzolaTopping, :GoatsCheeseTopping .

# --- Meat Toppings ---

:MeatTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Mild ] ;
    rdfs:label "Meat Topping" ;
    owl:disjointWith :CheeseTopping, :FishTopping, :FruitTopping,
        :HerbSpiceTopping, :NutTopping, :SauceTopping, :VegetableTopping .

:HamTopping a owl:Class ;
    rdfs:subClassOf :MeatTopping ;
    rdfs:label "Ham Topping" ;
    owl:disjointWith :PeperoniSausageTopping, :ChickenTopping, :HotSpicedBeefTopping, :ParmaHamTopping .

:PeperoniSausageTopping a owl:Class ;
    rdfs:subClassOf :MeatTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Medium ] ;
    rdfs:label "Peperoni Sausage Topping" ;
    owl:disjointWith :HamTopping, :ChickenTopping, :HotSpicedBeefTopping, :ParmaHamTopping .

:ChickenTopping a owl:Class ;
    rdfs:subClassOf :MeatTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Mild ] ;
    rdfs:label "Chicken Topping" ;
    owl:disjointWith :HamTopping, :PeperoniSausageTopping, :HotSpicedBeefTopping, :ParmaHamTopping .

:HotSpicedBeefTopping a owl:Class ;
    rdfs:subClassOf :MeatTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Hot ] ;
    rdfs:label "Hot Spiced Beef Topping" ;
    owl:disjointWith :HamTopping, :PeperoniSausageTopping, :ChickenTopping, :ParmaHamTopping .

:ParmaHamTopping a owl:Class ;
    rdfs:subClassOf :MeatTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Mild ] ;
    rdfs:label "Parma Ham Topping" ;
    owl:disjointWith :HamTopping, :PeperoniSausageTopping, :ChickenTopping, :HotSpicedBeefTopping .

# --- Fish Toppings ---

:FishTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Fish Topping" ;
    owl:disjointWith :CheeseTopping, :FruitTopping, :HerbSpiceTopping,
        :MeatTopping, :NutTopping, :SauceTopping, :VegetableTopping .

:AnchoviesTopping a owl:Class ;
    rdfs:subClassOf :FishTopping ;
    rdfs:label "Anchovies Topping" ;
    owl:disjointWith :PrawnsTopping, :MixedSeafoodTopping .

:PrawnsTopping a owl:Class ;
    rdfs:subClassOf :FishTopping ;
    rdfs:label "Prawns Topping" ;
    owl:disjointWith :AnchoviesTopping, :MixedSeafoodTopping .

:MixedSeafoodTopping a owl:Class ;
    rdfs:subClassOf :FishTopping ;
    rdfs:label "Mixed Seafood Topping" ;
    owl:disjointWith :AnchoviesTopping, :PrawnsTopping .

# --- Vegetable Toppings ---

:VegetableTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Mild ] ;
    rdfs:label "Vegetable Topping" ;
    owl:disjointWith :CheeseTopping, :FishTopping, :FruitTopping,
        :HerbSpiceTopping, :MeatTopping, :NutTopping, :SauceTopping .

:TomatoTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Tomato Topping" ;
    owl:disjointWith :MushroomTopping, :OnionTopping, :PepperTopping,
        :OliveTopping, :CaperTopping, :ArtichokeTopping, :SpinachTopping,
        :RocketTopping, :GarlicTopping, :LeekTopping, :PetitPoisTopping,
        :AsparagusTopping, :SlicedTomatoTopping, :SundriedTomatoTopping .

:SlicedTomatoTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Sliced Tomato Topping" ;
    owl:disjointWith :TomatoTopping .

:SundriedTomatoTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Medium ] ;
    rdfs:label "Sundried Tomato Topping" ;
    owl:disjointWith :TomatoTopping .

:MushroomTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Mushroom Topping" ;
    owl:disjointWith :TomatoTopping, :OnionTopping, :PepperTopping, :OliveTopping .

:OnionTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Onion Topping" ;
    owl:disjointWith :TomatoTopping, :MushroomTopping .

:RedOnionTopping a owl:Class ;
    rdfs:subClassOf :OnionTopping ;
    rdfs:label "Red Onion Topping" .

:PepperTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Pepper Topping" ;
    owl:disjointWith :TomatoTopping, :MushroomTopping, :OnionTopping, :OliveTopping .

:GreenPepperTopping a owl:Class ;
    rdfs:subClassOf :PepperTopping ;
    rdfs:label "Green Pepper Topping" ;
    owl:disjointWith :SweetPepperTopping, :JalapenoPepperTopping .

:SweetPepperTopping a owl:Class ;
    rdfs:subClassOf :PepperTopping ;
    rdfs:label "Sweet Pepper Topping" ;
    owl:disjointWith :GreenPepperTopping, :JalapenoPepperTopping .

:JalapenoPepperTopping a owl:Class ;
    rdfs:subClassOf :PepperTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Hot ] ;
    rdfs:label "Jalapeno Pepper Topping" ;
    owl:disjointWith :GreenPepperTopping, :SweetPepperTopping .

:HotGreenPepperTopping a owl:Class ;
    rdfs:subClassOf :GreenPepperTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Hot ] ;
    rdfs:label "Hot Green Pepper Topping" .

:OliveTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Olive Topping" ;
    owl:disjointWith :TomatoTopping, :MushroomTopping, :PepperTopping .

:CaperTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Caper Topping" .

:ArtichokeTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Artichoke Topping" .

:SpinachTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Spinach Topping" .

:RocketTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Rocket Topping" .

:GarlicTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Garlic Topping" .

:LeekTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Leek Topping" .

:PetitPoisTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Petit Pois Topping" .

:AsparagusTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Asparagus Topping" .

:PeperonataTopping a owl:Class ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Medium ] ;
    rdfs:label "Peperonata Topping" .

# --- Herb/Spice Toppings ---

:HerbSpiceTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Herb Spice Topping" ;
    owl:disjointWith :CheeseTopping, :FishTopping, :FruitTopping,
        :MeatTopping, :NutTopping, :SauceTopping, :VegetableTopping .

:CajunSpiceTopping a owl:Class ;
    rdfs:subClassOf :HerbSpiceTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Hot ] ;
    rdfs:label "Cajun Spice Topping" ;
    owl:disjointWith :RosemaryTopping .

:RosemaryTopping a owl:Class ;
    rdfs:subClassOf :HerbSpiceTopping ;
    rdfs:label "Rosemary Topping" ;
    owl:disjointWith :CajunSpiceTopping .

# --- Sauce Toppings ---

:SauceTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Sauce Topping" ;
    owl:disjointWith :CheeseTopping, :FishTopping, :FruitTopping,
        :HerbSpiceTopping, :MeatTopping, :NutTopping, :VegetableTopping .

:TobascoPepperSauce a owl:Class ;
    rdfs:subClassOf :SauceTopping ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasSpiciness ;
        owl:someValuesFrom :Hot ] ;
    rdfs:label "Tobasco Pepper Sauce" .

# --- Fruit Toppings ---

:FruitTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Fruit Topping" ;
    owl:disjointWith :CheeseTopping, :FishTopping, :HerbSpiceTopping,
        :MeatTopping, :NutTopping, :SauceTopping, :VegetableTopping .

:SultanaTopping a owl:Class ;
    rdfs:subClassOf :FruitTopping ;
    rdfs:label "Sultana Topping" .

# --- Nut Toppings ---

:NutTopping a owl:Class ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Nut Topping" ;
    owl:disjointWith :CheeseTopping, :FishTopping, :FruitTopping,
        :HerbSpiceTopping, :MeatTopping, :SauceTopping, :VegetableTopping .

:PineKernels a owl:Class ;
    rdfs:subClassOf :NutTopping ;
    rdfs:label "Pine Kernels" .

# =============================================================================
# Named Pizza Classes (with topping restrictions)
# =============================================================================

:NamedPizza a owl:Class ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Named Pizza" .

:Margherita a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:allValuesFrom [ a owl:Class ;
            owl:unionOf ( :TomatoTopping :MozzarellaTopping ) ] ] ;
    rdfs:label "Margherita" ;
    owl:disjointWith :American, :AmericanHot, :Cajun, :Capricciosa, :Caprina,
        :Fiorentina, :FourSeasons, :FruttiDiMare, :Giardiniera, :LaReine,
        :Mushroom, :Napoletana, :Parmense, :PolloAdAstra, :PrinceCarlo,
        :QuattroFormaggi, :Rosa, :Siciliana, :SloppyGiuseppe, :Soho, :Veneziana .

:American a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :PeperoniSausageTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:allValuesFrom [ a owl:Class ;
            owl:unionOf ( :TomatoTopping :MozzarellaTopping :PeperoniSausageTopping ) ] ] ;
    rdfs:label "American" .

:AmericanHot a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :PeperoniSausageTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :JalapenoPepperTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:allValuesFrom [ a owl:Class ;
            owl:unionOf ( :TomatoTopping :MozzarellaTopping :PeperoniSausageTopping :JalapenoPepperTopping ) ] ] ;
    rdfs:label "American Hot" .

:Cajun a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :OnionTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :PeperoniSausageTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :CajunSpiceTopping ] ;
    rdfs:label "Cajun" .

:Capricciosa a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :HamTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MushroomTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :OliveTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :AnchoviesTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :CaperTopping ] ;
    rdfs:label "Capricciosa" .

:Caprina a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :GoatsCheeseTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :SundriedTomatoTopping ] ;
    rdfs:label "Caprina" .

:Fiorentina a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :SpinachTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :OliveTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :ParmesanTopping ] ;
    rdfs:label "Fiorentina" .

:FourSeasons a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MozzarellaTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :HamTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MushroomTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :OliveTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :AnchoviesTopping ] ;
    rdfs:label "Four Seasons" .

:FruttiDiMare a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :TomatoTopping ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty :hasTopping ;
        owl:someValuesFrom :MixedSeafoodTopping ] ;
    rdfs:label "Frutti Di Mare" .

:Giardiniera a owl:Class ;
    rdfs:subClassOf :NamedPizza ;
    rdfs:subClassOf [ a owl:Restriction ;

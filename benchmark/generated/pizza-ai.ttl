# =============================================================================
# Defined Classes (OWL reasoning patterns)
# =============================================================================

:VegetarianPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( :CheeseTopping :FruitTopping :HerbSpiceTopping
                        :NutTopping :SauceTopping :VegetableTopping ) ] ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Vegetarian Pizza" ;
    rdfs:comment "A pizza that only has vegetarian toppings (no meat or fish)" .

:NonVegetarianPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( :MeatTopping :FishTopping ) ] ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Non-Vegetarian Pizza" ;
    owl:disjointWith :VegetarianPizza .

:MeatyPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:someValuesFrom :MeatTopping ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Meaty Pizza" .

:CheeseyPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:someValuesFrom :CheeseTopping ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Cheesey Pizza" .

:SpicyPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( :PizzaTopping
                        [ a owl:Restriction ;
                            owl:onProperty :hasSpiciness ;
                            owl:someValuesFrom :Hot ] ) ] ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Spicy Pizza" ;
    rdfs:comment "A pizza with at least one hot topping" .

:InterestingPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:minCardinality "3"^^xsd:nonNegativeInteger ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Interesting Pizza" ;
    rdfs:comment "A pizza with at least 3 toppings" .

:ThinAndCrispyPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasBase ;
                owl:someValuesFrom :ThinAndCrispyBase ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Thin and Crispy Pizza" .

:RealItalianPizza a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :Pizza
            [ a owl:Restriction ;
                owl:onProperty :hasBase ;
                owl:someValuesFrom :ThinAndCrispyBase ] ) ] ;
    rdfs:subClassOf :Pizza ;
    rdfs:label "Real Italian Pizza" .

# =============================================================================
# Vegetarian/Spicy helper class
# =============================================================================

:CheeseyVegetableTopping a owl:Class ;
    rdfs:subClassOf :CheeseTopping ;
    rdfs:subClassOf :VegetableTopping ;
    rdfs:label "Cheesey Vegetable Topping" .

:SpicyTopping a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :PizzaTopping
            [ a owl:Restriction ;
                owl:onProperty :hasSpiciness ;
                owl:someValuesFrom :Hot ] ) ] ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Spicy Topping" .

:VegetarianTopping a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( :PizzaTopping
            [ a owl:Restriction ;
                owl:onProperty :hasTopping ;
                owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( :CheeseTopping :FruitTopping :HerbSpiceTopping
                        :NutTopping :SauceTopping :VegetableTopping ) ] ] ) ] ;
    rdfs:subClassOf :PizzaTopping ;
    rdfs:label "Vegetarian Topping" .

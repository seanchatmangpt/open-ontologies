    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .

<http://example.org/ontology/ies-building#ClassOfSuspendedFloorInsulation> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Class Of Suspended Floor Insulation" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A classification of Suspended Floor Insulation types." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .

<http://example.org/ontology/ies-building#SolidFloorInsulation> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Solid Floor Insulation" ;

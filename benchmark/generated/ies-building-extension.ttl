# ========== Heating Production Subtypes ==========

<http://example.org/ontology/ies-building#HeatProductionSystem> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Heat Production System" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "The component of a heating system that generates heat." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://example.org/ontology/ies-building#HeatingSystem> .

<http://example.org/ontology/ies-building#HeatProductionSystemState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Heat Production System State" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A temporal state of a Heat Production System." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .

<http://example.org/ontology/ies-building#ClassOfHeatProductionSystem> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Class Of Heat Production System" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A classification of Heat Production System types." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .

<http://example.org/ontology/ies-building#BoilerSystem> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Boiler System" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A heating system using a boiler to heat water circulated to radiators or underfloor pipes." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://example.org/ontology/ies-building#HeatProductionSystem> .

<http://example.org/ontology/ies-building#BoilerSystemState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Boiler System State" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A temporal state of a Boiler System." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .

<http://example.org/ontology/ies-building#ClassOfBoilerSystem> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Class Of Boiler System" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A classification of Boiler System types." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .

<http://example.org/ontology/ies-building#CondensingBoiler> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Condensing Boiler" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A high-efficiency boiler that recovers heat from exhaust gases." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://example.org/ontology/ies-building#BoilerSystem> .

<http://example.org/ontology/ies-building#CondensingBoilerState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Condensing Boiler State" ;

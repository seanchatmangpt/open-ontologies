    <http://www.w3.org/2000/01/rdf-schema#label> "Assessment End State" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A temporal state of a Assessment End." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .

<http://example.org/ontology/ies-building#ClassOfAssessmentEnd> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Class Of Assessment End" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A classification of Assessment End types." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .

<http://example.org/ontology/ies-building#AssessmentStartState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Assessment Start State" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A temporal state of a Assessment Start." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .

<http://example.org/ontology/ies-building#ClassOfAssessmentStart> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Class Of Assessment Start" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A classification of Assessment Start types." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .

<http://example.org/ontology/ies-building#BuildingSystemState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Building System State" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A temporal state of a Building System." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .


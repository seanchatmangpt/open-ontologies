    <http://www.w3.org/2000/01/rdf-schema#domain> <http://example.org/ontology/ies-building#Building> ;
    <http://www.w3.org/2000/01/rdf-schema#range> <http://example.org/ontology/ies-building#FabricElement> ;
    <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://ies.data.gov.uk/ontology/ies4#relationship> .

<http://example.org/ontology/ies-building#hasTechnicalSystem> a <http://www.w3.org/2002/07/owl#ObjectProperty> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "has Technical System" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "Links a building to one of its building services systems." ;
    <http://www.w3.org/2000/01/rdf-schema#domain> <http://example.org/ontology/ies-building#Building> ;
    <http://www.w3.org/2000/01/rdf-schema#range> <http://example.org/ontology/ies-building#TechnicalSystem> ;
    <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://ies.data.gov.uk/ontology/ies4#relationship> .


# =============================================================================
# HIERARCHY DEEPENING — intermediate grouping classes from building science
# These add depth to subClassOf chains, increasing RDFS inference.
# Every class here is a standard building science classification.
# =============================================================================

# --- Heating system groupings (how heat reaches rooms) ---

bldg:CentralHeatingSystem a rdfs:Class ;
    rdfs:subClassOf bldg:HeatingSystem ;
    rdfs:label "Central Heating System" ;
    rdfs:comment "A whole-house heating system with a central heat source and distribution network delivering heat to multiple rooms." .

bldg:SpaceHeater a rdfs:Class ;
    rdfs:subClassOf bldg:HeatingSystem ;
    rdfs:label "Space Heater" ;
    rdfs:comment "A standalone heater providing warmth to a single room or space, without a distribution network." .

# Reparent: BoilerSystem, HeatPump, CommunityHeatingScheme, WarmAirSystem are central
# RoomHeater, PortableHeater, ElectricStorageHeater are space heaters

bldg:BoilerSystem rdfs:subClassOf bldg:CentralHeatingSystem .
bldg:WarmAirSystem rdfs:subClassOf bldg:CentralHeatingSystem .
bldg:CommunityHeatingScheme rdfs:subClassOf bldg:CentralHeatingSystem .
bldg:MicroCHP rdfs:subClassOf bldg:CentralHeatingSystem .
bldg:HeatPump rdfs:subClassOf bldg:CentralHeatingSystem .

bldg:RoomHeater rdfs:subClassOf bldg:SpaceHeater .
bldg:PortableHeater rdfs:subClassOf bldg:SpaceHeater .

# --- Heating by energy source (combustion vs electric) ---

bldg:CombustionHeatingSystem a rdfs:Class ;
    rdfs:subClassOf bldg:HeatProductionSystem ;
    rdfs:label "Combustion Heating System" ;
    rdfs:comment "A heat production system that burns fuel (gas, oil, LPG, solid fuel, biomass) to generate heat." .

bldg:ElectricHeatingSystem a rdfs:Class ;
    rdfs:subClassOf bldg:HeatProductionSystem ;
    rdfs:label "Electric Heating System" ;
    rdfs:comment "A heat production system that converts electricity directly to heat via resistance elements." .

bldg:BoilerSystem rdfs:subClassOf bldg:CombustionHeatingSystem .
bldg:ElectricStorageHeater rdfs:subClassOf bldg:ElectricHeatingSystem .
bldg:ElectricPanelHeater rdfs:subClassOf bldg:ElectricHeatingSystem .
bldg:ElectricUnderfloorHeating rdfs:subClassOf bldg:ElectricHeatingSystem .

# --- Heating by heat delivery method ---

bldg:RadiantHeatingSystem a rdfs:Class ;
    rdfs:subClassOf bldg:HeatingSystem ;
    rdfs:label "Radiant Heating System" ;
    rdfs:comment "A heating system that delivers heat primarily by thermal radiation (infrared), such as underfloor heating or radiant panels." .

bldg:ConvectiveHeatingSystem a rdfs:Class ;
    rdfs:subClassOf bldg:HeatingSystem ;
    rdfs:label "Convective Heating System" ;
    rdfs:comment "A heating system that delivers heat primarily by warming air through convection, such as radiators or warm air systems." .

bldg:ElectricUnderfloorHeating rdfs:subClassOf bldg:RadiantHeatingSystem .
bldg:RadiatorSystem rdfs:subClassOf bldg:ConvectiveHeatingSystem .
bldg:ConvectorSystem rdfs:subClassOf bldg:ConvectiveHeatingSystem .
bldg:WarmAirDistribution rdfs:subClassOf bldg:ConvectiveHeatingSystem .
bldg:UnderfloorWetSystem rdfs:subClassOf bldg:RadiantHeatingSystem .

# --- Fabric element groupings ---

bldg:OpaqueElement a rdfs:Class ;
    rdfs:subClassOf bldg:FabricElement ;
    rdfs:label "Opaque Element" ;
    rdfs:comment "A building fabric element that is not transparent — walls, roofs, and floors. Heat loss occurs by conduction through the material." .

bldg:TransparentElement a rdfs:Class ;
    rdfs:subClassOf bldg:FabricElement ;
    rdfs:label "Transparent Element" ;
    rdfs:comment "A building fabric element that transmits light — windows and glazed doors. Heat loss occurs by conduction, convection, and radiation." .

bldg:Wall rdfs:subClassOf bldg:OpaqueElement .
bldg:Roof rdfs:subClassOf bldg:OpaqueElement .
bldg:Floor rdfs:subClassOf bldg:OpaqueElement .
bldg:Window rdfs:subClassOf bldg:TransparentElement .
bldg:Door rdfs:subClassOf bldg:OpaqueElement .

# --- Insulation groupings ---

bldg:ThermalInsulation a rdfs:Class ;
    rdfs:subClassOf ies:Asset ;
    rdfs:label "Thermal Insulation" ;
    rdfs:comment "A material or system installed to reduce heat transfer through a building element." .

bldg:ThermalInsulationState a rdfs:Class ;
    rdfs:subClassOf ies:State ;
    rdfs:label "Thermal Insulation State" ;
    rdfs:comment "A temporal state of thermal insulation, capturing its condition and effectiveness." .

bldg:ClassOfThermalInsulation a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Class Of Thermal Insulation" ;
    rdfs:comment "A classification of thermal insulation types." .

bldg:WallInsulation rdfs:subClassOf bldg:ThermalInsulation .
bldg:RoofInsulation rdfs:subClassOf bldg:ThermalInsulation .
bldg:FloorInsulation rdfs:subClassOf bldg:ThermalInsulation .

# --- Spatial groupings ---

bldg:BuiltEntity a rdfs:Class ;
    rdfs:subClassOf ies:Entity ;
    rdfs:label "Built Entity" ;
    rdfs:comment "Any physical thing that has been constructed — buildings, walls, roofs, floors, systems. The common ancestor of all manufactured building components." .

bldg:BuiltEntityState a rdfs:Class ;
    rdfs:subClassOf ies:State ;
    rdfs:label "Built Entity State" ;
    rdfs:comment "A temporal state of a built entity." .

bldg:ClassOfBuiltEntity a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Class Of Built Entity" ;
    rdfs:comment "A classification of built entity types." .

bldg:FabricElement rdfs:subClassOf bldg:BuiltEntity .
bldg:TechnicalSystem rdfs:subClassOf bldg:BuiltEntity .
bldg:Building rdfs:subClassOf bldg:BuiltEntity .
bldg:Structure rdfs:subClassOf bldg:BuiltEntity .

# --- Assessment groupings ---

bldg:FabricAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:EPCAssessment ;
    rdfs:label "Fabric Assessment" ;
    rdfs:comment "An assessment activity inspecting a building fabric element (wall, roof, floor, window)." .

bldg:SystemAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:EPCAssessment ;
    rdfs:label "System Assessment" ;
    rdfs:comment "An assessment activity inspecting a building services system (heating, hot water, lighting, ventilation)." .

bldg:PerformanceCalculation a rdfs:Class ;
    rdfs:subClassOf bldg:EPCAssessment ;
    rdfs:label "Performance Calculation" ;
    rdfs:comment "A calculation deriving an energy performance metric from inspection data." .

# Reparent assessment activities
bldg:WallAssessment rdfs:subClassOf bldg:FabricAssessment .
bldg:RoofAssessment rdfs:subClassOf bldg:FabricAssessment .
bldg:FloorAssessment rdfs:subClassOf bldg:FabricAssessment .
bldg:WindowAssessment rdfs:subClassOf bldg:FabricAssessment .
bldg:HeatingAssessment rdfs:subClassOf bldg:SystemAssessment .
bldg:HeatingControlAssessment rdfs:subClassOf bldg:SystemAssessment .
bldg:SecondaryHeatingAssessment rdfs:subClassOf bldg:SystemAssessment .
bldg:HotWaterAssessment rdfs:subClassOf bldg:SystemAssessment .
bldg:LightingAssessment rdfs:subClassOf bldg:SystemAssessment .
bldg:CalculateSAPRating rdfs:subClassOf bldg:PerformanceCalculation .
bldg:CalculateEIRating rdfs:subClassOf bldg:PerformanceCalculation .
bldg:CalculateCO2Emissions rdfs:subClassOf bldg:PerformanceCalculation .
bldg:EstimateRunningCosts rdfs:subClassOf bldg:PerformanceCalculation .

# --- Certificate groupings ---

bldg:UKEnergyPerformanceCertificate a rdfs:Class ;
    rdfs:subClassOf bldg:EPCCertificate ;
    rdfs:label "UK Energy Performance Certificate" ;
    rdfs:comment "An Energy Performance Certificate issued under UK regulations." .

bldg:UKDomesticEPC rdfs:subClassOf bldg:UKEnergyPerformanceCertificate .
bldg:UKNonDomesticEPC rdfs:subClassOf bldg:UKEnergyPerformanceCertificate .
bldg:DisplayEnergyCertificate rdfs:subClassOf bldg:UKEnergyPerformanceCertificate .

# --- Renewable energy groupings ---

bldg:SolarEnergySystem a rdfs:Class ;
    rdfs:subClassOf bldg:RenewableEnergySystem ;
    rdfs:label "Solar Energy System" ;
    rdfs:comment "A renewable energy system that harvests energy from sunlight — includes photovoltaic (electric) and solar thermal (heat)." .

bldg:SolarPVSystem rdfs:subClassOf bldg:SolarEnergySystem .
bldg:SolarThermalPanel rdfs:subClassOf bldg:SolarEnergySystem .

# --- Hot water groupings ---

bldg:CentralHotWater a rdfs:Class ;
    rdfs:subClassOf bldg:HotWaterSystem ;
    rdfs:label "Central Hot Water" ;
    rdfs:comment "Hot water produced by the central heating system boiler and stored in a cylinder." .

bldg:PointOfUseHotWater a rdfs:Class ;
    rdfs:subClassOf bldg:HotWaterSystem ;
    rdfs:label "Point of Use Hot Water" ;
    rdfs:comment "Hot water produced at or near the point of use, without centralised storage." .

bldg:ElectricImmersionHeater rdfs:subClassOf bldg:CentralHotWater .
bldg:GasMultipoint rdfs:subClassOf bldg:PointOfUseHotWater .
bldg:InstantaneousWaterHeater rdfs:subClassOf bldg:PointOfUseHotWater .
bldg:CommunityHotWater rdfs:subClassOf bldg:CentralHotWater .

# --- Ventilation groupings ---

bldg:MechanicalVentilation a rdfs:Class ;
    rdfs:subClassOf bldg:VentilationSystem ;
    rdfs:label "Mechanical Ventilation" ;
    rdfs:comment "A ventilation system using fans to move air, including extract-only and supply-and-extract with heat recovery." .

bldg:NaturalVentilation a rdfs:Class ;
    rdfs:subClassOf bldg:VentilationSystem ;
    rdfs:label "Natural Ventilation" ;
    rdfs:comment "Ventilation driven by wind pressure and temperature differences through openings, without mechanical assistance." .

bldg:MechanicalExtractOnly a rdfs:Class ;
    rdfs:subClassOf bldg:MechanicalVentilation ;
    rdfs:label "Mechanical Extract Only" ;
    rdfs:comment "Mechanical ventilation that extracts stale air; fresh air enters through trickle vents and gaps." .

bldg:MVHR a rdfs:Class ;
    rdfs:subClassOf bldg:MechanicalVentilation ;
    rdfs:label "MVHR" ;
    rdfs:comment "Mechanical Ventilation with Heat Recovery — extracts stale air and recovers heat to warm incoming fresh air." .

# --- Retrofit groupings ---

bldg:FabricRetrofit a rdfs:Class ;
    rdfs:subClassOf bldg:RetrofitEvent ;
    rdfs:label "Fabric Retrofit" ;
    rdfs:comment "A retrofit intervention improving the building fabric (insulation, glazing, draught-proofing)." .

bldg:SystemRetrofit a rdfs:Class ;
    rdfs:subClassOf bldg:RetrofitEvent ;
    rdfs:label "System Retrofit" ;
    rdfs:comment "A retrofit intervention replacing or upgrading a building system (heating, hot water, lighting)." .

bldg:InsulationUpgrade rdfs:subClassOf bldg:FabricRetrofit .
bldg:WindowReplacement rdfs:subClassOf bldg:FabricRetrofit .
bldg:HeatingSystemReplacement rdfs:subClassOf bldg:SystemRetrofit .
bldg:LightingUpgrade rdfs:subClassOf bldg:SystemRetrofit .
bldg:RenewableInstallation rdfs:subClassOf bldg:SystemRetrofit .

# --- Wall construction groupings ---

bldg:MasonryWall a rdfs:Class ;
    rdfs:subClassOf bldg:ClassOfWall ;
    rdfs:label "Masonry Wall" ;
    rdfs:comment "A wall constructed from masonry units (brick, stone, block) — includes cavity and solid brick." .

bldg:LightweightWall a rdfs:Class ;
    rdfs:subClassOf bldg:ClassOfWall ;
    rdfs:label "Lightweight Wall" ;
    rdfs:comment "A wall constructed from lightweight materials (timber frame, system-built panels)." .

bldg:CavityWall rdfs:subClassOf bldg:MasonryWall .
bldg:SolidBrickWall rdfs:subClassOf bldg:MasonryWall .
bldg:SandstoneWall rdfs:subClassOf bldg:MasonryWall .
bldg:GraniteWall rdfs:subClassOf bldg:MasonryWall .
bldg:CobWall rdfs:subClassOf bldg:MasonryWall .
bldg:TimberFrameWall rdfs:subClassOf bldg:LightweightWall .
bldg:SystemBuiltWall rdfs:subClassOf bldg:LightweightWall .
bldg:ParkHomeWall rdfs:subClassOf bldg:LightweightWall .

# --- Cost estimate groupings ---

bldg:DomesticCostEstimate a rdfs:Class ;
    rdfs:subClassOf bldg:EPCAssessment ;
    rdfs:label "Domestic Cost Estimate" ;
    rdfs:comment "An estimated annual running cost for a domestic building system." .

bldg:HeatingCostEstimate rdfs:subClassOf bldg:DomesticCostEstimate .
bldg:HotWaterCostEstimate rdfs:subClassOf bldg:DomesticCostEstimate .
bldg:LightingCostEstimate rdfs:subClassOf bldg:DomesticCostEstimate .

# --- Property type grouping (from EPC PROPERTY_TYPE) ---

bldg:House a rdfs:Class ;
    rdfs:subClassOf bldg:ClassOfBuilding ;
    rdfs:label "House" ;
    rdfs:comment "A self-contained dwelling forming all or part of a building at ground level with direct external access." .

bldg:Flat a rdfs:Class ;
    rdfs:subClassOf bldg:ClassOfBuilding ;
    rdfs:label "Flat" ;
    rdfs:comment "A self-contained dwelling within a larger building, typically accessed via a shared entrance and stairway." .

# Reparent built forms under House/Flat
bldg:Detached rdfs:subClassOf bldg:House .
bldg:SemiDetached rdfs:subClassOf bldg:House .
bldg:Terraced rdfs:subClassOf bldg:House .
bldg:MidTerrace rdfs:subClassOf bldg:Terraced .
bldg:EndTerrace rdfs:subClassOf bldg:Terraced .
bldg:EnclosedMidTerrace rdfs:subClassOf bldg:Terraced .
bldg:EnclosedEndTerrace rdfs:subClassOf bldg:Terraced .
bldg:Bungalow rdfs:subClassOf bldg:House .
bldg:PurposeBuiltFlat rdfs:subClassOf bldg:Flat .
bldg:ConvertedFlat rdfs:subClassOf bldg:Flat .
bldg:FlatMaisonette rdfs:subClassOf bldg:Flat .

# =============================================================================
# DOMAIN-DERIVED DEEPENING
# Every class below is derived from EPC column structure and data values.
# No reference to any existing building ontology implementation.
# =============================================================================

# --- CURRENT_ENERGY_RATING + POTENTIAL_ENERGY_RATING, *_CURRENT + *_POTENTIAL ---
# Implication: Two temporal scenarios of the same dwelling — 'as assessed' and 'with improvements'

bldg:AssessmentScenario a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Assessment Scenario" ;
    rdfs:comment "A scenario in an energy assessment — either 'as assessed' (current) or 'with all improvements applied' (potential)." .

bldg:CurrentScenario a rdfs:Class ;
    rdfs:subClassOf bldg:AssessmentScenario ;
    rdfs:label "Current Scenario" ;
    rdfs:comment "The 'as assessed' scenario representing the dwelling in its current state." .

bldg:PotentialScenario a rdfs:Class ;
    rdfs:subClassOf bldg:AssessmentScenario ;
    rdfs:label "Potential Scenario" ;
    rdfs:comment "The 'with improvements' scenario representing the dwelling after recommended measures." .

# --- WALLS_DESCRIPTION + WALLS_ENERGY_EFF + WALLS_ENV_EFF (× 4 elements) ---
# Implication: Each fabric element is assessed independently, producing a description and two ratings

bldg:FabricAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:EPCAssessment ;
    rdfs:label "Fabric Assessment" ;
    rdfs:comment "An assessment of a specific building fabric element, producing a description and efficiency ratings." .

bldg:WallAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:FabricAssessment ;
    rdfs:label "Wall Assessment" ;
    rdfs:comment "An assessment of the walls of a dwelling." .

bldg:RoofAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:FabricAssessment ;
    rdfs:label "Roof Assessment" ;
    rdfs:comment "An assessment of the roof of a dwelling." .

bldg:FloorAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:FabricAssessment ;
    rdfs:label "Floor Assessment" ;
    rdfs:comment "An assessment of the floor of a dwelling." .

bldg:WindowAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:FabricAssessment ;
    rdfs:label "Window Assessment" ;
    rdfs:comment "An assessment of the windows of a dwelling." .

# --- MAINHEAT_DESCRIPTION + MAINHEAT_ENERGY_EFF + MAINHEAT_ENV_EFF (× 5 systems) ---
# Implication: Each building system is assessed independently

bldg:SystemAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:EPCAssessment ;
    rdfs:label "System Assessment" ;
    rdfs:comment "An assessment of a specific building system." .

bldg:HeatingAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:SystemAssessment ;
    rdfs:label "Heating Assessment" ;
    rdfs:comment "An assessment of the main heating system." .

bldg:HeatingControlAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:SystemAssessment ;
    rdfs:label "Heating Control Assessment" ;
    rdfs:comment "An assessment of the heating controls." .

bldg:SecondaryHeatingAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:SystemAssessment ;
    rdfs:label "Secondary Heating Assessment" ;
    rdfs:comment "An assessment of the secondary heating system." .

bldg:HotWaterAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:SystemAssessment ;
    rdfs:label "Hot Water Assessment" ;
    rdfs:comment "An assessment of the hot water system." .

bldg:LightingAssessment a rdfs:Class ;
    rdfs:subClassOf bldg:SystemAssessment ;
    rdfs:label "Lighting Assessment" ;
    rdfs:comment "An assessment of the lighting system." .

# --- HEATING_COST_CURRENT + HOT_WATER_COST_CURRENT + LIGHTING_COST_CURRENT (× 2 scenarios) ---
# Implication: Running costs are estimated separately per system

bldg:AnnualCostEstimate a rdfs:Class ;
    rdfs:subClassOf ies:Measure ;
    rdfs:label "Annual Cost Estimate" ;
    rdfs:comment "An estimated annual running cost in GBP." .

bldg:HeatingCostEstimate a rdfs:Class ;
    rdfs:subClassOf bldg:AnnualCostEstimate ;
    rdfs:label "Heating Cost Estimate" ;
    rdfs:comment "Estimated annual cost of space heating." .

bldg:HotWaterCostEstimate a rdfs:Class ;
    rdfs:subClassOf bldg:AnnualCostEstimate ;
    rdfs:label "Hot Water Cost Estimate" ;
    rdfs:comment "Estimated annual cost of hot water." .

bldg:LightingCostEstimate a rdfs:Class ;
    rdfs:subClassOf bldg:AnnualCostEstimate ;
    rdfs:label "Lighting Cost Estimate" ;
    rdfs:comment "Estimated annual cost of lighting." .

bldg:TotalCostEstimate a rdfs:Class ;
    rdfs:subClassOf bldg:AnnualCostEstimate ;
    rdfs:label "Total Cost Estimate" ;
    rdfs:comment "Estimated total annual energy cost." .

# --- WALLS_DESCRIPTION typical values ---
# Implication: Wall descriptions decompose into construction type + insulation type + insulation location

bldg:WallConstructionType a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Wall Construction Type" ;
    rdfs:comment "A classification of wall construction methods." .

bldg:WallInsulationType a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Wall Insulation Type" ;
    rdfs:comment "A classification of wall insulation methods." .

bldg:CavityWall a bldg:WallConstructionType ;
    rdfs:label "Cavity Wall" ;
    rdfs:comment "A wall with two leaves separated by a cavity." .

bldg:SolidBrickWall a bldg:WallConstructionType ;
    rdfs:label "Solid Brick Wall" ;
    rdfs:comment "A wall of solid brick or stone construction." .

bldg:TimberFrameWall a bldg:WallConstructionType ;
    rdfs:label "Timber Frame Wall" ;
    rdfs:comment "A wall with a timber structural frame." .

bldg:SystemBuiltWall a bldg:WallConstructionType ;
    rdfs:label "System Built Wall" ;
    rdfs:comment "A wall using prefabricated or system-built construction." .

bldg:SandstoneWall a bldg:WallConstructionType ;
    rdfs:label "Sandstone Wall" ;
    rdfs:comment "A wall of sandstone block construction." .

bldg:GraniteWall a bldg:WallConstructionType ;
    rdfs:label "Granite Wall" ;
    rdfs:comment "A wall of granite block construction." .

bldg:CobWall a bldg:WallConstructionType ;
    rdfs:label "Cob Wall" ;
    rdfs:comment "A wall of traditional cob (earth) construction." .

bldg:ParkHomeWall a bldg:WallConstructionType ;
    rdfs:label "Park Home Wall" ;
    rdfs:comment "A wall of park home (prefabricated lightweight) construction." .

bldg:FilledCavity a bldg:WallInsulationType ;
    rdfs:label "Filled Cavity" ;
    rdfs:comment "Insulation injected into or placed within the wall cavity." .

bldg:ExternalInsulation a bldg:WallInsulationType ;
    rdfs:label "External Insulation" ;
    rdfs:comment "Insulation applied to the outside face of the wall." .

bldg:InternalInsulation a bldg:WallInsulationType ;
    rdfs:label "Internal Insulation" ;
    rdfs:comment "Insulation applied to the inside face of the wall." .

bldg:NoWallInsulation a bldg:WallInsulationType ;
    rdfs:label "No Wall Insulation" ;
    rdfs:comment "No wall insulation present." .

bldg:AsBuiltInsulation a bldg:WallInsulationType ;
    rdfs:label "As Built Insulation" ;
    rdfs:comment "Original insulation as installed during construction." .

bldg:PartialFill a bldg:WallInsulationType ;
    rdfs:label "Partial Fill" ;
    rdfs:comment "Partial cavity fill insulation." .

# --- ROOF_DESCRIPTION typical values ---
# Implication: Roof descriptions decompose into roof type + insulation depth + insulation location

bldg:RoofConstructionType a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Roof Construction Type" ;
    rdfs:comment "A classification of roof construction types." .

bldg:RoofInsulationLocation a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Roof Insulation Location" ;
    rdfs:comment "Where insulation is located relative to the roof structure." .

bldg:PitchedRoof a bldg:RoofConstructionType ;
    rdfs:label "Pitched Roof" ;
    rdfs:comment "A roof with sloping surfaces meeting at a ridge." .

bldg:FlatRoof a bldg:RoofConstructionType ;
    rdfs:label "Flat Roof" ;
    rdfs:comment "A roof with minimal slope, typically less than 10 degrees." .

bldg:ThatchedRoof a bldg:RoofConstructionType ;
    rdfs:label "Thatched Roof" ;
    rdfs:comment "A roof covered with straw, reed, or similar natural material." .

bldg:RoomInRoof a bldg:RoofConstructionType ;
    rdfs:label "Room In Roof" ;
    rdfs:comment "A roof space converted for habitable use." .

bldg:MansardRoof a bldg:RoofConstructionType ;
    rdfs:label "Mansard Roof" ;
    rdfs:comment "A roof with two slopes on each side, the lower being steeper." .

bldg:LoftInsulation a bldg:RoofInsulationLocation ;
    rdfs:label "Loft Insulation" ;
    rdfs:comment "Insulation laid between or over ceiling joists in the loft." .

bldg:RafterInsulation a bldg:RoofInsulationLocation ;
    rdfs:label "Rafter Insulation" ;
    rdfs:comment "Insulation fitted between or over the roof rafters." .

bldg:FlatRoofTopInsulation a bldg:RoofInsulationLocation ;
    rdfs:label "Flat Roof Top Insulation" ;
    rdfs:comment "Insulation applied to the top of a flat roof deck." .

bldg:NoRoofInsulation a bldg:RoofInsulationLocation ;
    rdfs:label "No Roof Insulation" ;
    rdfs:comment "No roof insulation present." .

# --- FLOOR_DESCRIPTION typical values ---
# Implication: Floor descriptions decompose into floor type + insulation presence

bldg:FloorConstructionType a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Floor Construction Type" ;
    rdfs:comment "A classification of floor construction types." .

bldg:SuspendedTimberFloor a bldg:FloorConstructionType ;
    rdfs:label "Suspended Timber Floor" ;
    rdfs:comment "A floor of timber boards on joists with a void beneath." .

bldg:SolidConcreteFloor a bldg:FloorConstructionType ;
    rdfs:label "Solid Concrete Floor" ;
    rdfs:comment "A floor of solid concrete slab on the ground." .

bldg:SuspendedConcreteFloor a bldg:FloorConstructionType ;
    rdfs:label "Suspended Concrete Floor" ;
    rdfs:comment "A floor of precast or in-situ concrete with a void beneath." .

bldg:FloorToExternalAir a bldg:FloorConstructionType ;
    rdfs:label "Floor To External Air" ;
    rdfs:comment "A floor exposed to external air on its underside (e.g. over a passageway)." .

bldg:FloorOverUnheatedSpace a bldg:FloorConstructionType ;
    rdfs:label "Floor Over Unheated Space" ;
    rdfs:comment "A floor above an unheated space such as a garage." .

# --- MAINHEAT_DESCRIPTION compound values ---
# Implication: Heating descriptions decompose into production method + distribution method + fuel source

bldg:HeatProductionMethod a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Heat Production Method" ;
    rdfs:comment "A classification of methods for producing heat." .

bldg:HeatDistributionMethod a rdfs:Class ;
    rdfs:subClassOf ies:ClassOfEntity ;
    rdfs:label "Heat Distribution Method" ;
    rdfs:comment "A classification of methods for distributing heat to rooms." .

bldg:GasBoiler a bldg:HeatProductionMethod ;
    rdfs:label "Gas Boiler" ;
    rdfs:comment "Heat produced by a gas-fired boiler." .

bldg:OilBoiler a bldg:HeatProductionMethod ;
    rdfs:label "Oil Boiler" ;
    rdfs:comment "Heat produced by an oil-fired boiler." .

bldg:LPGBoiler a bldg:HeatProductionMethod ;
    rdfs:label "L P G Boiler" ;
    rdfs:comment "Heat produced by an LPG-fired boiler." .

bldg:ElectricBoiler a bldg:HeatProductionMethod ;
    rdfs:label "Electric Boiler" ;
    rdfs:comment "Heat produced by an electric boiler." .

bldg:CondensingBoilerMethod a bldg:HeatProductionMethod ;
    rdfs:label "Condensing Boiler Method" ;
    rdfs:comment "Heat produced by a high-efficiency condensing boiler." .

bldg:CombiBoilerMethod a bldg:HeatProductionMethod ;
    rdfs:label "Combi Boiler Method" ;
    rdfs:comment "Heat produced by a combination boiler providing heating and hot water." .

bldg:BackBoilerMethod a bldg:HeatProductionMethod ;
    rdfs:label "Back Boiler Method" ;
    rdfs:comment "Heat produced by a back boiler fitted behind a fireplace." .

bldg:AirSourceHeatPumpMethod a bldg:HeatProductionMethod ;
    rdfs:label "Air Source Heat Pump Method" ;
    rdfs:comment "Heat extracted from outside air by a heat pump." .

bldg:GroundSourceHeatPumpMethod a bldg:HeatProductionMethod ;
    rdfs:label "Ground Source Heat Pump Method" ;
    rdfs:comment "Heat extracted from the ground by a heat pump." .

bldg:ElectricStorageMethod a bldg:HeatProductionMethod ;
    rdfs:label "Electric Storage Method" ;
    rdfs:comment "Heat stored in thermal mass during off-peak electricity." .

bldg:ElectricPanelMethod a bldg:HeatProductionMethod ;
    rdfs:label "Electric Panel Method" ;
    rdfs:comment "Direct electric heating via wall-mounted panels." .

bldg:ElectricUnderfloorMethod a bldg:HeatProductionMethod ;
    rdfs:label "Electric Underfloor Method" ;
    rdfs:comment "Direct electric heating via floor-embedded elements." .

bldg:WarmAirMethod a bldg:HeatProductionMethod ;
    rdfs:label "Warm Air Method" ;
    rdfs:comment "Heat produced and distributed as heated air." .

bldg:CommunityHeatingMethod a bldg:HeatProductionMethod ;
    rdfs:label "Community Heating Method" ;
    rdfs:comment "Heat supplied from a communal or district network." .

bldg:MicroCHPMethod a bldg:HeatProductionMethod ;
    rdfs:label "Micro C H P Method" ;
    rdfs:comment "Heat and electricity co-generated by a micro-CHP unit." .

bldg:RoomHeaterMethod a bldg:HeatProductionMethod ;
    rdfs:label "Room Heater Method" ;
    rdfs:comment "Heat produced by standalone room heaters." .

bldg:PortableHeaterMethod a bldg:HeatProductionMethod ;
    rdfs:label "Portable Heater Method" ;
    rdfs:comment "Heat produced by portable electric heaters." .

bldg:SolidFuelHeaterMethod a bldg:HeatProductionMethod ;
    rdfs:label "Solid Fuel Heater Method" ;
    rdfs:comment "Heat produced by a solid fuel burning appliance." .

bldg:WetRadiators a bldg:HeatDistributionMethod ;
    rdfs:label "Wet Radiators" ;
    rdfs:comment "Heat distributed via hot water radiators." .

bldg:UnderfloorWet a bldg:HeatDistributionMethod ;
    rdfs:label "Underfloor Wet" ;
    rdfs:comment "Heat distributed via hot water pipes in the floor." .

bldg:UnderfloorElectric a bldg:HeatDistributionMethod ;
    rdfs:label "Underfloor Electric" ;
    rdfs:comment "Heat distributed via electric elements in the floor." .

bldg:WarmAirDucts a bldg:HeatDistributionMethod ;
    rdfs:label "Warm Air Ducts" ;
    rdfs:comment "Heat distributed via ducted warm air." .

bldg:Convectors a bldg:HeatDistributionMethod ;
    rdfs:label "Convectors" ;
    rdfs:comment "Heat distributed via fan or natural convector units." .

bldg:DirectElectric a bldg:HeatDistributionMethod ;
    rdfs:label "Direct Electric" ;

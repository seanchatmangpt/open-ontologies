    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://example.org/ontology/ies-building#FloorInsulation> .

<http://example.org/ontology/ies-building#SolidFloorInsulationState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Solid Floor Insulation State" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A temporal state of a Solid Floor Insulation." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#State> .

<http://example.org/ontology/ies-building#ClassOfSolidFloorInsulation> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Class Of Solid Floor Insulation" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "A classification of Solid Floor Insulation types." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .


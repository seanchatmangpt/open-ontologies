    <http://www.w3.org/2000/01/rdf-schema#label> "contains Space" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "Links a structure unit to a space within it." ;
    <http://www.w3.org/2000/01/rdf-schema#domain> <http://example.org/ontology/ies-building#StructureUnit> ;
    <http://www.w3.org/2000/01/rdf-schema#range> <http://example.org/ontology/ies-building#Space> ;
    <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://ies.data.gov.uk/ontology/ies4#relationship> .

<http://example.org/ontology/ies-building#hasFabricElement> a <http://www.w3.org/2002/07/owl#ObjectProperty> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "has Fabric Element" ;

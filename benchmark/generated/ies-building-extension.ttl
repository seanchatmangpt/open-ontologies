    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://ies.data.gov.uk/ontology/ies4#ClassOfEntity> .

<http://example.org/ontology/ies-building#SuspendedFloorInsulation> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Suspended Floor Insulation" ;
    <http://www.w3.org/2000/01/rdf-schema#comment> "Insulation fitted between joists of a suspended floor." ;
    <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://example.org/ontology/ies-building#FloorInsulation> .

<http://example.org/ontology/ies-building#SuspendedFloorInsulationState> a <http://www.w3.org/2000/01/rdf-schema#Class> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "Suspended Floor Insulation State" ;

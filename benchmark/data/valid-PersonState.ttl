@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .

_:person1 a ies_core:Person .

_:person1State ies_top:isTemporalPartOf _:person1 ;
    ies_core:hasIdentifiedGender _:person1Gender ;
    ies_core:hasName _:person1Name ;
    ies_core:hasSkill _:person1Skill .

_:person1Gender a ies_core:Gender .

_:person1Name a ies_core:PersonName .

_:person1Skill a ies_core:Skill .


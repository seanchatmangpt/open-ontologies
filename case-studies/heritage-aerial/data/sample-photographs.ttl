# =============================================================================
# RECORD 4 — ENHANCED
# WWII RAF reconnaissance, Hamburg, 1943 (full digitisation provenance)
# =============================================================================

ex:sortie-RAF-541-HAMBURG-43 a naph:Sortie ;
    rdfs:label "Sortie RAF/541/Hamburg/1943" ;
    naph:sortieReference "RAF/541/HAM/1943-07-26" ;
    naph:squadron "541 Squadron" ;
    naph:aircraft "Supermarine Spitfire PR.IX" .

ex:photo-004 a naph:AerialPhotograph ;
    dcterms:type dctype:StillImage ;
    rdfs:label "Hamburg post-firestorm frame 1287" ;
    naph:hasIdentifier "https://w3id.org/naph/photo/RAF-541-HAM-1943-07-26-1287" ;
    naph:partOfSortie ex:sortie-RAF-541-HAMBURG-43 ;
    naph:belongsToCollection ex:NCAPCollection ;
    naph:capturedOn "1943-07-30"^^xsd:date ;
    naph:coversArea ex:footprint-004 ;
    naph:hasRightsStatement ex:CrownCopyrightExpired ;
    naph:hasCaptureEvent ex:capture-004 ;
    naph:hasDigitalSurrogate ex:surrogate-004-master, ex:surrogate-004-access ;
    naph:hasProvenanceChain ex:provenance-004 ;
    naph:compliesWithTier naph:TierEnhanced .

ex:footprint-004 a naph:GeographicFootprint ;
    naph:asWKT "POLYGON((9.95 53.53, 10.05 53.53, 10.05 53.58, 9.95 53.58, 9.95 53.53))"^^geo:wktLiteral .

ex:capture-004 a naph:CaptureEvent ;
    naph:flightAltitude 9144.0 ;
    naph:cameraType "F.52 split-pair vertical camera, 36-inch lens" .

ex:surrogate-004-master a naph:DigitalSurrogate ;
    rdfs:label "Preservation master" ;
    naph:digitisedOn "2018-04-12"^^xsd:date ;
    naph:scanResolution 1200 ;
    naph:fileFormat "image/tiff" ;
    naph:digitisedBy ex:NCAP .

ex:surrogate-004-access a naph:DigitalSurrogate ;
    rdfs:label "Access copy" ;
    naph:digitisedOn "2018-04-12"^^xsd:date ;
    naph:scanResolution 600 ;
    naph:fileFormat "image/jp2" ;
    naph:digitisedBy ex:NCAP .

ex:provenance-004 a naph:ProvenanceChain ;
    rdfs:label "RAF 1943 → Air Ministry → MoD → NCAP transfer 2008" .


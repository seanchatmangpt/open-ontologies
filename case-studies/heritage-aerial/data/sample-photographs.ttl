@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dctype:  <http://purl.org/dc/dcmitype/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix naph:    <https://w3id.org/naph/ontology#> .
@prefix ex:      <https://w3id.org/naph/example/> .

# =============================================================================
# Sample dataset — 10 illustrative aerial photograph records
# Modeled on NCAP collection structure (publicly known characteristics)
# Distributed across the three compliance tiers to demonstrate the gap.
#
# Records 1-3: BASELINE only (mirrors current public Air Photo Finder state)
# Records 4-7: ENHANCED (achievable with current digitisation workflow + structure)
# Records 8-10: ASPIRATIONAL (full semantic enrichment + cross-collection linking)
# =============================================================================

# -----------------------------------------------------------------------------
# Custodial institution & collection
# -----------------------------------------------------------------------------

ex:NCAP a naph:CustodialInstitution ;
    rdfs:label "National Collection of Aerial Photography" ;
    skos:altLabel "NCAP" .

ex:NCAPCollection a naph:Collection ;
    rdfs:label "NCAP Holdings" ;
    naph:custodian ex:NCAP .

# -----------------------------------------------------------------------------
# Rights statements (reusable)
# -----------------------------------------------------------------------------

ex:CrownCopyrightExpired a naph:RightsStatement ;
    naph:rightsURI <http://rightsstatements.org/vocab/NoC-OKLR/1.0/> ;
    naph:rightsLabel "No Copyright — Other Known Legal Restrictions" .

ex:CrownCopyright a naph:RightsStatement ;
    naph:rightsURI <https://www.nationalarchives.gov.uk/information-management/re-using-public-sector-information/uk-government-licensing-framework/crown-copyright/> ;
    naph:rightsLabel "Crown Copyright" .

ex:NARAPublicDomain a naph:RightsStatement ;
    naph:rightsURI <http://rightsstatements.org/vocab/NoC-US/1.0/> ;
    naph:rightsLabel "No Copyright — United States" .

# =============================================================================
# RECORD 1 — BASELINE ONLY
# WWII RAF reconnaissance, Berlin, 1944
# =============================================================================

ex:sortie-RAF-106G-UK-1655 a naph:Sortie ;
    rdfs:label "Sortie RAF/106G/UK/1655" ;
    naph:sortieReference "RAF/106G/UK/1655" .

ex:photo-001 a naph:AerialPhotograph ;
    dcterms:type dctype:StillImage ;
    rdfs:label "Berlin reconnaissance frame 4023" ;
    naph:hasIdentifier "https://w3id.org/naph/photo/RAF-106G-UK-1655-4023" ;
    naph:partOfSortie ex:sortie-RAF-106G-UK-1655 ;
    naph:belongsToCollection ex:NCAPCollection ;
    naph:capturedOn "1944-03-28"^^xsd:date ;
    naph:coversArea ex:footprint-001 ;
    naph:hasRightsStatement ex:CrownCopyrightExpired ;
    naph:compliesWithTier naph:TierBaseline .

ex:footprint-001 a naph:GeographicFootprint ;
    naph:asWKT "POLYGON((13.35 52.50, 13.45 52.50, 13.45 52.55, 13.35 52.55, 13.35 52.50))"^^geo:wktLiteral .


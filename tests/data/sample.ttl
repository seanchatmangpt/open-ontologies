@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/test#> .

<http://example.org/test> rdf:type owl:Ontology ;
    rdfs:label "Test Ontology" .

ex:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human being" .

ex:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "A group of people" .

ex:worksFor a owl:ObjectProperty ;
    rdfs:label "works for" ;
    rdfs:comment "Employment relationship" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Organization ;
    rdfs:subPropertyOf <http://example.org/test#relationship> .

ex:Alice a ex:Person ;
    rdfs:label "Alice" ;
    ex:worksFor ex:AcmeCorp .

ex:AcmeCorp a ex:Organization ;
    rdfs:label "Acme Corp" .

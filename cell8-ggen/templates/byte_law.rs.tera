//! Generated byte law types. Fixed layout. Rust authority.

{% for row in sparql_results %}
/// {{ row.doc | default(value=row.label) }}
/// Size: {{ row.byte_size }} bytes
#[{{ row.repr }}]
#[derive(Debug, Clone, Copy, Default)]
pub struct {{ row.label }};

#[cfg(test)]
mod {{ row.label | lower }}_tests {
    use super::*;
    #[test]
    fn size_check() {
        assert_eq!(
            std::mem::size_of::<{{ row.label }}>(),
            {{ row.byte_size }},
            "{{ row.label }} must be exactly {{ row.byte_size }} bytes"
        );
    }
}
{% endfor %}

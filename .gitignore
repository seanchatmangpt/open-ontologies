# Ignore generated OWL files in root, but keep benchmark references
/*.owl

# Secrets — Invariant 7. NEVER commit anything matching these patterns.
.env
.env.*
*.pem
*.key
secrets/

# Local Claude Code config — user-specific.
.claude/

# Local OntoStar working directories not part of the manufactured solution.
cell8-ggen/
ontology/cell8-*.ttl

# ggen pipeline runtime state — regenerable cache and current sync state.
# `.ggen/receipts/` is left tracked: it is the project's audit trail.
.ggen/cache/
.ggen/sync-state.json

# Source-code backup files (e.g. *.rs.backup left by code generators).
*.rs.backup

# Erlang / AtomVM build outputs.
*.beam
*.avm

# Editor / OS noise.
.DS_Store
*.swp
*.swo

# Backup files left by tools.
*.backup

# DuckDB database files.
*.duckdb
